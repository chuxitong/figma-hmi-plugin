Name=\"text-xs text-gray-500 mt-1\">{card.trend}</div>\n                        </div>\n                    ))}\n                </div>\n            );\n        };\n\n        const FilterSection = () => {\n            return (\n                <div className=\"bg-white rounded-lg border border-gray-200 p-4 mb-6\">\n                    <div className=\"flex items-center justify-between\">\n                        <div className=\"flex items-center space-x-4\">\n                            <span className=\"text-gray-600 text-sm\">Severity</span>\n                            <div className=\"flex space-x-2\">\n                                <button className=\"px-4 py-1 bg-red-600 text-white text-xs rounded-full font-medium\">\n                                    CRITICAL\n                                </button>\n                                <button className=\"px-4 py-1 bg-orange-500 text-white text-xs rounded-full font-medium\">\n                                    WARNING\n                                </button>\n                                <button className=\"px-4 py-1 bg-blue-500 text-white text-xs rounded-full font-medium\">\n                                    INFO\n                                </button>\n                            </div>\n                        </div>\n                        \n                        <div className=\"flex items-center space-x-4\">\n                            <span className=\"text-gray-600 text-sm\">Tag / описание</span>\n                            <input \n                                type=\"text\" \n                                placeholder=\"Введите тер или часть описания...\" \n                                className=\"border border-gray-300 rounded px-3 py-1 text-sm w-64 focus:outline-none focus:border-blue-500\"\n                            />\n                            \n                            <div className=\"flex space-x-2\">\n                                <button className=\"px-6 py-1 bg-green-700 text-white text-sm rounded font-medium\">\n                                    ACK ALL\n                                </button>\n                                <button className=\"px-4 py-1 border border-gray-300 text-gray-700 text-sm rounded\">\n                                    Export...\n                                </button>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            );\n        };\n\n        const AlarmTable = () => {\n            const alarms = [\n                {\n                    severity: \"CRITICAL\",\n                    time: \"14:31:42\",\n                    tag: \"TT-301\",\n                    description: \"Motor temperature exceeds high-high limit\",\n                    value: \"94.2\",\n                    unit: \"°C\",\n                    source: \"Refinery2/U2/M-301\"\n                },\n                {\n                    severity: \"CRITICAL\",\n                    time: \"14:28:15\",\n                    tag: \"PT-102\",\n                    description: \"Discharge pressure too high\",\n                    value: \"5.8\",\n                    unit: \"bar\",\n                    source: \"Refinery2/U1/P-102\"\n                },\n                {\n                    severity: \"WARNING\",\n                    time: \"14:22:10\",\n                    tag: \"FT-401\",\n                    description: \"Flow rate deviation > 12 %\",\n                    value: \"23.1\",\n                    unit: \"m³/h\",\n                    source: \"Refinery2/U4/F-401\"\n                },\n                {\n                    severity: \"WARNING\",\n                    time: \"14:15:30\",\n                    tag: \"CT-502\",\n                    description: \"Cooling water temperature rising\",\n                    value: \"38.5\",\n                    unit: \"°C\",\n                    source: \"Utilities/CW-502\"\n                },\n                {\n                    severity: \"WARNING\",\n                    time: \"14:09:54\",\n                    tag: \"LT-301\",\n                    description: \"Tank level above setpoint\",\n                    value: \"88.4\",\n                    unit: \"%\",\n                    source: \"Refinery2/U2/T-301\"\n                },\n                {\n                    severity: \"INFO\",\n                    time: \"14:05:18\",\n                    tag: \"PDT-201\",\n                    description: \"Filter differential pressure\",\n                    value: \"0.8\",\n                    unit: \"bar\",\n                    source: \"Refinery2/U2/F-201\"\n                },\n                {\n                    severity: \"INFO\",\n                    time: \"14:01:09\",\n                    tag: \"FT-902\",\n                    description: \"Flow within tolerance — restored\",\n                    value: \"180\",\n                    unit: \"m³/h\",\n                    source: \"Refinery2/U9/F-902\"\n                },\n                {\n                    severity: \"INFO\",\n                    time: \"13:54:22\",\n                    tag: \"CT-101\",\n                    description: \"Communication restored\",\n                    value: \"—\",\n                    unit: \"\",\n                    source: \"Bus/CT-101\"\n                }\n            ];\n\n            const getSeverityColor = (severity) => {\n                switch(severity) {\n                    case \"CRITICAL\": return \"bg-red-600 text-white\";\n                    case \"WARNING\": return \"bg-orange-500 text-white\";\n                    case \"INFO\": return \"bg-blue-500 text-white\";\n                    default: return \"bg-gray-500 text-white\";\n                }\n            };\n\n            return (\n                <div className=\"bg-white rounded-lg border border-gray-200\">\n                    <table className=\"w-full\">\n                        <thead className=\"bg-gray-100\">\n                            <tr>\n                                <th className=\"text-left py-3 px-4 text-sm font-medium text-gray-600\">Severity</th>\n                                <th className=\"text-left py-3 px-4 text-sm font-medium text-gray-600\">Time</th>\n                                <th className=\"text-left py-3 px-4 text-sm font-medium text-gray-600\">Tag</th>\n                                <th className=\"text-left py-3 px-4 text-sm font-medium text-gray-600\">Description</th>\n                                <th className=\"text-left py-3 px-4 text-sm font-medium text-gray-600\">Value</th>\n                                <th className=\"text-left py-3 px-4 text-sm font-medium text-gray-600\">Source</th>\n                                <th className=\"text-left py-3 px-4 text-sm font-medium text-gray-600\">Action</th>\n                            </tr>\n                        </thead>\n                        <tbody>\n                            {alarms.map((alarm, index) => (\n                                <tr key={index} className=\"border-b border-gray-100 hover:bg-gray-50\">\n                                    <td className=\"py-3 px-4\">\n                                        <span className={`px-3 py-1 text-xs rounded ${getSeverityColor(alarm.severity)}`}>\n                                            {alarm.severity}\n                                        </span>\n                                    </td>\n                                    <td className=\"py-3 px-4 text-sm text-gray-700\">{alarm.time}</td>\n                                    <td className=\"py-3 px-4 text-sm font-medium text-gray-800\">{alarm.tag}</td>\n                                    <td className=\"py-3 px-4 text-sm text-gray-700\">{alarm.description}</td>\n                                    <td className=\"py-3 px-4 text-sm text-gray-700\">\n                                        {alarm.value} <span className=\"text-gray-500\">{alarm.unit}</span>\n                                    </td>\n                                    <td className=\"py-3 px-4 text-sm text-gray-500\">{alarm.source}</td>\n                                    <td className=\"py-3 px-4\">\n                                        <div className=\"flex space-x-2\">\n                                            <button className=\"px-4 py-1 border border-gray-300 text-gray-700 text-sm rounded hover:bg-gray-50\">\n                                                ACK\n                                            </button>\n                                            <button className=\"px-4 py-1 border border-gray-300 text-gray-700 text-sm rounded hover:bg-gray-50\">\n                                                View\n                                            </button>\n                                        </div>\n                                    </td>\n                                </tr>\n                            ))}\n                        </tbody>\n                    </table>\n                </div>\n            );\n        };\n\n        const Footer = () => {\n            return (\n                <footer className=\"px-6 py-4 text-xs text-gray-500 border-t border-gray-200\">\n                    <div>\n                        Connection: OK · Latency: 22 ms · Compliance: ANSI/ISA-101.01-2015 — colour + text + shape encoding for every state\n                    </div>\n                </footer>\n            );\n        };\n\n        ReactDOM.render(<App />, document.getElementById('root'));\n    </script>\n</body>\n</html>",
