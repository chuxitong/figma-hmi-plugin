olute top-0 -right-2 text-xs text-gray-600\">72%</div>\n                                </div>\n                                <span className=\"mt-2 text-xs text-gray-600\">T-101</span>\n                            </div>\n                            \n                            {/* Pipe 1 */}\n                            <div className=\"h-1 bg-gray-400 w-8\"></div>\n                            \n                            {/* P-101 Pump */}\n                            <div className=\"flex flex-col items-center\">\n                                <div className=\"w-12 h-12 rounded-full border-2 border-gray-400 flex items-center justify-center bg-gray-100\">\n                                    <div className=\"w-8 h-8 rounded-full bg-green-600 flex items-center justify-center\">\n                                        <i className=\"fas fa-sync-alt text-white text-xs\"></i>\n                                    </div>\n                                </div>\n                                <span className=\"mt-2 text-xs text-gray-600\">P-101</span>\n                            </div>\n                            \n                            {/* Pipe 2 */}\n                            <div className=\"h-1 bg-gray-400 w-8\"></div>\n                            \n                            {/* V-201 Valve */}\n                            <div className=\"flex flex-col items-center\">\n                                <div className=\"w-12 h-12 rounded-full border-2 border-gray-400 flex items-center justify-center bg-gray-100\">\n                                    <div className=\"w-6 h-6 rounded-full bg-green-600\"></div>\n                                </div>\n                                <span className=\"mt-2 text-xs text-gray-600\">V-201</span>\n                            </div>\n                            \n                            {/* Pipe 3 */}\n                            <div className=\"h-1 bg-gray-400 w-8\"></div>\n                          