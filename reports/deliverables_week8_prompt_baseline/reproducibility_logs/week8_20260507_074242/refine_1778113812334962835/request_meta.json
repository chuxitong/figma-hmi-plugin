md text-sm\">\n              2026-04-19 14:32:07 MSK\n            </div>\n          </div>\n        </header>\n      );\n    }\n\n    function MetricCard({ title, value, change, color }) {\n      return (\n        <div className=\"bg-white rounded-lg border border-gray-200 overflow-hidden\">\n          <div className=\"p-4\">\n            <div className=\"text-gray-500 text-sm\">{title}</div>\n            <div className=\"text-3xl font-bold text-gray-800 mt-1\">{value}</div>\n            <div className=\"text-xs text-gray-600 mt-2\">\n              {change}\n            </div>\n          </div>\n        </div>\n      );\n    }\n\n    function MetricsSection() {\n      return (\n        <div className=\"grid grid-cols-1 md:grid-cols-4 gap-4 mb-4\">\n          <MetricCard \n            title=\"Temperature\" \n            value=\"72.4\" \n            change=\"+1.2 са смеху\" \n            color=\"green\" \n          />\n          <MetricCard \n            title=\"Pressure\" \n            value=\"3.21\" \n            change=\"+0.04 са смеху\" \n            color=\"orange\" \n          />\n          <MetricCard \n            title=\"Flow\" \n            value=\"184\" \n            change=\"▼ -3 са смеху\" \n            color=\"orange\" \n          />\n          <MetricCard \n            title=\"Setpoint dev\" \n            value=\"1.8\" \n            change=\"+0.2 са смеху\" \n            color=\"green\" \n          />\n        </div>\n      );\n    }\n\n    function TrendChartSection() {\n      return (\n        <div className=\"bg-white rounded-lg border border-gray-200 p-4\">\n          <div className=\"flex justify-between items-center mb-4\">\n            <h2 className=\"text-lg font-semibold text-gray-800\">Trend window — 14:00 to 15:00</h2>\n            <div className=\"flex items-center space-x-4\">\n              <div className=\"flex items-center\">\n                <div className=\"w-3 h-3 bg-green-700 mr-2\"></div>\n                <span className=\"text-xs text-gray-600\">Temp (°C)</span>\n              </div>\n              <div className=\"flex items-center\">\n                <div className=\"w-3 h-3 bg-orange-500 mr-2\"></div>\n                <span className=\"text-xs text-gray-600\">Pressure (bar)</span>\n              </div>\n              <div className=\"flex items-center\">\n                <div className=\"w-3 h-3 bg-red-700 mr-2\"></div>\n                <span className=\"text-xs text-gray-600\">Flow (L/min) band: ±2σ</span>\n              </div>\n            </div>\n          </div>\n          \n          <div className=\"chart-container h-64 chart-grid relative\">\n            {/* Temperature line (green) */}\n            <svg className=\"absolute inset-0 w-full h-full\">\n              <polyline \n                points=\"0,75 100,75 200,90 300,110 400,105 500,110 600,75 700,70 800,75 900,65 1000,75 1100,65 1200,75\" \n                fill=\"none\" \n                stroke=\"#2c7a4d\" \n                strokeWidth=\"2\"\n              />\n            </svg>\n            \n            {/* Pressure line (orange) */}\n            <svg className=\"absolute inset-0 w-full h-full\">\n              <polyline \n                points=\"0,165 100,150 200,165 300,170 400,160 500,165 600,180 700,165 800,150 900,170 1000,165 1100,155 1200,160\" \n                fill=\"none\" \n                stroke=\"#f97316\" \n                strokeWidth=\"2\"\n              />\n            </svg>\n            \n            {/* Flow line (red) */}\n            <svg className=\"absolute inset-0 w-full h-full\">\n              <polyline \n                points=\"0,195 100,200 200,180 300,190 400,200 500,180 600,190 700,200 800,195 900,190 1000,185 1100,185 1200,195\" \n                fill=\"none\" \n                stroke=\"#b91c1c\" \n                strokeWidth=\"2\"\n              />\n            </svg>\n            \n            {/* Y-axis labels */}\n            <div className=\"absolute left-0 inset-y-0 flex flex-col justify-between text-xs text-gray-500 py-2\">\n              <div>100</div>\n              <div>90</div>\n              <div>80</div>\n              <div>70</div>\n              <div>60</div>\n              <div>50</div>\n              <div>40</div>\n            </div>\n            \n            {/* X-axis labels */}\n            <div className=\"absolute bottom-0 inset-x-0 flex justify-between text-xs text-gray-500 px-2\">\n              <div>14:00</div>\n              <div>14:05</div>\n              <div>14:10</div>\n              <div>14:15</div>\n              <div>14:20</div>\n              <div>14:25</div>\n              <div>14:30</div>\n              <div>14:35</div>\n              <div>14:40</div>\n              <div>14:45</div>\n              <div>14:50</div>\n              <div>14:55</div>\n              <div>14:60</div>\n            </div>\n          </div>\n          \n          <div className=\"mt-4 r bg-gray-50 border border-gray-200 rounded-md p-2 text-sm text-gray-700\">\n            <div className=\"flex justify-between\">\n              <span>14:22 — Flow rate deviation > 12 % (FT-401)</span>\n              <span>Operator: A. Petrov</span>\n            </div>\n          </div>\n        </div>\n      );\n    }\n\n    function Footer() {\n      return (\n        <footer className=\"p-4 text-xs text-gray-500 border-t\">\n          Connection: OK · Latency: 18 ms · Logging: enabled · Export to CSV available via toolbar\n        </footer>\n      );\n    }\n\n    ReactDOM.render(<App />, document.getElementById('root'));\n  </script>\n</body>\n</html>",
