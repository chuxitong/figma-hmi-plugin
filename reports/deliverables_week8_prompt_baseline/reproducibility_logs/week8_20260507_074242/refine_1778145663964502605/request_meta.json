order border-gray-300 font-medium\">\n                            ACK\n                        </button>\n                    </div>\n                    <div className=\"mt-2 text-sm text-gray-700\">{alarm.message}</div>\n                    <div className=\"mt-1\">\n                        <span className={`${getAlarmColor(alarm.type)} text-white text-xs px-4 py-0.5 rounded`}>\n                            {alarm.type}\n                        </span>\n                    </div>\n                </div>\n            );\n        };\n\n        const Footer = () => {\n            return (\n                <footer className=\"py-4 border-t border-gray-200 mt-6\">\n                    <div className=\"container mx-auto px-4\">\n                        <div className=\"text-xs text-gray-500\">\n                            Connection: OK • Latency: 18 ms • Logged in as A. Petrov • ThingsBoard SCADA glyphs imported via 00_raw_svg\n                        </div>\n                    </div>\n                </footer>\n            );\n        };\n\n        ReactDOM.render(<App />, document.getElementById('root'));\n    </script>\n</body>\n</html>",
