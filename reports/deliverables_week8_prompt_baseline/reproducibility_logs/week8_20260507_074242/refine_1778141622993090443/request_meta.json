    "current_code": "<html>\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Operator Panel</title>\n    <script src=\"https://cdn.jsdelivr.net/npm/react@18.0.0/umd/react.development.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/react-dom@18.0.0/umd/react-dom.development.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/@babel/standalone/babel.js\"></script>\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css\"></link>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap');\n        \n        body {\n            font-family: 'Roboto', sans-serif;\n            background-color: #f1f5f9;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"root\"></div>\n\n    <script type=\"text/babel\">\n        const App = () => {\n            return (\n                <div className=\"min-h-screen flex flex-col\">\n                    <Header />\n                    <MainContent />\n                    <Footer />\n                </div>\n            );\n        };\n\n        const Header = () => {\n            return (\n                <header className=\"bg-[#0a355e] text-white py-4 px-6\">\n                    <div className=\"container mx-auto flex justify-between items-center\">\n                        <div className=\"flex items-center space-x-4\">\n                            <i className=\"fas fa-cog text-xl\"></i>\n                            <div>\n                                <h1 className=\"text-2xl font-bold\">Operator Control Panel</h1>\n                                <p className=\"text-sm text-gray-300\">Process loop: Mixer MX-501 · Operator: A. Petrov</p>\n                            </div>\n                        </div>\n                        <div className=\"bg-[#1c3b5e] px-4 py-2 rounded-md text-sm\">\n                            2026-04-19 14:32:07 MSK\n                        </div>\n                    </div>\n                </header>\n            );\n        };\n\n        const ControlButton = ({ color, children }) => {\n            const bgColor = {\n                green: 'bg-[#2b7a3e]',\n                red: 'bg-[#d13232]',\n                white: 'bg-white border-2 border-[#0a355e] text-[#0a355e]'\n            }[color || 'green'];\n            \n            return (\n                <button className={`${bgColor} text-white font-bold py-3 px-6 rounded-md w-full max-w-[200px] text-xl`}>\n                    {children}\n                </button>\n            );\n        };\n\n        const ModeButton = ({ mode, active }) => {\n            const bgColor = active ? 'bg-[#0a355e] text-white' : 'bg-white border-2 border-gray-400 text-[#0a355e]';\n            \n            return (\n                <button className={`${bgColor} py-3 px-6 rounded-md font-bold text-lg`}>\n                    {mode}\n                </button>\n            );\n        };\n\n        const SetPointInput = ({ label, value, unit }) => {\n            return (\n                <div className=\"mb-4\">\n                    <div className=\"text-xs text-gray-500 mb-1\">{label}</div>\n                    <div className=\"flex space-x-2\">\n                        <input \n                            type=\"text\" \n                            value={`${value} ${unit}`} \n                            className=\"border-2 border-gray-300 rounded-md px-3 py-2 w-full\" \n                        />\n                        <button className=\"bg-[#2b7a3e] text-white font-bold py-2 px-6 rounded-md\">\n                            SET\n                        </button>\n                    </div>\n                </div>\n            );\n        };\n\n        const ReadoutCard = ({ title, value, unit, status }) => {\n            const statusColor = status === 'OK' \n                ? 'bg-[#2b7a3e]' \n                : 'bg-[#e67e22]';\n            \n            return (\n                <div className=\"border border-gray-300 rounded-lg p-4 bg-white\">\n                    <div className=\"text-sm text-gray-500 mb-2\">{title}</div>\n                    <div className=\"text-5xl font-light text-gray-800 mb-1\">\n                        {value}\n                    </div>\n                    <div className=\"text-xs text-gray-500 mb-4\">{unit}</div>\n                    <div className={`${statusColor} text-white text-center py-1 px-8 rounded text-sm`}>\n                        {status}\n                    </div>\n                </div>\n            );\n        };\n\n        const MainContent = () => {\n            return (\n                <main className=\"flex-grow py-8 px-6 bg-gray-50\">\n                    <div className=\"container mx-auto flex flex-col md:flex-row gap-6\">\n                        {/* Left Panel - Manual Control */}\n                        <div className=\"w-full md:w-1/2 bg-white rounded-lg border border-gray-300 p-6\">\n                            <h2 className=\"text-lg font-bold text-gray-800 mb-6\">Manual control</h2>\n                            \n                            <div className=\"flex flex-col md:flex-row gap-4 mb-6\">\n                                <ControlButton color=\"green\">START</ControlButton>\n                                <ControlButton color=\"red\">STOP</ControlButton>\n                                <ControlButton color=\"white\">RESET</ControlButton>\n                            </div>\n                            \n                            <div className=\"mb-6\">\n                                <h3 className=\"text-md font-bold text-gray-800 mb-4\">Operating mode</h3>\n                                <div className=\"grid grid-cols-1 md:grid-cols-3 gap-4\">\n                                    <ModeButton mode=\"AUTO\" active={true} />\n                                    <ModeButton mode=\"MANUAL\" active={false} />\n                                    <ModeButton mode=\"SERVICE\" active={false} />\n                                </div>\n                            </div>\n                            \n                            <div>\n                                <h3 className=\"text-md font-bold text-gray-800 mb-4\">Setpoints</h3>\n                                <SetPointInput label=\"Temperature\" value=\"75.0\" unit=\"°C\" />\n                                <SetPointInput label=\"Flow rate\" value=\"180\" unit=\"L/min\" />\n                                <SetPointInput label=\"Mixer RPM\" value=\"240\" unit=\"rpm\" />\n                            </div>\n                        </div>\n                        \n                        {/* Right Panel - Live Readouts */}\n                        <div className=\"w-full md:w-1/2 bg-white rounded-lg border border-gray-300 p-6\">\n                            <h2 className=\"text-lg font-bold text-gray-800 mb-6\">Live readouts</h2>\n                            \n                            <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n                                <ReadoutCard \n                                    title=\"Temperature out\" \n                                    value=\"74.6\" \n                                    unit=\"°C\" \n                                    status=\"OK\" \n                                />\n                                <ReadoutCard \n                                    title=\"Flow out\" \n                                    value=\"178\" \n                                    unit=\"L/min\" \n                                    status=\"OK\" \n                                />\n                                <ReadoutCard \n                                    title=\"Mixer RPM\" \n                                    value=\"238\" \n                                    unit=\"rpm\" \n                                    status=\"OK\" \n                                />\n                                <ReadoutCard \n                                    title=\"Pressure\" \n                                    value=\"3.18\" \n                                    unit=\"bar\" \n                                    status=\"WARN\" \n                                />\n                            </div>\n                        </div>\n                    </div>\n                </main>\n            );\n        };\n\n        const Footer = () => {\n            return (\n                <footer className=\"py-4 px-6 border-t border-gray-200\">\n                    <div className=\"container mx-auto\">\n                        <div className=\"text-xs text-gray-500\">\n                            Connection: OK · Loop status: closed-loop AUTO · Compliance: ANSI/ISA-101.01\n                        </div>\n                    </div>\n                </footer>\n            );\n        };\n\n        ReactDOM.render(<App />, document.getElementById('root'));\n    </script>\n</body>\n</html>",
