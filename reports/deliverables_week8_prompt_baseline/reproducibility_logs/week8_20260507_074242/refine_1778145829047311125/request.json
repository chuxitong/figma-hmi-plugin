n        const TankIndicator = ({ id, level, status }) => {\n            const getStatusColor = () => {\n                switch(status) {\n                    case 'OK': return 'bg-green-600 text-white';\n                    case 'WARN': return 'bg-orange-500 text-white';\n                    case 'ALARM': return 'bg-red-600 text-white';\n                    default: return 'bg-gray-500 text-white';\n                }\n            };\n\n            const getFillColor = () => {\n                switch(status) {\n                    case 'OK': return 'bg-green-600';\n                    case 'WARN': return 'bg-orange-500';\n                    case 'ALARM': return 'bg-red-600';\n                    default: return 'bg-green-600';\n                }\n            };\n\n            return (\n                <div className=\"flex flex-col items-center mb-6\">\n                    <div className=\"relative w-24 h-52 mr-2\">\n                        <div className=\"absolute w-full h-full bg-gray-200 rounded border-2 border-gray-400\"></div>\n                        <div className={`absolute bottom-0 w-full ${getFillColor()} rounded-b`} style={{height: `${level}%`}}></div>\n                        <div className=\"absolute w-full h-full bg-gray-300 opacity-20\"></div>\n                        <div className=\"absolute right-0 top-1/4 text-xs text-gray-600\">\n                            {level}%\n                        </div>\n                    </div>\n                    <div className=\"mt-2 text-sm font-bold text-gray-800\">{id}</div>\n                    <div className={`mt-1 px-4 py-0.5 rounded text-xs ${getStatusColor()}`}>\n                        {status}\n                    </div>\n                </div>\n            );\n        };\n\n        const MainContent = () => {\n            const tanks = [\n                { id: 'T-101', level: 72, status: 'OK' },\n                { id: 'T-102', level: 41, status: 'OK' },\n                { id: 'T-103', level: 88, status: 'WARN' },\n                { id: 'T-104', level: 12, status: 'ALARM' },\n                { id: 'T-201', level: 64, status: 'OK' },\n                { id: 'T-202', level: 95, status: 'ALARM' },\n                { id: 'T-203', level: 33, status: 'OK' },\n                { id: 'T-204', level: 58, status: 'OK' },\n                { id: 'T-301', level: 47, status: 'OK' },\n                { id: 'T-302', level: 22, status: 'WARN' }\n            ];\n\n            return (\n                <main className=\"flex-grow p-6\">\n                    <div className=\"bg-white rounded-lg border border-gray-300 p-6 mb-6\">\n                        <h2 className=\"text-lg font-bold text-gray-800 mb-6\">Levels and connections</h2>\n                        \n                        <div className=\"flex justify-between\">\n                            <div className=\"grid grid-cols-5 gap-4 w-full\">\n                                {tanks.map((tank) => (\n                                    <TankIndicator \n                                        key={tank.id} \n                                        id={tank.id} \n                                        level={tank.level} \n                                        status={tank.status} \n                                    />\n                                ))}\n                            </div>\n                        </div>\n\n                        <div className=\"mt-4 border-t border-gray-300 w-full h-2 bg-gray-400\"></div>\n                    </div>\n\n                    <div className=\"bg-white rounded-lg border border-gray-300 p-6\">\n                        <h3 className=\"text-md font-bold text-gray-800 mb-4\">Status legend</h3>\n                        <div className=\"flex items-center space-x-6\">\n                            <div className=\"flex items-center\">\n                                <span className=\"bg-green-600 text-white px-4 py-0.5 rounded text-xs mr-2\">OK</span>\n                             