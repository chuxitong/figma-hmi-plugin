    "current_code": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Energy Monitoring Dashboard</title>\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/react@18.0.0/umd/react.development.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/react-dom@18.0.0/umd/react-dom.development.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/@babel/standalone/babel.js\"></script>\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css\"></link>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');\n        body {\n            font-family: 'Inter', sans-serif;\n            background-color: #f3f5f8;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"root\"></div>\n\n    <script type=\"text/babel\">\n        const App = () => {\n            return (\n                <div className=\"min-h-screen bg-gray-50\">\n                    <Header />\n                    <div className=\"container mx-auto px-4 py-6\">\n                        <MetricsSection />\n                        <div className=\"grid grid-cols-1 lg:grid-cols-2 gap-6 mt-6\">\n                            <PowerConsumptionZones />\n                            <SourceBreakdown />\n                        </div>\n                    </div>\n                    <Footer />\n                </div>\n            );\n        };\n\n        const Header = () => {\n            return (\n                <header className=\"bg-slate-800 text-white py-4 px-6\">\n                    <div className=\"container mx-auto flex justify-between items-center\">\n                        <div>\n                            <h1 className=\"text-2xl font-semibold\">Energy Monitoring Dashboard</h1>\n                            <p className=\"text-slate-300 text-sm mt-1\">Industrial-2 · Day shift · All zones</p>\n                        </div>\n                        <div className=\"bg-slate-700 rounded-md px-4 py-2 text-sm text-slate-300\">\n                            2026-04-19 14:32:07 MSK\n                        </div>\n                    </div>\n                </header>\n            );\n        };\n\n        const MetricsSection = () => {\n            const metrics = [\n                {\n                    title: \"Total kWh\",\n                    value: \"12 845\",\n                    change: \"+340 за смену\",\n                    borderColor: \"border-green-600\",\n                    changeColor: \"text-green-600\",\n                    icon: \"▲\"\n                },\n                {\n                    title: \"Peak load\",\n                    value: \"742\",\n                    change: \"+18 за смену\",\n                    borderColor: \"border-orange-500\",\n                    changeColor: \"text-orange-500\",\n                    icon: \"▲\"\n                },\n                {\n                    title: \"Cost (today)\",\n                    value: \"€ 1 932\",\n                    change: \"+78 за смену\",\n                    borderColor: \"border-orange-500\",\n                    changeColor: \"text-orange-500\",\n                    icon: \"▲\"\n                },\n                {\n                    title: \"Power factor\",\n                    value: \"0.92\",\n                    change: \"+0.01 за смену\",\n                    borderColor: \"border-green-600\",\n                    changeColor: \"text-green-600\",\n                    icon: \"▲\"\n                }\n            ];\n\n            return (\n                <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6\">\n                    {metrics.map((metric, index) => (\n                        <div key={index} className={`bg-white rounded-lg border-l-4 ${metric.borderColor} p-4 shadow-sm`}>\n                            <div className=\"text-gray-500 text-sm mb-1\">{metric.title}</div>\n                            <div className=\"text-3xl font-bold text-gray-800 mb-2\">{metric.value}</div>\n                            <div className=\"text-xs\">\n                                <span className={metric.changeColor}>{metric.icon} {metric.change}</span>\n                            </div>\n                        </div>\n                    ))}\n                </div>\n            );\n        };\n\n        const ZoneBar = ({ zone, percentage, status }) => {\n            const getStatusColor = () => {\n                switch(status) {\n                    case 'OK': return 'bg-green-600';\n                    case 'WARN': return 'bg-orange-500';\n                    case 'ALARM': return 'bg-red-600';\n                    default: return 'bg-green-600';\n                }\n            };\n\n            return (\n                <div className=\"flex items-center mb-6\">\n                    <div className=\"w-16 text-sm font-medium text-gray-800\">{zone}</div>\n                    <div className=\"flex-1 mx-4 bg-gray-100 rounded-full h-6\">\n                        <div \n                            className={`h-6 rounded-full ${getStatusColor()}`}\n                            style={{ width: `${percentage}%` }}\n                        ></div>\n                    </div>\n                    <div className=\"flex items-center space-x-2\">\n                        <span className=\"text-sm text-gray-600\">{percentage}%</span>\n                        <span className={`text-xs text-white px-3 py-1 rounded ${getStatusColor()}`}>{status}</span>\n                    </div>\n                </div>\n            );\n        };\n\n        const PowerConsumptionZones = () => {\n            const zones = [\n                { zone: \"Zone A\", percentage: 62, status: \"OK\" },\n                { zone: \"Zone B\", percentage: 48, status: \"OK\" },\n                { zone: \"Zone C\", percentage: 81, status: \"WARN\" },\n                { zone: \"Zone D\", percentage: 35, status: \"OK\" },\n                { zone: \"Zone E\", percentage: 90, status: \"ALARM\" },\n                { zone: \"Zone F\", percentage: 27, status: \"OK\" }\n            ];\n\n            return (\n                <div className=\"bg-white rounded-lg border border-gray-200 p-6 shadow-sm\">\n                    <h2 className=\"text-gray-800 font-semibold text-base mb-6\">Power consumption by zone</h2>\n                    {zones.map((item, index) => (\n                        <ZoneBar \n                            key={index}\n                            zone={item.zone}\n                            percentage={item.percentage}\n                            status={item.status}\n                        />\n                    ))}\n                </div>\n            );\n        };\n\n        const SourceBreakdown = () => {\n            return (\n                <div className=\"bg-white rounded-lg border border-gray-200 p-6 shadow-sm\">\n                    <h2 className=\"text-gray-800 font-semibold text-base mb-6\">Source breakdown</h2>\n                    <div className=\"flex items-center justify-center\">\n                        <div className=\"relative w-64 h-64\">\n                            {/* Donut chart */}\n                            <div className=\"w-64 h-64 rounded-full relative overflow-hidden\">\n                                <div className=\"absolute inset-0\" style={{\n                                    background: \"conic-gradient(\n                                        #22c55e 0% 57%, \n                                        #f97316 57% 82%, \n                                        #3b82f6 82% 100%\n                                    )\"\n                                }}></div>\n                                <div className=\"absolute inset-12 bg-white rounded-full\"></div>\n                            </div>\n                            <div className=\"absolute inset-0 flex items-center justify-center flex-col\">\n                                <div className=\"text-4xl font-bold text-gray-800\">100%</div>\n                                <div className=\"text-gray-500 text-sm mt-1\">today</div>\n                            </div>\n                        </div>\n                        <div className=\"ml-8\">\n                            <div className=\"flex items-center mb-3\">\n                                <div className=\"w-4 h-4 bg-green-600 mr-2\"></div>\n                                <span className=\"text-sm text-gray-700\">Электроэнергию · 57 %</span>\n                            </div>\n                            <div className=\"flex items-center mb-3\">\n                                <div className=\"w-4 h-4 bg-orange-500 mr-2\"></div>\n                                <span className=\"text-sm text-gray-700\">Газ · 25 %</span>\n                            </div>\n                            <div className=\"flex items-center\">\n                                <div className=\"w-4 h-4 bg-blue-500 mr-2\"></div>\n                                <span className=\"text-sm text-gray-700\">Утилизация тепла · 18 %</span>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            );\n        };\n\n        const Footer = () => {\n            return (\n                <footer className=\"bg-gray-100 py-4 px-6 border-t border-gray-200\">\n                    <div className=\"container mx-auto\">\n                        <p className=\"text-xs text-gray-500\">\n                            Connection: OK · Tariff plan: Industrial-2 · Compliance: ANSI/ISA-101.01\n                        </p>\n                    </div>\n                </footer>\n            );\n        };\n\n        ReactDOM.render(<App />, document.getElementById('root'));\n    </script>\n</body>\n</html>",
