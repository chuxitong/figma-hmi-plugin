    "current_code": "<html>\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Tank Farm Synoptic</title>\n    <script src=\"https://cdn.jsdelivr.net/npm/react@18.0.0/umd/react.development.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/react-dom@18.0.0/umd/react-dom.development.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/@babel/standalone/babel.js\"></script>\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css\"></link>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap');\n        \n        body {\n            font-family: 'Roboto', sans-serif;\n            background-color: #f1f5f9;\n        }\n        \n        .tank-chart {\n            position: relative;\n            width: 100px;\n            height: 180px;\n            border: 2px solid #666;\n            border-radius: 4px;\n            background-color: #e0e8f0;\n        }\n        \n        .tank-fill {\n            position: absolute;\n            bottom: 0;\n            left: 0;\n            width: 100%;\n            border-radius: 0;\n            transition: height 0.5s;\n        }\n        \n        .percentage-label {\n            position: absolute;\n            right: -30px;\n            top: 30px;\n            font-size: 12px;\n            color: #666;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"root\"></div>\n\n    <script type=\"text/babel\">\n        const App = () => {\n            return (\n                <div className=\"min-h-screen flex flex-col\">\n                    <Header />\n                    <main className=\"flex-1 p-6 bg-[#f1f5f9]\">\n                        <div className=\"bg-white rounded-lg border border-gray-300 p-6 mb-6\">\n                            <h2 className=\"text-lg font-semibold text-gray-800 mb-6\">Levels and connections</h2>\n                            <div className=\"grid grid-cols-5 gap-6\">\n                                <TankDisplay id=\"T-101\" percentage={72} status=\"OK\" color=\"green\" />\n                                <TankDisplay id=\"T-102\" percentage={41} status=\"OK\" color=\"green\" />\n                                <TankDisplay id=\"T-103\" percentage={88} status=\"WARN\" color=\"orange\" />\n                                <TankDisplay id=\"T-104\" percentage={12} status=\"ALARM\" color=\"red\" />\n                                <TankDisplay id=\"T-201\" percentage={64} status=\"OK\" color=\"green\" />\n                                <TankDisplay id=\"T-202\" percentage={95} status=\"ALARM\" color=\"red\" />\n                                <TankDisplay id=\"T-203\" percentage={33} status=\"OK\" color=\"green\" />\n                                <TankDisplay id=\"T-204\" percentage={58} status=\"OK\" color=\"green\" />\n                                <TankDisplay id=\"T-301\" percentage={47} status=\"OK\" color=\"green\" />\n                                <TankDisplay id=\"T-302\" percentage={22} status=\"WARN\" color=\"orange\" />\n                            </div>\n                        </div>\n                        <div className=\"bg-white rounded-lg border border-gray-300 p-6\">\n                            <h2 className=\"text-lg font-semibold text-gray-800 mb-4\">Status legend</h2>\n                            <div className=\"flex items-center space-x-6\">\n                                <div className=\"flex items-center space-x-2\">\n                                    <div className=\"w-16 h-6 bg-green-600 rounded text-white text-xs font-bold text-center leading-6\">OK</div>\n                                    <span className=\"text-xs text-gray-600\">в норме</span>\n                                </div>\n                                <div className=\"flex items-center space-x-2\">\n                                    <div className=\"w-16 h-6 bg-orange-500 rounded text-white text-xs font-bold text-center leading-6\">WARN</div>\n                                    <span className=\"text-xs text-gray-600\">отключение, нужно вмешательство</span>\n                                </div>\n                                <div className=\"flex items-center space-x-2\">\n                                    <div className=\"w-16 h-6 bg-red-600 rounded text-white text-xs font-bold text-center leading-6\">ALARM</div>\n                                    <span className=\"text-xs text-gray-600\">критическое отключение, требуется ACK</span>\n                                </div>\n                            </div>\n                            <div className=\"mt-6 text-xs text-gray-500\">\n                                Соответствие закодировано терменами независимыми признаками: цвет state-fill, текстовая белёж state-badge, форма state-shape.\n                            </div>\n                        </div>\n                    </main>\n                    <Footer />\n                </div>\n            );\n        };\n\n        const Header = () => {\n            return (\n                <header className=\"bg-[#0b3a5d] text-white py-4 px-6\">\n                    <div className=\"flex justify-between items-center\">\n                        <div className=\"flex items-center space-x-4\">\n                            <div className=\"text-green-400\">\n                                <i className=\"fas fa-tint text-xl\"></i>\n                            </div>\n                            <div>\n                                <h1 className=\"text-2xl font-bold\">Tank Farm Synoptic</h1>\n                                <p className=\"text-sm text-gray-300\">Warehouse 2 - Tank yard A - 10 tanks</p>\n                            </div>\n                        </div>\n                        <div className=\"bg-[#1c3b67] px-4 py-2 rounded text-sm text-gray-300\">\n                            2026-04-19 14:32:07 MSK\n                        </div>\n                    </div>\n                </header>\n            );\n        };\n\n        const TankDisplay = ({ id, percentage, status, color }) => {\n            const getStatusColor = (status) => {\n                switch (status) {\n                    case 'OK': return 'bg-green-600';\n                    case 'WARN': return 'bg-orange-500';\n                    case 'ALARM': return 'bg-red-600';\n                    default: return 'bg-gray-500';\n                }\n            };\n\n            const getFillColor = (color) => {\n                switch (color) {\n                    case 'green': return 'bg-green-600';\n                    case 'orange': return 'bg-orange-500';\n                    case 'red': return 'bg-red-600';\n                    default: return 'bg-gray-500';\n                }\n            };\n\n            return (\n                <div className=\"flex flex-col items-center\">\n                    <div className=\"tank-chart mb-2\">\n                        <div className=\"tank-fill\" style={{ height: `${percentage}%`, backgroundColor: color === 'green' ? '#4285F4' : color === 'orange' ? '#FB8C00' : '#DC3545' }}></div>\n                        <div className=\"percentage-label\">{percentage}%</div>\n                    </div>\n                    <div className=\"text-sm font-bold text-gray-800 mb-2\">{id}</div>\n                    <div className={`text-xs font-bold text-white px-4 py-0.5 rounded ${getStatusColor(status)}`}>\n                        {status}\n                    </div>\n                </div>\n            );\n        };\n\n        const Footer = () => {\n            return (\n                <footer className=\"bg-gray-100 py-4 px-6 text-xs text-gray-500\">\n                    <div className=\"flex space-x-2\">\n                        <span>Connection: OK</span>\n                        <span>•</span>\n                        <span> Tanks online: 10/10</span>\n                        <span>•</span>\n                        <span> Critical: 2</span>\n                        <span>•</span>\n                        <span> Warning: 2</span>\n                    </div>\n                </footer>\n            );\n        };\n\n        ReactDOM.render(<App />, document.getElementById('root'));\n    </script>\n</body>\n</html>",
