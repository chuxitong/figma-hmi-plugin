    "current_code": "<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Parameter Trend Monitor</title>\n  <script src=\"https://cdn.tailwindcss.com\"></script>\n  <script src=\"https://cdn.jsdelivr.net/npm/react@18.0.0/umd/react.development.js\"></script>\n  <script src=\"https://cdn.jsdelivr.net/npm/react-dom@18.0.0/umd/react-dom.development.js\"></script>\n  <script src=\"https://cdn.jsdelivr.net/npm/@babel/standalone/babel.js\"></script>\n  <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css\">\n  <style>\n    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');\n    \n    body {\n      font-family: 'Inter', sans-serif;\n      background-color: #f0f2f5;\n    }\n  </style>\n</head>\n<body>\n  <div id=\"root\"></div>\n\n  <script type=\"text/babel\">\n    function App() {\n      return (\n        <div className=\"min-h-screen bg-gray-50\">\n          <Header />\n          <div className=\"container mx-auto p-4\">\n            <MetricCards />\n            <TrendChart />\n          </div>\n          <Footer />\n        </div>\n      );\n    }\n\n    function Header() {\n      return (\n        <header className=\"bg-[#13314f] text-white py-4 px-6\">\n          <div className=\"container mx-auto flex justify-between items-center\">\n            <div>\n              <h1 className=\"text-2xl font-semibold\">Parameter Trend Monitor</h1>\n              <p className=\"text-sm text-gray-300 mt-1\">Trend Window: 60 min · Sample: 1 s</p>\n            </div>\n            <div className=\"bg-[#1b4779] text-gray-300 px-4 py-2 rounded-md text-sm\">\n              2026-04-19 14:32:07 MSK\n            </div>\n          </div>\n        </header>\n      );\n    }\n\n    function MetricCard({ title, value, change, borderColor }) {\n      return (\n        <div className={`bg-white rounded-lg border-l-4 ${borderColor} shadow-sm p-4`}>\n          <div className=\"text-gray-500 text-sm\">{title}</div>\n          <div className=\"text-4xl font-bold text-gray-800 mt-1\">{value}</div>\n          <div className=\"text-xs text-gray-600 mt-2\">{change}</div>\n        </div>\n      );\n    }\n\n    function MetricCards() {\n      return (\n        <div className=\"grid grid-cols-1 md:grid-cols-4 gap-4 mb-6\">\n          <MetricCard \n            title=\"Temperature\" \n            value=\"72.4\" \n            change=\"+1.2 са смеху\" \n            borderColor=\"border-green-600\"\n          />\n          <MetricCard \n            title=\"Pressure\" \n            value=\"3.21\" \n            change=\"+0.04 са смеху\" \n            borderColor=\"border-green-600\"\n          />\n          <MetricCard \n            title=\"Flow\" \n            value=\"184\" \n            change=\"▼ -3 са смеху\" \n            borderColor=\"border-orange-500\"\n          />\n          <MetricCard \n            title=\"Setpoint dev\" \n            value=\"1.8\" \n            change=\"+0.2 са смеху\" \n            borderColor=\"border-green-600\"\n          />\n        </div>\n      );\n    }\n\n    function TrendChart() {\n      return (\n        <div className=\"bg-white rounded-lg border border-gray-200 shadow-sm p-6\">\n          <div className=\"flex justify-between items-center mb-6\">\n            <h2 className=\"text-lg font-semibold text-gray-800\">Trend window — 14:00 to 15:00</h2>\n            <div className=\"flex items-center space-x-4\">\n              <div className=\"flex items-center\">\n                <div className=\"w-3 h-3 bg-green-700 mr-2\"></div>\n                <span className=\"text-xs text-gray-600\">Temp (°C)</span>\n              </div>\n              <div className=\"flex items-center\">\n                <div className=\"w-3 h-3 bg-orange-500 mr-2\"></div>\n                <span className=\"text-xs text-gray-600\">Pressure (bar)</span>\n              </div>\n              <div className=\"flex items-center\">\n                <div className=\"w-3 h-3 bg-red-700 mr-2\"></div>\n                <span className=\"text-xs text-gray-600\">Flow (L/min) band: ±2σ</span>\n              </div>\n            </div>\n          </div>\n          \n          <div className=\"relative h-64 border border-gray-200 bg-white\">\n            {/* Chart grid */}\n            <div className=\"absolute inset-0 grid grid-cols-12 grid-rows-6\">\n              {Array.from({ length: 12 }).map((_, i) => (\n                <div key={`col-${i}`} className=\"border-r border-gray-100 h-full\"></div>\n              ))}\n              {Array.from({ length: 6 }).map((_, i) => (\n                <div key={`row-${i}`} className=\"border-b border-gray-100 w-full col-span-12\"></div>\n              ))}\n            </div>\n            \n            {/* Y-axis labels */}\n            <div className=\"absolute left-2 top-0 h-full flex flex-col justify-between py-2 text-xs text-gray-500\">\n              <div>100</div>\n              <div>90</div>\n              <div>80</div>\n              <div>70</div>\n              <div>60</div>\n              <div>50</div>\n              <div>40</div>\n            </div>\n            \n            {/* X-axis labels */}\n            <div className=\"absolute bottom-2 left-12 right-4 flex justify-between text-xs text-gray-500\">\n              <div>14:00</div>\n              <div>14:05</div>\n              <div>14:10</div>\n              <div>14:15</div>\n              <div>14:20</div>\n              <div>14:25</div>\n              <div>14:30</div>\n              <div>14:35</div>\n              <div>14:40</div>\n              <div>14:45</div>\n              <div>14:50</div>\n              <div>14:55</div>\n              <div>14:60</div>\n            </div>\n            \n            {/* Chart lines - using SVG for better precision */}\n            <svg className=\"absolute inset-0 w-full h-full\" viewBox=\"0 0 1200 400\" preserveAspectRatio=\"none\">\n              {/* Temperature line (green) */}\n              <path \n                d=\"M0,120 L100,120 L200,140 L300,100 L400,90 L500,110 L600,120 L700,100 L800,105 L900,90 L1000,100 L1100,120 L1200,120\" \n                fill=\"none\" \n                stroke=\"#2c7a4d\" \n                strokeWidth=\"2\"\n              />\n              \n              {/* Pressure line (orange) */}\n              <path \n                d=\"M0,200 L100,180 L200,190 L300,185 L400,190 L500,180 L600,190 L700,175 L800,185 L900,190 L1000,175 L1100,180 L1200,185\" \n                fill=\"none\" \n                stroke=\"#f97316\" \n                strokeWidth=\"2\"\n              />\n              \n              {/* Flow line (red) */}\n              <path \n                d=\"M0,240 L100,245 L200,220 L300,230 L400,245 L500,240 L600,230 L700,245 L800,240 L900,225 L1000,230 L1100,220 L1200,240\" \n                fill=\"none\" \n                stroke=\"#b91c1c\" \n                strokeWidth=\"2\"\n              />\n            </svg>\n          </div>\n          \n          <div className=\"mt-4 bg-gray-50 border border-gray-200 rounded-md p-3 text-sm text-gray-700\">\n            <div className=\"flex justify-between\">\n              <span>14:22 — Flow rate deviation > 12 % (FT-401)</span>\n              <span>Operator: A. Petrov</span>\n            </div>\n          </div>\n        </div>\n      );\n    }\n\n    function Footer() {\n      return (\n        <footer className=\"py-4 px-6 text-xs text-gray-500 border-t\">\n          <div className=\"container mx-auto\">\n            Connection: OK · Latency: 18 ms · Logging: enabled · Export to CSV available via toolbar\n          </div>\n        </footer>\n      );\n    }\n\n    ReactDOM.render(<App />, document.getElementById('root'));\n  </script>\n</body>\n</html>",
