iv>\n                                            <span className=\"text-sm text-gray-700\">Газ · 25 %</span>\n                                        </div>\n                                        <div className=\"flex items-center\">\n                                            <div className=\"w-4 h-4 bg-blue-600 mr-2\"></div>\n                                            <span className=\"text-sm text-gray-700\">Утилизация тепла · 18 %</span>\n                                        </div>\n                                    </div>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n\n                    {/* Footer */}\n                    <footer className=\"bg-gray-100 border-t border-gray-200 py-4 px-6 mt-8\">\n                        <div className=\"text-xs text-gray-500\">\n                            Connection: OK · Tariff plan: Industrial-2 · Compliance: ANSI/ISA-101.01\n                        </div>\n                    </footer>\n                </div>\n            );\n        };\n\n        const MetricCard = ({ title, value, change, color }) => {\n            const borderColor = color === 'green' ? 'border-green-600' : 'border-orange-500';\n            \n            return (\n                <div className={`bg-white rounded-lg border ${borderColor} p-4`}>\n                    <div className=\"text-xs text-gray-500 mb-1\">{title}</div>\n                    <div className=\"text-3xl font-bold text-gray-800 mb-2\">{value}</div>\n                    <div className=\"text-xs text-gray-500\">\n                        <span className=\"text-green-600\">▲</span> {change}\n                    </div>\n                </div>\n            );\n        };\n\n        const ZoneRow = ({ zone, percentage, status, color }) => {\n            const getStatusColor = () => {\n                if (status === \"OK\") return \"bg-green-700\";\n                if (status === \"WARN\") return