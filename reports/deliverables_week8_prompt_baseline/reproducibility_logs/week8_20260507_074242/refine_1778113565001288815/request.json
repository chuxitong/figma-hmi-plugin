         );\n        };\n\n        const MetricCard = ({ title, value, change, unit, borderColor }) => {\n            return (\n                <div className={`bg-white rounded-lg border-l-4 ${borderColor} p-4 shadow-sm`}>\n                    <div className=\"text-gray-500 text-sm\">{title}</div>\n                    <div className=\"text-4xl font-bold text-gray-800 my-2\">{value}</div>\n                    <div className=\"flex items-center text-xs text-gray-600\">\n                        <span className=\"mr-1\">{\"<\"}</span>\n                        <span>{change} {unit}</span>\n                    </div>\n                </div>\n            );\n        };\n\n        const MetricCards = () => {\n            return (\n                <div className=\"grid grid-cols-1 md:grid-cols-4 gap-4 mb-4\">\n                    <MetricCard \n                        title=\"Temperature\" \n                        value=\"72.4\" \n                        change=\"+1.2\" \n                        unit=\"за смени\" \n                        borderColor=\"border-green-600\" \n                    />\n                    <MetricCard \n                        title=\"Pressure\" \n                        value=\"3.21\" \n                        change=\"+0.04\" \n                        unit=\"за смени\" \n                        borderColor=\"border-green-600\" \n                    />\n                    <MetricCard \n                        title=\"Flow\" \n                        value=\"184\" \n                        change=\"-3\" \n                        unit=\"за смени\" \n                        borderColor=\"border-orange-500\" \n                    />\n                    <MetricCard \n                        title=\"Setpoint dev\" \n                        value=\"1.8\" \n                        change=\"+0.2\" \n                        unit=\"за смени\" \n                        borderColor=\"border-green-600\" \n                    />\n                </div>\n            );\n        };\n\n        const TrendChart = () => {\n            return (\n                <div className=\"bg-white rounded-lg border border-gray-200 shadow-sm p-4\">\n                    <div className=\"flex justify-between items-center mb-4\">\n                        <h2 className=\"text-lg font-semibold text-gray-800\">Trend window — 14:00 to 15:00</h2>\n                        <div className=\"flex space-x-4\">\n                            <div className=\"flex items-center\">\n                                <div className=\"w-3 h-3 bg-green-600 mr-2\"></div>\n                                <span className=\"text-xs text-gray-600\">Temp (°C)</span>\n                            </div>\n                            <div className=\"flex items-center\">\n                                <div className=\"w-3 h-3 bg-orange-500 mr-2\"></div>\n                                <span className=\"text-xs text-gray-600\">Pressure (bar)</span>\n                            </div>\n                            <div className=\"flex items-center\">\n                                <div className=\"w-3 h-3 bg-red-600 mr-2\"></div>\n                                <span className=\"text-xs text-gray-600\">Flow (L/min) band: ±2σ</span>\n                            </div>\n                        </div>\n                    </div>\n                    \n                    <div className=\"relative h-64 w-full\">\n                        {/* Chart grid */}\n                        <div className=\"absolute inset-0 grid grid-cols-12 w-full h-full\">\n                            {[...Array(12)].map((_, i) => (\n                                <div key={i} className=\"border-r border-gray-200 h-full\"></div>\n                            ))}\n                        </div>\n                        <div className=\"absolute inset-0 grid grid-rows-6 w-full h-full\">\n                            {[...Array(6)].map((_, i) => (\n                                <div key={i} className=\"border-t border-gray-200 w-full\"></div>\n                            ))}\n                        </div>\n                        \n                        {/* Y-axis labels */}\n                        <div className=\"absolute -left-12 top-0 h-full flex flex-col justify-between text-xs text-gray-500\">\n                            <div>100</div>\n                            <div>90</div>\n                            <div>80</div>\n                            <div>70</div>\n                            <div>60</div>\n                            <div>50</div>\n                            <div>40</div>\n                        </div>\n                        \n                        {/* Chart lines */}\n                        <svg className=\"absolute inset-0 w-full h-full\" viewBox=\"0 0 1200 600\" preserveAspectRatio=\"none\">\n                            {/* Temperature line (green) */}\n                            <path d=\"M0,150 L100,155 L200,140 L300,170 L400,130 L500,140 L600,150 L700,140 L800,145 L900,140 L1000,160 L1100,130 L1200,140\" \n                                  stroke=\"#16a34a\" strokeWidth=\"2\" fill=\"none\" />\n                            \n                            {/* Pressure line (orange) */}\n                            <path d=\"M0,350 L100,340 L200,350 L300,360 L400,340 L500,360 L600,370 L700,350 L800,330 L900,340 L1000,320 L1100,350 L1200,340\" \n                                  stroke=\"#f97316\" strokeWidth=\"2\" fill=\"none\" />\n                            \n                            {/* Flow line (red) */}\n                            <path d=\"M0,430 L100,440 L200,420 L300,410 L400,430 L500,450 L600,430 L700,450 L800,430 L900,420 L1000,430 L1100,410 L1200,430\" \n                                  stroke=\"#dc2626\" strokeWidth=\"2\" fill=\"none\" />\n                        </svg>\n                        \n                        {/* X-axis labels */}\n                        <div className=\"absolute bottom-0 left-0