   <div className=\"flex flex-col items-center\">\n                                <div className=\"w-8 h-8 rounded-full bg-gray-500 text-white flex items-center justify-center text-sm font-medium\">\n                                    7\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                    \n                    <div className=\"flex justify-between text-xs text-gray-500 mb-8\">\n                        <div className=\"w-12 text-center\">10m</div>\n                        <div className=\"w-12 text-center\">8m</div>\n                        <div className=\"w-12 text-center\">15m</div>\n                        <div className=\"w-12 text-center\">4m</div>\n                        <div className=\"w-12 text-center\">20m</div>\n                        <div className=\"w-12 text-center\">12m</div>\n                        <div className=\"w-12 text-center\">6m</div>\n                    </div>\n\n                    <div className=\"flex space-x-4\">\n                        <button className=\"flex-1 bg-green-700 text-white py-3 px-4 rounded-md font-medium text-lg uppercase\">\n                            Resume\n                        </button>\n                        <button className=\"flex-1 bg-orange-500 text-white py-3 px-4 rounded-md font-medium text-lg uppercase\">\n                            Hold\n                        </button>\n                        <button className=\"flex-1 bg-red-600 text-white py-3 px-4 rounded-md font-medium text-lg uppercase\">\n                            Abort\n                        </button>\n                    </div>\n                </div>\n            );\n        };\n\n        const Footer = () => {\n            return (\n                <footer className=\"bg-gray-100 border-t py-4 px-6 text-gray-500 text-sm\">\n                    <div className=\"container mx-auto\">\n                        Recipe R-204 · Step 3 of 7 ACTIVE · Compliance: ANSI/ISA-101.01\n                    </div>\n                </footer>\n            );\n        };\n\n        ReactDOM.render(<App />, document.getElementById('root'));\n    </script>\n</body>\n</html>",
