    "current_code": "<html>\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Batch Recipe Management</title>\n    <script src=\"https://cdn.jsdelivr.net/npm/react@18.0.0/umd/react.development.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/react-dom@18.0.0/umd/react-dom.development.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/@babel/standalone/babel.js\"></script>\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css\">\n    <style>\n        body {\n            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Arial, sans-serif;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"root\"></div>\n\n    <script type=\"text/babel\">\n        const App = () => {\n            return (\n                <div className=\"min-h-screen bg-slate-50\">\n                    <Header />\n                    <div className=\"container mx-auto p-6\">\n                        <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">\n                            <div className=\"lg:col-span-2 bg-white rounded-lg border border-gray-200 p-6\">\n                                <StepsTable />\n                            </div>\n                            <div className=\"space-y-6\">\n                                <LiveParameters />\n                                <Timeline />\n                            </div>\n                        </div>\n                    </div>\n                    <Footer />\n                </div>\n            );\n        };\n\n        const Header = () => {\n            return (\n                <header className=\"bg-slate-900 text-white py-4 px-6\">\n                    <div className=\"container mx-auto flex justify-between items-center\">\n                        <div className=\"flex items-center space-x-2\">\n                            <i className=\"fas fa-cog text-white\"></i>\n                            <div>\n                                <h1 className=\"text-xl font-semibold\">Batch Recipe Management</h1>\n                                <p className=\"text-xs text-gray-300\">Recipe R-204 · Lot 2026-017 · Batch operator: A. Petrov</p>\n                            </div>\n                        </div>\n                        <div className=\"bg-slate-800 rounded-md px-4 py-2 text-sm text-gray-300\">\n                            2026-04-19 14:32:07 MSK\n                        </div>\n                    </div>\n                </header>\n            );\n        };\n\n        const StepsTable = () => {\n            const steps = [\n                { id: 1, name: 'Pre-heat', duration: '10 min', status: 'DONE' },\n                { id: 2, name: 'Fill base', duration: '8 min', status: 'DONE' },\n                { id: 3, name: 'Mix', duration: '15 min', status: 'ACTIVE' },\n                { id: 4, name: 'Add catalyst', duration: '4 min', status: 'PENDING' },\n                { id: 5, name: 'Hold', duration: '20 min', status: 'PENDING' },\n                { id: 6, name: 'Cool down', duration: '12 min', status: 'PENDING' },\n                { id: 7, name: 'Discharge', duration: '6 min', status: 'PENDING' }\n            ];\n\n            return (\n                <div>\n                    <h2 className=\"text-lg font-semibold mb-4 text-gray-800\">Steps</h2>\n                    <div className=\"overflow-x-auto\">\n                        <table className=\"w-full\">\n                            <thead className=\"bg-gray-100\">\n                                <tr>\n                                    <th className=\"text-left py-2 px-4 text-sm font-medium text-gray-700\">#</th>\n                                    <th className=\"text-left py-2 px-4 text-sm font-medium text-gray-700\">Step</th>\n                                    <th className=\"text-left py-2 px-4 text-sm font-medium text-gray-700\">Duration</th>\n                                    <th className=\"text-left py-2 px-4 text-sm font-medium text-gray-700\">Status</th>\n                                    <th className=\"text-left py-2 px-4 text-sm font-medium text-gray-700\">Action</th>\n                                </tr>\n                            </thead>\n                            <tbody>\n                                {steps.map((step) => (\n                                    <tr key={step.id} className=\"border-b hover:bg-gray-50\">\n                                        <td className=\"py-3 px-4 text-gray-800\">{step.id}</td>\n                                        <td className=\"py-3 px-4 text-gray-800 font-medium\">{step.name}</td>\n                                        <td className=\"py-3 px-4 text-gray-800\">{step.duration}</td>\n                                        <td className=\"py-3 px-4\">\n                                            <span className={`px-6 py-1 text-xs font-medium rounded ${\n                                                step.status === 'DONE' ? 'bg-green-700 text-white' :\n                                                step.status === 'ACTIVE' ? 'bg-blue-600 text-white' :\n                                                'bg-gray-600 text-white'\n                                            }`}>\n                                                {step.status}\n                                            </span>\n                                        </td>\n                                        <td className=\"py-3 px-4\">\n                                            <button className=\"px-6 py-1 border border-gray-400 rounded text-gray-800 font-medium hover:bg-gray-50\">\n                                                View\n                                            </button>\n                                        </td>\n                                    </tr>\n                                ))}\n                            </tbody>\n                        </table>\n                    </div>\n                </div>\n            );\n        };\n\n        const LiveParameters = () => {\n            return (\n                <div className=\"bg-white rounded-lg border border-gray-200 p-6\">\n                    <h2 className=\"text-lg font-semibold mb-6 text-gray-800\">Live parameters</h2>\n                    <div className=\"grid grid-cols-2 gap-4\">\n                        <div className=\"border rounded-lg p-4\">\n                            <div className=\"text-sm text-gray-500 mb-2\">Temperature</div>\n                            <div className=\"flex items-baseline\">\n                                <span className=\"text-4xl font-medium text-gray-800\">65.4</span>\n                                <span className=\"text-xl ml-2 text-gray-600\">°C</span>\n                            </div>\n                            <div className=\"mt-2\">\n                                <span className=\"px-8 py-1 rounded text-xs font-medium bg-green-700 text-white\">\n                                    OK\n                                </span>\n                            </div>\n                        </div>\n                        \n                        <div className=\"border rounded-lg p-4\">\n                            <div className=\"text-sm text-gray-500 mb-2\">pH</div>\n                            <div className=\"flex items-baseline\">\n                                <span className=\"text-4xl font-medium text-gray-800\">7.1</span>\n                            </div>\n                            <div className=\"mt-2\">\n                                <span className=\"px-8 py-1 rounded text-xs font-medium bg-green-700 text-white\">\n                                    OK\n                                </span>\n                            </div>\n                        </div>\n                        \n                        <di