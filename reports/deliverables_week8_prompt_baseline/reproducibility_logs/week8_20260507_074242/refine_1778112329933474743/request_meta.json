          <StatusCard \n                        title=\"Acknowledged\" \n                        count=\"34\" \n                        subtitle=\"st 24h\" \n                        change=\"▲ +7 за смену\" \n                        color=\"green\" \n                    />\n                    <StatusCard \n                        title=\"MTBA\" \n                        count=\"1h 42m\" \n                        subtitle=\"\" \n                        change=\"▼ -12m за смену\" \n                        color=\"orange\" \n                    />\n                </div>\n            );\n        };\n\n        const FilterSection = () => {\n            return (\n                <div className=\"bg-white rounded-md shadow-sm p-4 mb-6\">\n                    <div className=\"flex flex-wrap items-center justify-between\">\n                        <div className=\"flex items-center space-x-2 mb-2 md:mb-0\">\n                            <span className=\"text-gray-500 text-sm\">Severity</span>\n                            <button className=\"bg-red-600 text-white px-4 py-1 rounded-full text-sm font-medium\">\n                                CRITICAL\n                            </button>\n                            <button className=\"bg-orange-500 text-white px-4 py-1 rounded-full text-sm font-medium\">\n                                WARNING\n                            </button>\n                            <button className=\"bg-blue-600 text-white px-4 py-1 rounded-full text-sm font-medium\">\n                                INFO\n                            </button>\n                        </div>\n                        \n                        <div className=\"flex items-center space-x-4\">\n                            <div className=\"text-gray-500 text-sm\">Tag / описание</div>\n                            <input \n                                type=\"text\" \n                                placeholder=\"Введите тер или часть описания...\" \n                                className=\"border border-gray-300 rounded-md px-4 py-1 text-sm w-64\"\n                            />\n                            \n                            <div className=\"flex space-x-2\">\n                                <button className=\"bg-green-700 text-white px-6 py-1 rounded-md text-sm font-medium\">\n                                    ACK ALL\n                                </button>\n                                <button className=\"border border-gray-300 text-gray-700 px-6 py-1 rounded-md text-sm font-medium\">\n                                    Export...\n                                </button>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            );\n        };\n\n        const AlarmRow = ({ severity, time, tag, description, value, unit, source }) => {\n            const severityClass = {\n                'CRITICAL': 'bg-red-600 text-white',\n                'WARNING': 'bg-orange-500 text-white',\n                'INFO': 'bg-blue-600 text-white'\n            };\n\n            return (\n                <tr className=\"border-b border-gray-200\">\n                    <td className=\"py-3 px-2\">\n                        <span className={`${severityClass[severity]} text-xs px-3 py-1 rounded`}>\n                            {severity}\n                        </span>\n                    </td>\n                    <td className=\"py-3 px-2 text-sm text-gray-700\">{time}</td>\n                    <td className=\"py-3 px-2 text-sm text-gray-700 font-medium\">{tag}</td>\n                    <td className=\"py-3 px-2 text-sm text-gray-700\">{description}</td>\n                    <td className=\"py-3 px-2 text-sm text-gray-700\">\n                        {value} <span className=\"text-gray-500\">{unit}</span>\n                    </td>\n                    <td className=\"py-3 px-2 text-sm text-gray-500\">{source}</td>\n                    <td className=\"py-3 px-2\">\n                        <div className=\"flex space-x-2\">\n                            <button className=\"border border-gray-400 text-gray-700 text-xs px-6 py-1 rounded-md\">\n                                ACK\n                            </button>\n                            <button className=\"border border-gray-400 text-gray-700 text-xs px-6 py-1 rounded-md\">\n                                View\n                            </button>\n                        </div>\n                    </td>\n                </tr>\n            );\n        };\n\n        const AlarmTable = () => {\n            const alarms = [\n                {\n                    severity: 'CRITICAL',\n                    time: '14:31:42',\n                    tag: 'TT-301',\n                    description: 'Motor temperature exceeds high-high limit',\n                    value: '94.2',\n                    unit: '°C',\n                    source: 'Refinery2/U2/M-301'\n                },\n                {\n                    severity: 'CRITICAL',\n                    time: '14:28:15',\n                    tag: 'PT-102',\n                    description: 'Discharge pressure too high',\n                    value: '5.8',\n                    unit: 'bar',\n                    source: 'Refinery2/U1/P-102'\n                },\n                {\n                    severity: 'WARNING',\n                    time: '14:22:10',\n                    tag: 'FT-401',\n                    description: 'Flow rate deviation > 12 %',\n                    value: '23.1',\n                    unit: 'm³/h',\n                    source: 'Refinery2/U4/F-401'\n                },\n                {\n                    severity: 'WARNING',\n                    time: '14:15:30',\n                    tag: 'CT-502',\n                    description: 'Cooling water temperature rising',\n                    value: '38.5',\n                    unit: '°C',\n                    source: 'Utilities/CW-