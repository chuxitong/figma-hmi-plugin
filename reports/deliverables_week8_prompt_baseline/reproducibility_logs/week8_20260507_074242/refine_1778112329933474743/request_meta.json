    "current_code": "<html>\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <script src=\"https://cdn.jsdelivr.net/npm/react@18.0.0/umd/react.development.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/react-dom@18.0.0/umd/react-dom.development.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/@babel/standalone/babel.js\"></script>\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css\">\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap');\n        \n        body {\n            font-family: 'Roboto', sans-serif;\n            background-color: #f3f5f8;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"root\"></div>\n\n    <script type=\"text/babel\">\n        const App = () => {\n            return (\n                <div className=\"min-h-screen flex flex-col\">\n                    <Header />\n                    <main className=\"flex-1 p-4\">\n                        <StatusCards />\n                        <FilterSection />\n                        <AlarmTable />\n                    </main>\n                    <Footer />\n                </div>\n            );\n        };\n\n        const Header = () => {\n            return (\n                <header className=\"bg-[#13314f] text-white py-4 px-6\">\n                    <div className=\"flex justify-between items-center\">\n                        <div>\n                            <h1 className=\"text-2xl font-semibold\">Alarm & Events Monitor</h1>\n                            <div className=\"text-sm text-gray-300\">Refinery 2 · Shift B · All sites</div>\n                        </div>\n                        <div className=\"bg-[#1e4871] text-gray-300 px-4 py-2 rounded-md text-sm\">\n                            2026-0