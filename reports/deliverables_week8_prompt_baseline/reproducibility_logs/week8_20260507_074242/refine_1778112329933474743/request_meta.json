                    <th className=\"text-left py-3 px-2 text-sm font-medium text-gray-600\">Description</th>\n                                <th className=\"text-left py-3 px-2 text-sm font-medium text-gray-600\">Value</th>\n                                <th className=\"text-left py-3 px-2 text-sm font-medium text-gray-600\">Source</th>\n                                <th className=\"text-left py-3 px-2 text-sm font-medium text-gray-600\">Action</th>\n                            </tr>\n                        </thead>\n                        <tbody>\n                            {alarms.map((alarm, index) => (\n                                <AlarmRow key={index} {...alarm} />\n                            ))}\n                        </tbody>\n                    </table>\n                </div>\n            );\n        };\n\n        const Footer = () => {\n            return (\n                <footer className=\"p-4 text-xs text-gray-500 border-t\">\n                    <div className=\"flex items-center justify-between\">\n                        <div>\n                            Connection: OK · Latency: 22 ms · Compliance: ANSI/ISA-101.01-2015 — colour + text + shape encoding for every state\n                        </div>\n                    </div>\n                </footer>\n            );\n        };\n\n        ReactDOM.render(<App />, document.getElementById('root'));\n    </script>\n</body>\n</html>",
