    "current_code": "<html>\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Batch Recipe Management</title>\n    <script src=\"https://cdn.jsdelivr.net/npm/react@18.0.0/umd/react.development.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/react-dom@18.0.0/umd/react-dom.development.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/@babel/standalone/babel.js\"></script>\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css\"></link>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');\n        body {\n            font-family: 'Inter', sans-serif;\n            background-color: #f3f5f8;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"root\"></div>\n\n    <script type=\"text/babel\">\n        function App() {\n            return (\n                <div className=\"min-h-screen flex flex-col\">\n                    <Header />\n                    <main className=\"flex-grow p-6\">\n                        <div className=\"flex gap-6\">\n                            <div className=\"w-2/3 bg-white rounded-lg shadow-sm border border-gray-200 p-6\">\n                                <StepsTable />\n                            </div>\n                            <div className=\"w-1/3 space-y-6\">\n                                <div className=\"bg-white rounded-lg shadow-sm border border-gray-200 p-6\">\n                                    <h2 className=\"text-lg font-semibold text-gray-800 mb-4\">Live parameters</h2>\n                                    <divParameters />\n                                </div>\n                                <div className=\"bg-white rounded-lg shadow-sm border border-gray-200 p-6\">\n                                    <h2 className=\"text-lg font-semibold text-gray-800 mb-4\">Timeline</h2>\n                                    <Timeline />\n                                    <div className=\"mt-8 flex justify-between gap-4\">\n                                        <button className=\"flex-1 bg-green-700 hover:bg-green-800 text-white font-bold py-3 px-4 rounded-md\">\n                                            RESUME\n                                        </button>\n                                        <button className=\"flex-1 bg-orange-500 hover:bg-orange-600 text-white font-bold py-3 px-4 rounded-md\">\n                                            HOLD\n                                        </button>\n                                        <button className=\"flex-1 bg-red-600 hover:bg-red-700 text-white font-bold py-3 px-4 rounded-md\">\n                                            ABORT\n                                        </button>\n                                    </div>\n                                </div>\n                            </div>\n                        </div>\n                    </main>\n                    <Footer />\n                </div>\n            );\n        }\n\n        function Header() {\n            return (\n                <header className=\"bg-[#13314f] text-white py-4 px-6\">\n                    <div className=\"flex justify-between items-center\">\n                        <div>\n                            <h1 className=\"text-xl font-bold flex items-center gap-2\">\n                                <i className=\"fas fa-microchip\"></i> Batch Recipe Management\n                            </h1>\n                            <p className=\"text-xs text-gray-300 mt-1\">\n                                Recipe: R-204 · Lot 2026-017 · Batch operator: A. Petrov\n                            </p>\n                        </div>\n                        <div className=\"bg-[#1e3a7a] text-gray-300 py-2 px-4 rounded-md text-sm\">\n                            2026-04-19 14:32:07 MSK\n                        </div>\n                    </div>\n                </header>\n            );\n        }\n\n        function StepsTable() {\n            const steps = [\n                { id: 1, name: 'Pre-heat', duration: '10 min', status: 'DONE' },\n                { id: 2, name: 'Fill base', duration: '8 min', status: 'DONE' },\n                { id: 3, name: 'Mix', duration: '15 min', status: 'ACTIVE' },\n                { id: 4, name: 'Add catalyst', duration: '4 min', status: 'PENDING' },\n                { id: 5, name: 'Hold', duration: '20 min', status: 'PENDING' },\n                { id: 6, name: 'Cool down', duration: '12 min', status: 'PENDING' },\n                { id: 7, name: 'Discharge', duration: '6 min', status: 'PENDING' }\n            ];\n\n            return (\n                <div>\n                    <h2 className=\"text-lg font-semibold text-gray-800 mb-4\">Steps</h2>\n                    <div className=\"overflow-x-auto\">\n                        <table className=\"min-w-full\">\n                            <thead className=\"bg-gray-100\">\n                                <tr>\n                                    <th className=\"px-4 py-2 text-left text-sm font-medium text-gray-600\">#</th>\n                                    <th className=\"px-4 py-2 text-left text-sm font-medium text-gray-600\">Step</th>\n                                    <th className=\"px-4 py-2 text-left text-sm font-medium text-gray-600\">Duration</th>\n                                    <th className=\"px-4 py-2 text-left text-sm font-medium text-gray-600\">Status</th>\n                                    <th className=\"px-4 py-2 text-left text-sm font-medium text-gray-600\">Action</th>\n                                </tr>\n                            </thead>\n                            <tbody>\n                                {steps.map((step) => (\n                                    <tr key={step.id} className=\"border-b border-gray-200\">\n                                        <td className=\"px-4 py-3 text-gray-800\">{step.id}</td>\n                                        <td className=\"px-4 py-3 text-gray-800 font-medium\">{step.name}</td>\n                                        <td className=\"px-4 py-3 text-gray-800\">{step.duration}</td>\n                                        <td className=\"px-4 py-3\">\n                                            <span className={`px-8 py-1 rounded text-white text-xs font-medium ${\n                                                step.status === 'DONE' ? 'bg-green-700' :\n                                                step.status === 'ACTIVE' ? 'bg-blue-600' :\n                                                'bg-gray-500'\n                                            }`}>\n                                                {step.status}\n                                            </span>\n                                        </td>\n                                        <td className=\"px-4 py-3\">\n                                            <button className=\"border border-gray-400 rounded px-6 py-1 text-gray-800 hover:bg-gray-50 font-medium\">\n                                                View\n                                            </button>\n                                        </td>\n                                    </tr>\n                                ))}\n                            </tbody>\n                        </table>\n                    </div>\n                </div>\n            );\n        }\n\n        function DivParameters() {\n            return (\n                <div className=\"grid grid-cols-2 gap-4\">\n                    <div className=\"border rounded-lg p-4\">\n                        <div className=\"text-gray-500 text-sm\">Temperature</div>\n                        <div className=\"flex items-end gap-2\">\n                            <span className=\"text-4xl font-medium text-gray-800\">65.4</span>\n                            <span className=\"text-2xl text-gray-600\">°C</span>\n                        </div>\n                        <div className=\"mt-2\">\n                            <span className=\"bg-green-700 text-white text-xs px-8 py-1 rounded\">OK</span>\n                        </div>\n                    </div>\n                    \n                    <div className=\"border rounded-lg p-4\">\n                        <div className=\"text-gray-500 text-sm\">pH</div>\n                        <div className=\"flex items-end gap-2\">\n                            <span className=\"text-4xl font-medium text-gray-800\">7.1</span>\n                        </div>\n                        <div className=\"mt-2\">\n                            <span className=\"bg-green-700 text-white text-xs px-8 py-1 rounded\">OK</span>\n                        </div>\n                    </div>\n                    \n                    <div className=\"border rounded-lg p-4\">\n                        <div className=\"text-gray-500 text-sm\">RPM</div>\n                        <div className=\"flex items-end\">\n                            <span className=\"text-4xl font-medium text-gray-800\">240</span>\n                        </div>\n                        <div className=\"mt-2\">\n                            <span className=\"bg-green-700 text-white text-xs px-8 py-1 rounded\">OK</span>\n                        </div>\n                    </div>\n                    \n                    <div className=\"border rounded-lg p-4\">\n                        <div className=\"text-gray-500 text-sm\">Pressure</div>\n                        <div className=\"flex items-end gap-2\">\n                            <span className=\"text-4xl font-medium text-gray-800\">1.18</span>\n                            <span className=\"text-2xl text-gray-600\">bar</span>\n                        </div>\n                        <div className=\"mt-2\">\n                            <span className=\"bg-orange-500 text-white text-xs px-8 py-1 rounded\">WARN</span>\n                        </div>\n                    </div>\n                </div>\n            );\n        }\n\n        function Timeline() {\n            const timelineItems = [\n                { id: 1, active: true, time: '10m' },\n                { id: 2, active: true, time: '8m' },\n                { id: 3, active: true, time: '15m' },\n                { id: 4, active: false, time: '4m' },\n                { id: 5, active: false, time: '20m' },\n                { id: 6, active: false, time: '12m' },\n                { id: 7, active: false, time: '6m' }\n            ];\n\n            return (\n                <div className=\"flex items-center justify-between\">\n                    {timelineItems.map((item) => (\n                        <div key={item.id} className=\"flex flex-col items-center\">\n                            <div className={`w-8 h-8 rounded-full flex items-center justify-center text-white text-sm font-medium ${\n                                item.id <= 3 ? 'bg-green-700' : 'bg-gray-500'\n                            }`}>\n                                {item.id}\n                            </div>\n                            <div className=\"text-xs text-gray-500 mt-1\">{item.time}</div>\n                        </div>\n                    ))}\n                </div>\n            );\n        }\n\n        function Footer() {\n            return (\n                <footer className=\"bg-gray-100 py-4 px-6 border-t border-gray-200\">\n                    <div className=\"text-xs text-gray-500\">\n                        Recipe R-204 · Step 3 of 7 ACTIVE · Compliance: ANSI/ISA-101.01\n                    </div>\n                </footer>\n            );\n        }\n\n        ReactDOM.render(<App />, document.getElementById('root'));\n    </script>\n</body>\n</html>",
