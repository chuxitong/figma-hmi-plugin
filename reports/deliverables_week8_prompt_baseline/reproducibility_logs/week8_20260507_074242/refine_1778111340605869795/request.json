getStatusStyle(status);\n\n            return (\n                <div className={`bg-white border rounded-lg p-4 shadow-sm ${style.border}`}>\n                    <div className=\"text-gray-600 text-sm mb-2\">{equipment}</div>\n                    <div className=\"text-4xl font-bold text-gray-900 mb-2\">{value}</div>\n                    <div className=\"text-gray-500 text-xs mb-2\">trend: {trend}</div>\n                    <div className={`inline-block px-3 py-1 rounded text-xs font-medium ${style.bg} ${style.text}`}>\n                        {status}\n                    </div>\n                </div>\n            );\n        };\n\n        const App = () => {\n            const equipmentData = [\n                { equipment: \"Pump P-101\", value: \"1480\", trend: \"+12\", status: \"OK\" },\n                { equipment: \"Pump P-102\", value: \"1492\", trend: \"+8\", status: \"OK\" },\n                { equipment: \"Compressor C-201\", value: \"3.21\", trend: \"+0.04\", status: \"OK\" },\n                { equipment: \"Motor M-301\", value: \"94.2\", trend: \"+5.1\", status: \"ALARM\" },\n                { equipment: \"Valve V-102\", value: \"CLOSED\", trend: \"-\", status: \"ALARM\" },\n                { equipment: \"Conveyor CV-401\", value: \"0.00\", trend: \"-\", status: \"MAINT\" },\n                { equipment: \"Mixer MX-501\", value: \"240\", trend: \"-\", status: \"IDLE\" },\n                { equipment: \"Heater H-201\", value: \"62.0\", trend: \"-1.2\", status: \"WARN\" },\n                { equipment: \"Tank T-101\", value: \"72\", trend: \"+2\", status: \"OK\" },\n                { equipment: \"Tank T-102\", value: \"41\", trend: \"-1\", status: \"OK\" },\n                { equipment: \"Sensor T-405\", value: \"38.5\", trend: \"+0.4\", status: \"OK\" },\n                { equipment: \"Sensor F-902\", value: \"180\", trend: \"+3\", status: \"OK\" }\n            ];\n\n            return (\n                <div className=\"min-h-screen bg-gray-50\">\n                    {/* Header */}\n                    <div className=\"bg-slate-900 text-white px-6 py-4\">\n                        <div className=\"flex justify-between items-center\">\n                            <div>\n                                <div className=\"flex items-center space-x-2 mb-1\">\n                                    <i className=\"fas fa-industry text-white\"></i>\n                                    <span className=\"text-xl font-semibold\">Equipment Status Dashboard</span>\n                                </div>\n                                <div className=\"text-sm text-gray-300\">Facility 2 • Line A • Shift B</div>\n                            </div>\n                            <div className=\"text-sm text-gray-300 bg-slate-800 px-4 py-2 rounded\">\n                                2026-04-19 14:32:07 MSK\n                            </div>\n                        </div>\n                    </div>\n\n                    {/* Main Content */}\n                    <div className=\"p-6\">\n                        <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6\">\n                            {equipmentData.map((item, index) => (\n                                <StatusCard \n                                    key={index}\n                                    equipment={item.equipment}\n                                    value={item.value}\n                                    trend={item.trend}\n                                    status={item.status}\n                                />\n                            ))}\n                        </div>\n                    </div>\n\n                    {/* Footer */}\n                    <div className=\"border-t bg-gray-100 py-4 px-6\">\n                        <div className=\"text-gray-500 text-sm\">\n                            Connection: OK • Items: 12 • Critical: 2 • Warning: 2\n                        </div>\n                    </div>\n                </div>\n            );\n        };\n\n        ReactDOM.render(<App />, document.getElementById('root'));\n    </script>\n</body>\n</html>",
