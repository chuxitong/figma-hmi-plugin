ult: return 'bg-gray-500';\n                }\n            };\n\n            return (\n                <div className=\"flex items-center justify-between\">\n                    <div className=\"w-16 font-medium text-gray-800\">{zone}</div>\n                    <div className=\"flex-grow mx-6\">\n                        <div className=\"bg-gray-100 rounded-full h-6\">\n                            <div className={`${color} h-6 rounded-full`} style={{width: `${percentage}%`}}></div>\n                        </div>\n                    </div>\n                    <div className=\"w-12 text-right text-sm text-gray-700\">{percentage}%</div>\n                    <div className=\"ml-4\">\n                        <span className={`px-4 py-1 rounded text-xs font-medium text-white ${getStatusColor()}`}>\n                            {status}\n                        </span>\n                    </div>\n                </div>\n            );\n        };\n\n        const DonutChart = () => {\n            return (\n                <svg viewBox=\"0 0 100 100\" className=\"w-full h-full\">\n                    <circle cx=\"50\" cy=\"50\" r=\"40\" fill=\"none\" stroke=\"#22c55e\" strokeWidth=\"20\" />\n                    <circle cx=\"50\" cy=\"50\" r=\"40\" fill=\"none\" stroke=\"#3b82f6\" strokeWidth=\"20\" \n                            strokeDasharray=\"75 251\" strokeDashoffset=\"0\" />\n                    <circle cx=\"50\" cy=\"50\" r=\"40\" fill=\"none\" stroke=\"#f97316\" strokeWidth=\"20\" \n                            strokeDasharray=\"63 251\" strokeDashoffset=\"-75\" />\n                </svg>\n            );\n        };\n\n        const Footer = () => {\n            return (\n                <footer className=\"bg-gray-100 border-t border-gray-200 py-4 px-6\">\n                    <div className=\"text-gray-500 text-sm\">\n                        Connection: OK · Tariff plan: Industrial-2 · Compliance: ANSI/ISA-101.01\n                    </div>\n                </foote