    "current_code": "<html>\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Alarms & Events Monitor</title>\n    <script src=\"https://cdn.jsdelivr.net/npm/react@18.0.0/umd/react.development.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/react-dom@18.0.0/umd/react-dom.development.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/@babel/standalone/babel.js\"></script>\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css\">\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap');\n        \n        body {\n            font-family: 'Roboto', sans-serif;\n            background-color: #f1f5f9;\n        }\n        \n        .header-bg {\n            background-color: #13314f;\n        }\n        \n        .critical-bg {\n            background-color: #c62828;\n            color: white;\n        }\n        \n        .warning-bg {\n            background-color: #ef6c00;\n            color: white;\n        }\n        \n        .info-bg {\n            background-color: #1976d2;\n            color: white;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"root\"></div>\n\n    <script type=\"text/babel\">\n        function App() {\n            return (\n                <div className=\"flex flex-col min-h-screen\">\n                    <Header />\n                    <main className=\"flex-1 p-4 bg-gray-50\">\n                        <SummaryCards />\n                        <FilterSection />\n                        <AlarmTable />\n                    </main>\n                    <Footer />\n                </div>\n            );\n        }\n\n        function Header() {\n            return (\n                <header className=\"header-bg text-white py-4 px-6\">\n                    <div className=\"flex justify-between items-center\">\n                        <div>\n                            <h1 className=\"text-2xl font-bold\">Alarms & Events Monitor</h1>\n                            <p className=\"text-sm text-gray-300\">Refinery 2 · Shift B · All sites</p>\n                        </div>\n                        <div className=\"bg-[#1d3c70] text-gray-300 px-4 py-2 rounded-md text-sm\">\n                            2026-04-19 14:34:55 MSK\n                        </div>\n                    </div>\n                </header>\n            );\n        }\n\n        function SummaryCards() {\n            const summaryData = [\n                {\n                    title: \"Critical\",\n                    count: \"2\",\n                    subtitle: \"active\",\n                    change: \"+1 за смену\",\n                    color: \"critical\",\n                    borderColor: \"border-red-600\"\n                },\n                {\n                    title: \"Warning\",\n                    count: \"5\",\n                    subtitle: \"active\",\n                    change: \"-1 за смену\",\n                    color: \"warning\",\n                    borderColor: \"border-orange-600\"\n                },\n                {\n                    title: \"Information\",\n                    count: \"11\",\n                    subtitle: \"cent\",\n                    change: \"+3 за смену\",\n                    color: \"info\",\n                    borderColor: \"border-green-600\"\n                },\n                {\n                    title: \"Acknowledged\",\n                    count: \"34\",\n                    subtitle: \"t 24h\",\n                    change: \"+7 за смену\",\n                    color: \"info\",\n                    borderColor: \"border-green-600\"\n                },\n                {\n                    title: \"MTBA\",\n                    count: \"1h 42m\",\n                    subtitle: \"\",\n                    change: \"-12m за смену\",\n                    color: \"warning\",\n                    borderColor: \"border-orange-600\"\n                }\n            ];\n\n            return (\n                <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4 mb-6\">\n                    {summaryData.map((item, index) => (\n                        <div key={index} className=\"bg-white rounded-md shadow-sm border-l-4 \">\n                            <div className=\"p-4\">\n                                <div className=\"text-gray-500 text-sm\">{item.title}</div>\n                                <div className=\"text-4xl font-bold text-gray-800\">{item.count}</div>\n                                <div className=\"text-gray-500 text-xs\">{item.change}</div>\n                            </div>\n                        </div>\n                    ))}\n                </div>\n            );\n        }\n\n        function FilterSection() {\n            return (\n                <div className=\"bg-white rounded-lg shadow-sm border p-4 mb-6\">\n                    <div className=\"flex flex-wrap items-center gap-4\">\n                        <div className=\"text-gray-600 text-sm\">Severity</div>\n                        <div className=\"flex gap-2\">\n                            <button className=\"px-4 py-1 bg-red-700 text-white text-sm rounded-full font-medium\">CRITICAL</button>\n                            <button className=\"px-4 py-1 bg-orange-500 text-white text-sm rounded-full font-medium\">WARNING</button>\n                            <button className=\"px-4 py-1 bg-blue-600 text-white text-sm rounded-full font-medium\">INFO</button>\n                        </div>\n                        <div className=\"text-gray-600 text-sm ml-4\">Tag / описание</div>\n                        <div className=\"flex-grow\">\n                            <input \n                                type=\"text\" \n                                placeholder=\"Введите тер или часть описания...\" \n                                className=\"w-full px-4 py-1 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-blue-500\"\n                            />\n                        </div>\n                        <button className=\"px-6 py-1 bg-green-700 text-white text-sm rounded-md font-medium\">ACK ALL</button>\n                        <button className=\"px-6 py-1 border border-gray-400 text-gray-700 text-sm rounded-md font-medium\">Export...</button>\n                    </div>\n                </div>\n            );\n        }\n\n        function AlarmTable() {\n            const alarmData = [\n                {\n                    severity: \"CRITICAL\",\n                    time: \"14:31:42\",\n                    tag: \"TT-301\",\n                    description: \"Motor temperature exceeds high-high limit\",\n                    value: \"94.2\",\n                    unit: \"°C\",\n                    source: \"Refinery2/U2/M-301\"\n                },\n                {\n                    severity: \"CRITICAL\",\n                    time: \"14:28:15\",\n                    tag: \"PT-102\",\n                    description: \"Discharge pressure too high\",\n                    value: \"5.8\",\n                    unit: \"bar\",\n                    source: \"Refinery2/U1/P-102\"\n                },\n                {\n                    severity: \"WARNING\",\n                    time: \"14:22:10\",\n                    tag: \"FT-401\",\n                    description: \"Flow rate deviation > 12 %\",\n                    value: \"23.1\",\n                    unit: \"m³/h\",\n                    source: \"Refinery2/U4/F-401\"\n                },\n                {\n                    severity: \"WARNING\",\n                    time: \"14:15:30\",\n                    tag: \"CT-502\",\n                    description: \"Cooling water temperature rising\",\n                    value: \"38.5\",\n                    unit: \"°C\",\n                    source: \"Utilities/CW-502\"\n                },\n                {\n                    severity: \"WARNING\",\n                    time: \"14:09:54\",\n                    tag: \"LT-301\",\n                    description: \"Tank level above setpoint\",\n                    value: \"88.4\",\n                    unit: \"%\",\n                    source: \"Refinery2/U2/T-301\"\n                },\n                {\n                    severity: \"INFO\",\n                    time: \"14:05:18\",\n                    tag: \"PDT-201\",\n                    description: \"Filter differential pressure\",\n                    value: \"0.8\",\n                    unit: \"bar\",\n                    source: \"Refinery2/U2/F-201\"\n                },\n                {\n                    severity: \"INFO\",\n                    time: \"14:01:09\",\n                    tag: \"FT-902\",\n                    description: \"Flow within tolerance — restored\",\n                    value: \"180\",\n                    unit: \"m³/h\",\n                    source: \"Refinery2/U9/F-902\"\n                },\n                {\n                    severity: \"INFO\",\n                    time: \"13:54:22\",\n                    tag: \"CT-101\",\n                    description: \"Communication restored\",\n                    value: \"-\",\n                    unit: \"\",\n                    source: \"Bus/CT-101\"\n                }\n            ];\n\n            return (\n                <div className=\"bg-white rounded-lg shadow-sm border\">\n                    <table className=\"w-full\">\n                        <thead className=\"bg-gray-100\">\n                            <tr>\n                                <th className=\"text-left py-3 px-4 text-gray-600 text-sm font-medium\">Severity</th>\n                                <th className=\"text-left py-3 px-4 text-gray-600 text-sm font-medium\">Time</th>\n                                <th className=\"text-left py-3 px-4 text-gray-600 text-sm font-medium\">Tag</th>\n                                <th className=\"text-left py-3 px-4 text-gray-600 text-sm font-medium\">Description</th>\n                                <th className=\"text-left py-3 px-4 text-gray-600 text-sm font-medium\">Value</th>\n                                <th className=\"text-left py-3 px-4 text-gray-600 text-sm font-medium\">Source</th>\n                                <th className=\"text-left py-3 px-4 text-gray-600 text-sm font-medium\">Action</th>\n                            </tr>\n                        </thead>\n                        <tbody>\n                            {alarmData.map((alarm, index) => (\n                                <tr key={index} className=\"border-t hover:bg-gray-50\">\n                                    <td className=\"py-3 px-4\">\n                                        <span className={`px-3 py-1 text-xs font-medium rounded-md ${\n                                            alarm.severity === \"CRITICAL\" ? \"bg-red-700 text-white\" : \n                                            alarm.severity === \"WARNING\" ? \"bg-orange-500 text-white\" : \n                                            \"bg-blue-600 text-white\"\n                                        }`}>\n                                            {alarm.severity}\n                                        </span>\n                                    </td>\n                                    <td className=\"py-3 px-4 text-gray-700\">{alarm.time}</td>\n                                    <td className=\"py-3 px-4 text-gray-900 font-medium\">{alarm.tag}</td>\n                                    <td className=\"py-3 px-4 text-gray-800\">{alarm.description}</td>\n                                    <td className=\"py-3 px-4\">\n                                        <span className=\"text-gray-700\">{alarm.value}</span> <span className=\"text-gray-600\">{alarm.unit}</span>\n                                    </td>\n                                    <td className=\"py-3 px-4 text-gray-600 text-sm\">{alarm.source}</td>\n                                    <td className=\"py-3 px-4\">\n                                        <div className=\"flex space-x-2\">\n                                            <button className=\"px-4 py-1 border border-gray-400 text-gray-800 text-sm rounded-md font-medium hover:bg-gray-50\">ACK</button>\n                                            <button className=\"px-4 py-1 border border-gray-400 text-gray-800 text-sm rounded-md font-medium hover:bg-gray-50\">View</button>\n                                        </div>\n                                    </td>\n                                </tr>\n                            ))}\n                        </tbody>\n                    </table>\n                </div>\n            );\n        }\n\n        function Footer() {\n            return (\n                <footer className=\"bg-gray-100 py-4 px-6 text-xs text-gray-500 border-t\">\n                    <div className=\"flex justify-between items-center\">\n                        <div>Connection: OK · Latency: 22 ms · Compliance: ANSI/ISA-101.01-2015 — colour + text + shape encoding for every state</div>\n                    </div>\n                </footer>\n            );\n        }\n\n        ReactDOM.render(<App />, document.getElementById('root'));\n    </script>\n</body>\n</html>",
