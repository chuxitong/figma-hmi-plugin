    "current_code": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Alarm & Events Monitor</title>\n    <script src=\"https://cdn.jsdelivr.net/npm/react@18.0.0/umd/react.development.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/react-dom@18.0.0/umd/react-dom.development.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/@babel/standalone/babel.js\"></script>\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css\">\n    <style>\n        body {\n            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"root\"></div>\n\n    <script type=\"text/babel\">\n        function App() {\n            return (\n                <div className=\"min-h-screen bg-gray-50\">\n                    <Header />\n                    <div className=\"container mx-auto p-4\">\n                        <StatusCards />\n                        <FilterSection />\n                        <AlarmTable />\n                        <Footer />\n                    </div>\n                </div>\n            );\n        }\n\n        function Header() {\n            return (\n                <header className=\"bg-[#0f3a5e] text-white py-4 px-6\">\n                    <div className=\"container mx-auto flex justify-between items-center\">\n                        <div>\n                            <h1 className=\"text-2xl font-bold\">Alarm & Events Monitor</h1>\n                            <p className=\"text-sm text-gray-300\">Refinery 2 · Shift B · All sites</p>\n                        </div>\n                        <div className=\"bg-[#1c3b67] px-4 py-2 rounded text-sm text-gray-300\">\n                            2026-04-19 14:34:55 MSK\n                        </div>\n                    </div>\n                </header>\n            );\n        }\n\n        function StatusCard({ title, count, subtitle, change, color, borderColor }) {\n            return (\n                <div className={`border-l-4 ${borderColor} bg-white rounded-md p-4 shadow-sm`}>\n                    <div className=\"flex justify-between items-start\">\n                        <div>\n                            <h3 className=\"text-sm text-gray-500\">{title}</h3>\n                            <div className=\"text-3xl font-bold text-gray-800\">\n                                {count} <span className=\"text-sm font-normal text-gray-500\">{subtitle}</span>\n                            </div>\n                        </div>\n                    </div>\n                    <div className=\"mt-2 text-xs text-gray-500\">\n                        <span>{change}</span>\n                    </div>\n                </div>\n            );\n        }\n\n        function StatusCards() {\n            return (\n                <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4 mb-6\">\n                    <StatusCard \n                        title=\"Critical\" \n                        count=\"2\" \n                        subtitle=\"active\" \n                        change=\"▲ +1 за смену\" \n                        borderColor=\"border-red-500\" \n                    />\n                    <StatusCard \n                        title=\"Warning\" \n                        count=\"5\" \n                        subtitle=\"active\" \n                        change=\"▼ -1 за смену\" \n                        borderColor=\"border-orange-500\" \n                    />\n                    <StatusCard \n                        title=\"Information\" \n                        count=\"11\" \n                        subtitle=\"recent\" \n                        change=\"▲ +3 за смену\" \n                        borderColor=\"border-green-500\" \n                    />\n                    <StatusCard \n                        title=\"Acknowledged\" \n                        count=\"34\" \n                        subtitle=\"in 24h\" \n                        change=\"▲ +7 за смену\" \n                        borderColor=\"border-green-500\" \n                    />\n                    <StatusCard \n                        title=\"MTBA\" \n                        count=\"1h 42m\" \n                        subtitle=\"\" \n                        change=\"▼ -12m за смену\" \n                        borderColor=\"border-orange-500\" \n                    />\n                </div>\n            );\n        }\n\n        function FilterSection() {\n            return (\n                <div className=\"bg-white rounded-lg border border-gray-200 p-4 mb-6\">\n                    <div className=\"flex flex-wrap items-center justify-between\">\n                        <div className=\"flex items-center space-x-4\">\n                            <span className=\"text-gray-600\">Severity</span>\n                            <div className=\"flex space-x-2\">\n                                <button className=\"px-4 py-1 bg-red-600 text-white text-xs rounded-full font-bold\">\n                                    CRITICAL\n                                </button>\n                                <button className=\"px-4 py-1 bg-orange-500 text-white text-xs rounded-full font-bold\">\n                                    WARNING\n                                </button>\n                                <button className=\"px-4 py-1 bg-blue-600 text-white text-xs rounded-full font-bold\">\n                                    INFO\n                                </button>\n                            </div>\n                        </div>\n                        \n                        <div className=\"flex items-center space-x-4\">\n                            <span className=\"text-gray-600 text-sm\">Tag / описание</span>\n                            <input \n                                type=\"text\" \n                                placeholder=\"Введите тер или часть описания...\" \n                                className=\"border border-gray-300 rounded px-3 py-1 text-sm w-64\"\n                            />\n                            <button className=\"px-6 py-2 bg-green-700 text-white text-sm font-bold rounded\">\n                                ACK ALL\n                            </button>\n                            <button className=\"px-4 py-2 border border-gray-300 text-gray-700 text-sm rounded\">\n                                Export...\n                            </button>\n                        </div>\n                    </div>\n                </div>\n            );\n        }\n\n        function AlarmRow({ severity, time, tag, description, value, unit, source }) {\n            const getSeverityStyle = (sev) => {\n                switch(sev) {\n                    case 'CRITICAL':\n                        return 'bg-red-600 text-white';\n                    case 'WARNING':\n                        return 'bg-orange-500 text-white';\n                    case 'INFO':\n                        return 'bg-blue-600 text-white';\n                    default:\n                        return 'bg-gray-600 text-white';\n                }\n            };\n\n            return (\n                <tr className=\"border-b border-gray-200\">\n                    <td className=\"px-4 py-3\">\n                        <span className={`px-3 py-1 rounded-full text-xs font-bold ${getSeverityStyle(severity)}`}>\n                            {severity}\n                        </span>\n                    </td>\n                    <td className=\"px-4 py-3 text-sm\">{time}</td>\n                    <td className=\"px-4 py-3 text-sm font-medium\">{tag}</td>\n                    <td className=\"px-4 py-3 text-sm\">{description}</td>\n                    <td className=\"px-4 py-3 text-sm\">\n                        <span>{value}</span> <span className=\"text-gray-500\">{unit}</span>\n                    </td>\n                    <td className=\"px-4 py-3 text-sm text-gray-500\">{source}</td>\n                    <td className=\"px-4 py-3\">\n                        <div className=\"flex space-x-2\">\n                            <button className=\"px-4 py-1 border border-gray-500 text-xs rounded hover:bg-gray-50\">\n                                ACK\n                            </button>\n                            <button className=\"px-4 py-1 border border-gray-500 text-xs rounded hover:bg-gray-50\">\n                                View\n                            </button>\n                        </div>\n                    </td>\n                </tr>\n            );\n        }\n\n        function AlarmTable() {\n            const alarms = [\n                {\n                    severity: 'CRITICAL',\n                    time: '14:31:42',\n                    tag: 'TT-301',\n                    description: 'Motor temperature exceeds high-high limit',\n                    value: '94.2',\n                    unit: '°C',\n                    source: 'Refinery2/U2/M-301'\n                },\n                {\n                    severity: 'CRITICAL',\n                    time: '14:28:15',\n                    tag: 'PT-102',\n                    description: 'Discharge pressure too high',\n                    value: '5.8',\n                    unit: 'bar',\n                    source: 'Refinery2/U1/P-102'\n                },\n                {\n                    severity: 'WARNING',\n                    time: '14:22:10',\n                    tag: 'FT-401',\n                    description: 'Flow rate deviation > 12 %',\n                    value: '23.1',\n                    unit: 'm³/h',\n                    source: 'Refinery2/U4/F-401'\n                },\n                {\n                    severity: 'WARNING',\n                    time: '14:15:30',\n                    tag: 'CT-502',\n                    description: 'Cooling water temperature rising',\n                    value: '38.5',\n                    unit: '°C',\n                    source: 'Utilities/CW-502'\n                },\n                {\n                    severity: 'WARNING',\n                    time: '14:09:54',\n                    tag: 'LT-301',\n                    description: 'Tank level above setpoint',\n                    value: '88.4',\n                    unit: '%',\n                    source: 'Refinery2/U2/T-301'\n                },\n                {\n                    severity: 'INFO',\n                    time: '14:05:18',\n                    tag: 'PDT-201',\n                    description: 'Filter differential pressure',\n                    value: '0.8',\n                    unit: 'bar',\n                    source: 'Refinery2/U2/F-201'\n                },\n                {\n                    severity: 'INFO',\n                    time: '14:01:09',\n                    tag: 'FT-902',\n                    description: 'Flow within tolerance — restored',\n                    value: '180',\n                    unit: 'm³/h',\n                    source: 'Refinery2/U9/F-902'\n                },\n                {\n                    severity: 'INFO',\n                    time: '13:54:22',\n                    tag: 'CT-101',\n                    description: 'Communication restored',\n                    value: '-',\n                    unit: '',\n                    source: 'Bus/CT-101'\n                }\n            ];\n\n            return (\n                <div className=\"bg-white rounded-lg border border-gray-200\">\n                    <table className=\"w-full\">\n                        <thead className=\"bg-gray-100\">\n                            <tr>\n                                <th className=\"px-4 py-3 text-left text-xs font-medium text-gray-600 uppercase\">Severity</th>\n                                <th className=\"px-4 py-3 text-left text-xs font-medium text-gray-600 uppercase\">Time</th>\n                                <th className=\"px-4 py-3 text-left text-xs font-medium text-gray-600 uppercase\">Tag</th>\n                                <th className=\"px-4 py-3 text-left text-xs font-medium text-gray-600 uppercase\">Description</th>\n                                <th className=\"px-4 py-3 text-left text-xs font-medium text-gray-600 uppercase\">Value</th>\n                                <th className=\"px-4 py-3 text-left text-xs font-medium text-gray-600 uppercase\">Source</th>\n                                <th className=\"px-4 py-3 text-left text-xs font-medium text-gray-600 uppercase\">Action</th>\n                            </tr>\n                        </thead>\n                        <tbody>\n                            {alarms.map((alarm, index) => (\n                                <AlarmRow key={index} {...alarm} />\n                            ))}\n                        </tbody>\n                    </table>\n                </div>\n            );\n        }\n\n        function Footer() {\n            return (\n                <div className=\"text-xs text-gray-500 mt-6 pb-4\">\n                    Connection: OK · Latency: 22 ms · Compliance: ANSI/ISA-101.01-2015 — colour + text + shape encoding for every state\n                </div>\n            );\n        }\n\n        ReactDOM.render(<App />, document.getElementById('root'));\n    </script>\n</body>\n</html>",
