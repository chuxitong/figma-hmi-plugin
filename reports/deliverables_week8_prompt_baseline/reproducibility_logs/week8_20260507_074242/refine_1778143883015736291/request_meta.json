          </div>\n                    </div>\n                </div>\n            );\n        };\n\n        const MetricCard = ({ title, value, change, positive }) => {\n            return (\n                <div className=\"bg-white rounded-md border border-gray-200 p-4\">\n                    <div className=\"flex justify-between items-center\">\n                        <div className=\"text-gray-600 text-sm\">{title}</div>\n                        <div className=\"text-3xl font-bold text-gray-900\">{value}</div>\n                    </div>\n                    <div className=\"mt-2 text-xs text-gray-600\">\n                        <span className={positive ? \"text-green-600\" : \"text-red-600\"}>\n                            <i className={`fas fa-${positive ? \"caret-up\" : \"caret-down\"} mr-1`}></i>\n                            {change}\n                        </span>\n                    </div>\n                </div>\n            );\n        };\n\n        const TrendChart = () => {\n            return (\n                <div className=\"bg-white rounded-md border border-gray-200 p-6 mt-6\">\n                    <div className=\"flex justify-between items-center mb-4\">\n                        <h3 className=\"text-gray-800 font-semibold\">Real-time trend — last 60 min</h3>\n                        <div className=\"flex items-center space-x-4 text-sm\">\n                            <div className=\"flex items-center\">\n                                <div className=\"w-3 h-3 bg-green-700 mr-2\"></div>\n                                <span>Temp</span>\n                            </div>\n                            <div className=\"flex items-center\">\n                                <div className=\"w-3 h-3 bg-orange-500 mr-2\"></div>\n                                <span>Pressure</span>\n                            </div>\n                            <div className=\"flex items-center\">\n                                <div className=\"w-3 h-3 bg-red-700 mr-2\"></div>\n                                <span>Flow</span>\n                            </div>\n                        </div>\n                    </div>\n                    <div className=\"h-24 w-full relative border-b border-l border-gray-200\">\n                        <svg className=\"w-full h-full\" viewBox=\"0 0 1000 100\" preserveAspectRatio=\"none\">\n                            <path d=\"M0,70 L100,65 L200,60 L300,65 L400,50 L500,40 L600,55 L700,45 L800,35 L900,30 L1000,25\" fill=\"none\" stroke=\"#16a34a\" strokeWidth=\"2\" />\n                            <path d=\"M0,80 L100,75 L200,72 L300,68 L400,65 L500,62 L600,60 L700,58 L800,55 L900,52 L1000,48\" fill=\"none\" stroke=\"#f97316\" strokeWidth=\"2\" />\n                            <path d=\"M0,90 L100,88 L200,85 L300,82 L400,84 L500,86 L600,84 L700,82 L800,80 L900,78 L1000,75\" fill=\"none\" stroke=\"#dc2626\" strokeWidth=\"2\" />\n                        </svg>\n                    </div>\n                </div>\n            );\n        };\n\n        const AlarmPanel = () => {\n            const alarms = [\n                { time: \"14:31\", id: \"TT-301\", description: \"Motor temperature high\", level: \"ALARM\" },\n                { time: \"14:28\", id: \"PT-102\", description: \"Discharge pressure\", level: \"ALARM\" },\n                { time: \"14:22\", id: \"FT-401\", description: \"Flow rate deviation\", level: \"WARN\" },\n                { time: \"14:15\", id: \"CT-502\", description: \"Cooling water temp\", level: \"WARN\" },\n                { time: \"14:05\", id: \"PDT-201\", description: \"Filter ΔP\", level: \"INFO\" }\n            ];\n\n            return (\n                <div className=\"bg-white rounded-md border border-gray-200 p-6\">\n                    <div className=\"flex justify-between items-center mb-4\">\n                        <h3 className=\"text-gray-800 font-semibold\">Active alarms</h3>\n                        <span className=\"text-xs text-gray-500\">3 of 14</span>\n                    </div>\n                    <div className=\"space-y-4\">\n                        {alarms.map((alarm, index) => (\n                            <AlarmItem key={index} alarm={alarm} />\n                        ))}\n                    </div>\n                </div>\n            );\n        };\n\n        const AlarmItem = ({ alarm }) => {\n            const getLevelStyle = () => {\n                switch (alarm.level) {\n                    case \"ALARM\":\n                        return \"bg-red-700 text-white\";\n                    case \"WARN\":\n                        return \"bg-orange-500 text-white\";\n                    case \"INFO\":\n                        return \"bg-blue-600 text-white\";\n                    default:\n                        return \"bg-gray-500 text-white\";\n                }\n            };\n\n            return (\n                <div className=\"border border-gray-300 rounded-md p-4\">\n                    <div className=\"flex justify-between items-center mb-2\">\n                        <div className=\"flex items-center gap-4\">\n                            <span className=\"text-xs text-gray-600\">{alarm.time}</span>\n                            <span className=\"text-xs text-gray-600\">{alarm.id}</span>\n                        </div>\n                    </div>\n                    <div className=\"flex justify-between items-center\">\n                        <div>\n                            <div className=\"text-sm text-gray-700\">{alarm.description}</div>\n                            <div className={`text-xs px-2 py-0.5 rounded mt-1 inline-block ${getLevelStyle()}`}>\n                                {alarm.level}\n                            </div>\n                        </div>\n                        <button className=\"px-6 py-1 border border-gray-400 rounded-md text-sm font-medium text-gray-800 hover:bg-gray-50\">\n                            ACK\n                        </button>