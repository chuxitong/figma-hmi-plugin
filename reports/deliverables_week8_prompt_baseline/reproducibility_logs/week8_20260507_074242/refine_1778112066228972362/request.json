rm.description}\n                                        </td>\n                                        <td className=\"px-6 py-4 whitespace-nowrap text-sm text-gray-700\">\n                                            <span>{alarm.value}</span>\n                                            {alarm.unit && <span className=\"ml-2\">{alarm.unit}</span>}\n                                        </td>\n                                        <td className=\"px-6 py-4 whitespace-nowrap text-sm text-gray-500\">\n                                            {alarm.source}\n                                        </td>\n                                        <td className=\"px-6 py-4 whitespace-nowrap text-sm font-medium\">\n                                            <div className=\"flex space-x-2\">\n                                                <button className=\"border border-gray-300 rounded px-4 py-1 text-xs font-medium text-gray-700 hover:bg-gray-50\">\n                                                    ACK\n                                                </button>\n                                                <button className=\"border border-gray-300 rounded px-4 py-1 text-xs font-medium text-gray-700 hover:bg-gray-50\">\n                                                    View\n                                                </button>\n                                            </div>\n                                        </td>\n                                    </tr>\n                                ))}\n                            </tbody>\n                        </table>\n                    </div>\n                </div>\n            );\n        }\n\n        function Footer() {\n            return (\n                <footer className=\"bg-gray-100 py-4 px-6 text-xs text-gray-500 border-t\">\n                    <div className=\"flex items-center justify-between\">\n                        <span>Connection: OK · Latency: 22 ms · Compliance: ANSI/ISA