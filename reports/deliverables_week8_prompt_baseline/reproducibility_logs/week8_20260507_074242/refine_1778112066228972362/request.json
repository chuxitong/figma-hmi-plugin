>\n                            2026-04-19 14:34:55 MSK\n                        </div>\n                    </div>\n                </header>\n            );\n        }\n\n        function SummaryCards() {\n            const cards = [\n                {\n                    title: 'Critical',\n                    value: '2',\n                    subtitle: 'active',\n                    color: 'border-red-500',\n                    bgColor: 'bg-red-50',\n                    change: '+1 за смену',\n                    changeColor: 'text-green-600'\n                },\n                {\n                    title: 'Warning',\n                    value: '5',\n                    subtitle: 'active',\n                    color: 'border-orange-500',\n                    bgColor: 'bg-orange-50',\n                    change: '-1 за смену',\n                    changeColor: 'text-gray-500'\n                },\n                {\n                    title: 'Information',\n                    value: '11',\n                    subtitle: 'recent',\n                    color: 'border-green-500',\n                    bgColor: 'bg-green-50',\n                    change: '+3 за смену',\n                    changeColor: 'text-green-600'\n                },\n                {\n                    title: 'Acknowledged',\n                    value: '34',\n                    subtitle: 'in 24h',\n                    color: 'border-green-500',\n                    bgColor: 'bg-green-50',\n                    change: '+7 за смену',\n                    changeColor: 'text-green-600'\n                },\n                {\n                    title: 'MTBA',\n                    value: '1h 42m',\n                    subtitle: '',\n                    color: 'border-orange-500',\n                    bgColor: 'bg-orange-50',\n                    change: '-12m за смену',\n                    changeColor: 'text-gray-500'\n                }\n            ];\n\n            return (\n                <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4 mb-4\">\n                    {cards.map((card, index) => (\n                        <div key={index} className={`${card.bgColor} border-l-4 ${card.color} rounded-md p-4 shadow-sm`}>\n                            <div className=\"flex justify-between items-start\">\n                                <div>\n                                    <h3 className=\"text-sm text-gray-500\">{card.title}</h3>\n                                    <div className=\"text-3xl font-bold text-gray-800\">\n                                        {card.value} <span className=\"text-sm font-normal\">{card.subtitle}</span>\n                                    </div>\n                                </div>\n                            </div>\n                            <div className=\"mt-2 text-xs flex items-center\">\n                                <span className={`${card.changeColor}`}>\n                                    {card.change.includes('+') ? '▲' : '▼'} {card.change.substring(2)}\n                                </span>\n                            </div>\n                        </div>\n                    ))}\n                </div>\n            );\n        }\n\n        function FilterSection() {\n            return (\n                <div className=\"bg-white rounded-lg shadow-sm border border-gray-200 p-4 mb-4\">\n                    <div className=\"flex flex-wrap items-center justify-between\">\n                        <div className=\"flex items-center space-x-2 mr-4\">\n                            <span className=\"text-sm text-gray-600\">Severity</span>\n                            <button className=\"bg-red-600 text-white px-4 py-1 rounded-full text-sm font-bold\">\n                                CRITICAL\n                            </button>\n                            <button className=\"bg-orange-500 text-white px-4 py-1 rounded-full text-sm font-bold\">\n                                WARNING\n                            </button>\n                            <button className=\"bg-blue-600 text-white px-4 py-1 rounded-full text-sm font-bold\">\n                                INFO\n                            </button>\n                        </div>\n                        \n                        <div className=\"flex items-center space-x-4\">\n                            <div className=\"flex items-center space-x-2\">\n                                <span className=\"text-sm text-gray-600\">Tag / описание</span>\n                            </div>\n                            <div className=\"relative\">\n                                <input \n                                    type=\"text\" \n                                    placeholder=\"Введите тер или часть описания...\" \n                                    className=\"border border-gray-300 rounded-md px-4 py-1 w-64 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent\"\n                                />\n                            </div>\n                            <button className=\"bg-green-700 hover:bg-green-800 text-white font-bold py-2 px-6 rounded\">\n                                ACK ALL\n                            </button>\n                            <button className=\"border border-gray-300 text-gray-700 font-medium py-2 px-4 rounded-md hover:bg-gray-50\">\n                                Export...\n                            </button>\n                        </div>\n                    </div>\n                </div>\n            );\n        }\n\n        function AlarmTable() {\n            const alarms = [\n                {\n                    severity: 'CRITICAL',\n                    severityColor: 'bg-red-600',\n                    time: '14:31:42',\n                    tag: 'TT-301',\n                    description: 'Motor temperature exceeds high-high limit',\n                    value: '94.2',\n                    unit: '°C',\n                    source: 'Refinery2/U2/M-301'\n                },\n                {\n                    severity: 'CRITICAL',\n                    severityColor: 'bg-red-600',\n                    time: '14:28:15',\n                    tag: 'PT-102',\n                    description: 'Discharge pressure too high',\n                    value: '5.8',\n                    unit: 'bar',\n                    source: 'Refinery2/U1/P-102'\n                },\n                {\n                    severity: 'WARNING',\n                    severityColor: 'bg-orange-500',\n                    time: '14:22:10',\n                    tag: 'FT-401',\n                    description: 'Flow rate deviation > 12 %',\n                    value: '23.1',\n                    unit: 'm³/h',\n                    source: 'Refinery2/U4/F-401'\n                },\n                {\n                    severity: 'WARNING',\n                    severityColor: 'bg-orange-500',\n                    time: '14:15:30',\n                    tag: 'CT-502',\n                    description: 'Cooling water temperature rising',\n                    value: '38.5',\n                    unit: '°C',\n                    source: 'Utilities/CW-502'\n                },\n                {\n                    severity: 'WARNING',\n                    severityColor: 'bg-orange-500',\n                    time: '14:09:54',\n                    tag: 'LT-301',\n                    description: 'Tank level above setpoint',\n                    value: '88.4',\n                    unit: '%',\n                    source: 'Refinery2/U2/T-301'\n                },\n                {\n                    severity: 'INFO',\n                    severityColor: 'bg-blue-600',\n                    time: '14:05:18',\n                    tag: 'PDT-201',\n                    description: 'Filter differential pressure',\n                    value: '0.8',\n                    unit: 'bar',\n                    source: 'Refinery2/U2