    "current_code": "<html>\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Batch Recipe Management</title>\n    <script src=\"https://cdn.jsdelivr.net/npm/react@18.0.0/umd/react.development.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/react-dom@18.0.0/umd/react-dom.development.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/@babel/standalone/babel.js\"></script>\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css\"></link>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap');\n        \n        body {\n            font-family: 'Roboto', sans-serif;\n            background-color: #f1f5f9;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"root\"></div>\n\n    <script type=\"text/babel\">\n        const App = () => {\n            return (\n                <div className=\"min-h-screen flex flex-col\">\n                    <Header />\n                    <main className=\"flex-grow p-6 bg-[#f1f5f9]\">\n                        <div className=\"flex gap-6\">\n                            <div className=\"w-2/3 bg-white rounded-lg border border-gray-300 p-6\">\n                                <StepsTable />\n                            </div>\n                            <div className=\"w-1/3 flex flex-col gap-6\">\n                                <LiveParameters />\n                                <Timeline />\n                            </div>\n                        </div>\n                    </main>\n                    <Footer />\n                </div>\n            );\n        };\n\n        const Header = () => {\n            return (\n                <header className=\"bg-[#13314f] text-white py-4 px-6\">\n                    <div className=\"flex justify-between items-center\">\n                        <div>\n                            <div className=\"flex items-center\">\n                                <div className=\"mr-2\">\n                                    <i className=\"fas fa-microchip text-xl\"></i>\n                                </div>\n                                <h1 className=\"text-2xl font-semibold\">Batch Recipe Management</h1>\n                            </div>\n                            <p className=\"text-sm text-gray-300 mt-1\">\n                                Recipe: R-204 · Lot 2026-017 · Batch operator: A. Petrov\n                            </p>\n                        </div>\n                        <div className=\"bg-[#1c4879] rounded-md px-4 py-2 text-sm text-gray-300\">\n                            2026-04-19 14:32:07 MSK\n                        </div>\n                    </div>\n                </header>\n            );\n        };\n\n        const StepsTable = () => {\n            const steps = [\n                { id: 1, name: 'Pre-heat', duration: '10 min', status: 'DONE', color: 'green' },\n                { id: 2, name: 'Fill base', duration: '8 min', status: 'DONE', color: 'green' },\n                { id: 3, name: 'Mix', duration: '15 min', status: 'ACTIVE', color: 'blue' },\n                { id: 4, name: 'Add catalyst', duration: '4 min', status: 'PENDING', color: 'gray' },\n                { id: 5, name: 'Hold', duration: '20 min', status: 'PENDING', color: 'gray' },\n                { id: 6, name: 'Cool down', duration: '12 min', status: 'PENDING', color: 'gray' },\n                { id: 7, name: 'Discharge', duration: '6 min', status: 'PENDING', color: 'gray' },\n            ];\n\n            return (\n                <div>\n                    <h2 className=\"text-lg font-semibold mb-4 text-gray-800\">Steps</h2>\n                    <div className=\"overflow-x-auto\">\n                        <table className=\"w-full border-collapse\">\n                            <thead>\n                                <tr className=\"bg-gray-100\">\n                                    <th className=\"text-left py-2 px-4 text-sm text-gray-600 border-b\">#</th>\n                                    <th className=\"text-left py-2 px-4 text-sm text-gray-600 border-b\">Step</th>\n                                    <th className=\"text-left py-2 px-4 text-sm text-gray-600 border-b\">Duration</th>\n                                    <th className=\"text-left py-2 px-4 text-sm text-gray-600 border-b\">Status</th>\n                                    <th className=\"text-left py-2 px-4 text-sm text-gray-600 border-b\">Action</th>\n                                </tr>\n                            </thead>\n                            <tbody>\n                                {steps.map((step) => (\n                                    <StepRow key={step.id} step={step} />\n                                ))}\n                            </tbody>\n                        </table>\n                    </div>\n                </div>\n            );\n        };\n\n        const StepRow = ({ step }) => {\n            const getStatusBg = (status) => {\n                switch (status) {\n                    case 'DONE':\n                        return 'bg-[#2e7d32] text-white';\n                    case 'ACTIVE':\n                        return 'bg-[#1976d2] text-white';\n                    case 'PENDING':\n                        return 'bg-[#4e5b70] text-white';\n                    default:\n                        return 'bg-gray-500 text-white';\n                }\n            };\n\n            return (\n                <tr className=\"border-b hover:bg-gray-50\">\n                    <td className=\"py-3 px-4 text-gray-800\">{step.id}</td>\n                    <td className=\"py-3 px-4 text-gray-800 font-medium\">{step.name}</td>\n                    <td className=\"py-3 px-4 text-gray-800\">{step.duration}</td>\n                    <td className=\"py-3 px-4\">\n                        <span className={`px-8 py-1 rounded text-xs font-medium ${getStatusBg(step.status)}`}>\n                            {step.status}\n                        </span>\n                    </td>\n                    <td className=\"py-3 px-4\">\n                        <button className=\"px-6 py-1 border border-gray-400 rounded-md text-gray-800 font-medium hover:bg-gray-50\">\n                            View\n                        </button>\n                    </td>\n                </tr>\n            );\n        };\n\n        const LiveParameters = () => {\n            const parameters = [\n                { label: 'Temperature', value: '65.4', unit: '°C', status: 'OK' },\n                { label: 'pH', value: '7.1', unit: '', status: 'OK' },\n                { label: 'RPM', value: '240', unit: '', status: 'OK' },\n                { label: 'Pressure', value: '1.18', unit: 'bar', status: 'WARN' }\n            ];\n\n            return (\n                <div className=\"bg-white rounded-lg border border-gray-300 p-6\">\n                    <h2 className=\"text-lg font-semibold mb-4 text-gray-800\">Live parameters</h2>\n                    <div className=\"grid grid-cols-2 gap-4\">\n                        {parameters.map((param, index) => (\n                            <div key={index} className=\"border rounded-lg p-4\">\n                                <div className=\"text-sm text-gray-500 mb-2\">{param.label}</div>\n                                <div className=\"flex items-end\">\n                                    <span className=\"text-4xl font-medium text-gray-800\">{param.value}</span>\n                                    <span className=\"text-xl text-gray-600 ml-2\">{param.unit}</span>\n                                </div>\n                                <div className=\"mt-2\">\n                                    <span className={`px-8 py-1 rounded text-xs font-medium ${\n                                        param.status === 'OK' ? 'bg-[#2e7d32] text-white' : 'bg-[#e65100] text-white'\n                                    }`}>\n                                        {param.status}\n                                    </span>\n                                </div>\n                            </div>\n                        ))}\n                    </div>\n                </div>\n            );\n        };\n\n        const Timeline = () => {\n            const timelineSteps = [\n                { number: 1, active: true, time: '10m' },\n                { number: 2, active: true, time: '8m' },\n                { number: 3, active: true, time: '15m', highlight: true },\n                { number: 4, active: false, time: '4m' },\n                { number: 5, active: false, time: '20m' },\n                { number: 6, active: false, time: '12m' },\n                { number: 7, active: false, time: '6m' }\n            ];\n\n            return (\n                <div className=\"bg-white rounded-lg border border-gray-300 p-6\">\n                    <h2 className=\"text-lg font-semibold mb-6 text-gray-800\">Timeline</h2>\n                    \n                    <div className=\"flex justify-between items-center mb-8\">\n                        {timelineSteps.map((step) => (\n                            <div key={step.number} className=\"flex flex-col items-center\">\n                                <div className={`w-8 h-8 rounded-full flex items-center justify-center text-white text-sm font-medium ${\n                                    step.highlight ? 'bg-blue-500' : step.active ? 'bg-green-700' : 'bg-gray-500'\n                                }`}>\n                                    {step.number}\n                                </div>\n                            </div>\n                        ))}\n                    </div>\n                    \n                    <div className=\"flex justify-between text-xs text-gray-500 mb-8\">\n                        {timelineSteps.map((step) => (\n                            <div key={step.number} className=\"w-8\">\n                                {step.time}\n                            </div>\n                        ))}\n                    </div>\n\n                    <div className=\"flex gap-4 mt-4\">\n                        <button className=\"flex-1 bg-[#2e7d32] text-white py-3 px-4 rounded-md font-medium text-lg\">\n                            RESUME\n                        </button>\n                        <button className=\"flex-1 bg-[#e65100] text-white py-3 px-4 rounded-md font-medium text-lg\">\n                            HOLD\n                        </button>\n                        <button className=\"flex-1 bg-[#d32f2f] text-white py-3 px-4 rounded-md font-medium text-lg\">\n                            ABORT\n                        </button>\n                    </div>\n                </div>\n            );\n        };\n\n        const Footer = () => {\n            return (\n                <footer className=\"bg-[#f8fafc] border-t py-4 px-6\">\n                    <div className=\"container mx-auto\">\n                        <p className=\"text-sm text-gray-500\">\n                            Recipe R-204 · Step 3 of 7 ACTIVE · Compliance: ANSI/ISA-101.01\n                        </p>\n                    </div>\n                </footer>\n            );\n        };\n\n        ReactDOM.render(<App />, document.getElementById('root'));\n    </script>\n</body>\n</html>",
