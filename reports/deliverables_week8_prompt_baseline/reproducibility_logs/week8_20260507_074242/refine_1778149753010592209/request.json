    "current_code": "<html>\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Batch Recipe Management</title>\n    <script src=\"https://cdn.jsdelivr.net/npm/react@18.0.0/umd/react.development.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/react-dom@18.0.0/umd/react-dom.development.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/@babel/standalone/babel.js\"></script>\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css\">\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap');\n        body {\n            font-family: 'Roboto', sans-serif;\n            background-color: #f8fafc;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"root\"></div>\n\n    <script type=\"text/babel\">\n        const App = () => {\n            return (\n                <div className=\"min-h-screen flex flex-col\">\n                    <Header />\n                    <MainContent />\n                    <Footer />\n                </div>\n            );\n        };\n\n        const Header = () => {\n            return (\n                <header className=\"bg-[#1a2c45] text-white py-4 px-6\">\n                    <div className=\"flex justify-between items-center\">\n                        <div className=\"flex items-center space-x-2\">\n                            <i className=\"fas fa-cog text-white\"></i>\n                            <div>\n                                <h1 className=\"text-xl font-semibold\">Batch Recipe Management</h1>\n                                <p className=\"text-sm text-gray-300\">Recipe: R-204 · Lot 2026-017 · Batch operator: A. Petrov</p>\n                            </div>\n                        </div>\n                        <div className=\"bg-[#1e3a5c] rounded-md px-4 py-2 text-sm\">\n                            2026-04-19 14:32:07 MSK\n                        </div>\n                    </div>\n                </header>\n            );\n        };\n\n        const MainContent = () => {\n            return (\n                <main className=\"flex-grow p-6 bg-gray-50\">\n                    <div className=\"flex gap-6\">\n                        <div className=\"w-2/3 bg-white rounded-lg border border-gray-200 p-6\">\n                            <StepsTable />\n                        </div>\n                        <div className=\"w-1/3\">\n                            <div className=\"bg-white rounded-lg border border-gray-200 p-6 mb-6\">\n                                <h2 className=\"text-lg font-semibold text-gray-800 mb-4\">Live parameters</h2>\n                                <divParameters />\n                            </div>\n                            <div className=\"bg-white rounded-lg border border-gray-200 p-6\">\n                                <h2 className=\"text-lg font-semibold text-gray-800 mb-6\">Timeline</h2>\n                                <Timeline />\n                                <div className=\"mt-8 flex justify-between\">\n                                    <button className=\"bg-[#2b8a3e] hover:bg-[#257a38] text-white font-semibold py-3 px-6 rounded w-1/3 mr-2\">\n                                        RESUME\n                                    </button>\n                                    <button className=\"bg-[#e75b12] hover:bg-[#d6510c] text-white font-semibold py-3 px-6 rounded w-1/3 mx-2\">\n                                        HOLD\n                                    </button>\n                                    <button className=\"bg-[#dc3545] hover:bg-[#c93039] text-white font-semibold py-3 px-6 rounded w-1/3 ml-2\">\n                                        ABORT\n                                    </button>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </main>\n            );\n        };\n\n        const StepsTable = () => {\n            const steps = [\n                { id: 1, name: 'Pre-heat', duration: '10 min', status: 'DONE', statusColor: 'bg-[#2563eb]' },\n                { id: 2, name: 'Fill base', duration: '8 min', status: 'DONE', statusColor: 'bg-[#2563eb]' },\n                { id: 3, name: 'Mix', duration: '15 min', status: 'ACTIVE', statusColor: 'bg-[#2563eb]' },\n                { id: 4, name: 'Add catalyst', duration: '4 min', status: 'PENDING', statusColor: 'bg-gray-500' },\n                { id: 5, name: 'Hold', duration: '20 min', status: 'PENDING', statusColor: 'bg-gray-500' },\n                { id: 6, name: 'Cool down', duration: '12 min', status: 'PENDING', statusColor: 'bg-gray-500' },\n                { id: 7, name: 'Discharge', duration: '6 min', status: 'PENDING', statusColor: 'bg-gray-500' },\n            ];\n\n            return (\n                <div>\n                    <h2 className=\"text-lg font-semibold text-gray-800 mb-4\">Steps</h2>\n                    <div className=\"overflow-x-auto\">\n                        <table className=\"min-w-full\">\n                            <thead className=\"bg-gray-100\">\n                                <tr>\n                                    <th className=\"px-4 py-2 text-left text-sm text-gray-600\">#</th>\n                                    <th className=\"px-4 py-2 text-left text-sm text-gray-600\">Step</th>\n                                    <th className=\"px-4 py-2 text-left text-sm text-gray-600\">Duration</th>\n                                    <th className=\"px-4 py-2 text-left text-sm text-gray-600\">Status</th>\n                                    <th className=\"px-4 py-2 text-left text-sm text-gray-600\">Action</th>\n                                </tr>\n                            </thead>\n                            <tbody>\n                                {steps.map((step) => (\n                                    <tr key={step.id} className=\"border-b border-gray-200\">\n                                        <td className=\"px-4 py-3 text-gray-800\">{step.id}</td>\n                                        <td className=\"px-4 py-3 text-gray-800 font-medium\">{step.name}</td>\n                                        <td className=\"px-4 py-3 text-gray-800\">{step.duration}</td>\n                                        <td className=\"px-4 py-3\">\n                                            <span className={`${step.statusColor} text-white text-xs font-medium px-8 py-1 rounded`}>\n                                                {step.status}\n                                            </span>\n                                        </td>\n                                        <td className=\"px-4 py-3\">\n                                            <button className=\"border border-gray-400 text-gray-800 px-4 py-1 rounded hover:bg-gray-50\">\n                                                View\n                                            </button>\n                                        </td>\n                                    </tr>\n                                ))}\n                            </tbody>\n                        </table>\n                    </div>\n                </div>\n            );\n        };\n\n        const divParameters = () => {\n            const parameters = [\n                { label: 'Temperature', value: '65.4', unit: '°C', status: 'OK', statusColor: 'bg-[#2563eb]' },\n                { label: 'pH', value: '7.1', unit: '', status: 'OK', statusColor: 'bg-[#2563eb]' },\n                { label: 'RPM', value: '240', unit: '', status: 'OK', statusColor: 'bg-[#2563eb]' },\n                { label: 'Pressure', value: '1.18', unit: 'bar', status: 'WARN', statusColor: 'bg-[#e75b12]' }\n            ];\n\n            return (\n                <div className=\"grid grid-cols-2 gap-4\">\n                    {parameters.map((param, index) => (\n                        <div key={index} className=\"border border-gray-200 rounded-lg p-4\">\n                            <div className=\"text-sm text-gray-500 mb-1\">{param.label}</div>\n                            <div className=\"flex items-center\">\n                                <span className=\"text-3xl font-medium text-gray-800 mr-2\">{param.value}</span>\n                                <span className=\"text-lg text-gray-600\">{param.unit}</span>\n                            </div>\n                            <div className=\"mt-2\">\n                                <span className={`${param.statusColor} text-white text-xs font-medium px-8 py-0.5 rounded`}>\n                                    {param.status}\n                                </span>\n                            </div>\n                        </div>\n                    ))}\n                </div>\n            );\n        };\n\n        const Timeline = () => {\n            const timelineSteps = [\n                { id: 1, active: false, color: 'bg-green-600' },\n                { id: 2, active: false, color: 'bg-green-600' },\n                { id: 3, active: true, color: 'bg-blue-600' },\n                { id: 4, active: false, color: 'bg-gray-500' },\n                { id: 5, active: false, color: 'bg-gray-500' },\n                { id: 6, active: false, color: 'bg-gray-500' },\n                { id: 7, active: false, color: 'bg-gray-500' }\n            ];\n\n            return (\n                <div className=\"flex items-center justify-between\">\n                    {timelineSteps.map((step, index) => (\n                        <div key={index} className=\"flex flex-col items-center\">\n                            <div className={`w-8 h-8 rounded-full ${step.color} text-white flex items-center justify-center font-medium text-sm`}>\n                                {step.id}\n                            </div>\n                            <div className=\"text-xs text-gray-500 mt-2\">\n                                {index === 0 ? '10m' : \n                                 index === 1 ? '8m' :\n                                 index === 2 ? '15m' :\n                                 index === 3 ? '4m' :\n                                 index === 4 ? '20m' :\n                                 index === 5 ? '12m' : '6m'}\n                            </div>\n                            {index < timelineSteps.length - 1 && (\n                                <div className=\"w-12 h-0.5 bg-gray-300 mt-2\"></div>\n                            )}\n                        </div>\n                    ))}\n                </div>\n            );\n        };\n\n        const Footer = () => {\n            return (\n                <footer className=\"bg-gray-100 py-4 px-6 border-t border-gray-200\">\n                    <div className=\"text-xs text-gray-500\">\n                        Recipe R-204 · Step 3 of 7 ACTIVE · Compliance: ANSI/ISA-101.01\n                    </div>\n                </footer>\n            );\n        };\n\n        ReactDOM.render(<App />, document.getElementById('root'));\n    </script>\n</body>\n</html>",
