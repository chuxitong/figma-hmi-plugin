                  </div>\n                            \n                            <div className=\"bg-white rounded-md border-l-4 border-green-700 p-4\">\n                                <div className=\"text-gray-500 text-sm\">Power factor</div>\n                                <div className=\"text-3xl font-bold text-gray-800 mt-1\">0.92</div>\n                                <div className=\"text-gray-500 text-xs mt-1\">\n                                    <span className=\"text-green-600\">▲</span> 0.01 за смену\n                                </div>\n                            </div>\n                        </div>\n\n                        {/* Charts Section */}\n                        <div className=\"grid grid-cols-1 lg:grid-cols-2 gap-6\">\n                            {/* Power Consumption Chart */}\n                            <div className=\"bg-white rounded-lg border border-gray-200 p-6\">\n                                <h2 className=\"text-gray-800 font-semibold mb-6\">Power consumption by zone</h2>\n                                \n                                <div className=\"space-y-4\">\n                                    <ZoneRow zone=\"Zone A\" percentage={62} status=\"OK\" />\n                                    <ZoneRow zone=\"Zone B\" percentage={48} status=\"OK\" />\n                                    <ZoneRow zone=\"Zone C\" percentage={81} status=\"WARN\" />\n                                    <ZoneRow zone=\"Zone D\" percentage={35} status=\"OK\" />\n                                    <ZoneRow zone=\"Zone E\" percentage={90} status=\"ALARM\" />\n                                    <ZoneRow zone=\"Zone F\" percentage={27} status=\"OK\" />\n                                </div>\n                            </div>\n\n                            {/* Source Breakdown Chart */}\n                            <div className=\"bg-white rounded-lg border border-gray-200 p-6\">\n                                <h2 className=\"text-gray-800 font-semibold mb-6\">Source breakdown</h2>\n                                \n                                <div className=\"flex items-center justify-center\">\n                                    <div className=\"relative w-64 h-64\">\n                                        {/* Donut chart representation */}\n                                        <svg viewBox=\"0 0 100 100\" className=\"w-full h-full\">\n                                            {/* Green section - 57% */}\n                                            <circle \n                                                cx=\"50\" \n                                                cy=\"50\" \n                                                r=\"40\" \n                                                fill=\"transparent\" \n                                                stroke=\"#166534\" \n                                                strokeWidth=\"20\"\n                                                strokeDasharray=\"353 628\" \n                                                strokeDashoffset=\"0\" \n                                                transform=\"rotate(-90 50 50)\"\n                                            />\n                                            {/* Blue section - 25% */}\n                                            <circle \n                                                cx=\"50\" \n                                                cy=\"50\" \n                                                r=\"40\" \n                                                fill=\"transparent\" \n                                                stroke=\"#2563eb\" \n                                                strokeWidth=\"20\"\n                                                strokeDasharray=\"156 628\" \n                                                strokeDashoffset=\"-353\" \n                                                transform=\"rotate(-90 50 50)\"\n                                            />\n                                            {/* Orange section - 18% */}\n                                            <circle \n                                                cx=\"50\" \n                                                cy=\"50\" \n                                                r=\"40\" \n                                                fill=\"transparent\" \n                                                stroke=\"#f97316\" \n                                                strokeWidth=\"20\"\n                                                strokeDasharray=\"112 628\" \n                                                strokeDashoffset=\"-509\" \n                                                transform=\"rotate(-90 50 50)\"\n                                            />\n                                            {/* Inner white circle */}\n                                            <circle \n                                                cx=\"50\" \n                                                cy=\"50\" \n                                                r=\"30\" \n                                                fill=\"white\" \n                                            />\n                                        </svg>\n                                        \n                                        <div className=\"absolute inset-0 flex items-center justify-center\">\n                                            <div className=\"text-center\">\n                                                <div className=\"text-4xl font-bold text-gray-800\">100%</div>\n                                                <div className=\"text-xs text-gray-500 mt-1\">today</div>\n                                            </div>\n                                        </div>\n                                    </div>\n                                    \n                                    <div className=\"ml-8 space-y-3\">\n                                        <div className=\"flex items-center\">\n                                            <div className=\"w-4 h-4 bg-green-700 mr-2\"></div>\n                                            <span className=\"text-sm text-gray-700\">Электроэнергия · 57 %</span>\n                                        </div>\n                                        <div className=\"flex items-center\">\n                                            <div className=\"w-4 h-4 bg-orange-500 mr-2\"></div>\n                                            <span className=\"text-sm text-gray-700\">Газ · 25 %</span>\n                                        </div>\n                                        <div className=\"flex items-center\">\n                                            <div className=\"w-4 h-4 bg-blue-600 mr-2\"></div>\n                                            <span className=\"text-sm text-gray-700\">Утилизация тепла · 18 %</span>\n                                        </div>\n                                    </div>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n\n                    {/* Footer */}\n                    <footer className=\"mt-8 py-4 px-6 text-xs text-gray-500 border-t border-gray-200\">\n                        Connection: OK · Tariff plan: Industrial-2 · Compliance: ANSI/ISA-101.01\n                    </footer>\n                </div>\n            );\n        };\n\n        ReactDOM.render(<App />, document.getElementById('root'));\n    </script>\n</body>\n</html>",
