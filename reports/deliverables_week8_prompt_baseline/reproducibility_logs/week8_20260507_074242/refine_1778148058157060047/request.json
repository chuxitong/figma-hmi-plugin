    "current_code": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Energy Monitoring Dashboard</title>\n    <script src=\"https://cdn.jsdelivr.net/npm/react@18.0.0/umd/react.development.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/react-dom@18.0.0/umd/react-dom.development.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/@babel/standalone/babel.js\"></script>\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css\">\n    <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\n    <style>\n        body {\n            font-family: 'Inter', sans-serif;\n            background-color: #f0f2f5;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"root\"></div>\n\n    <script type=\"text/babel\">\n        const MetricCard = ({ title, value, change, color = \"green\" }) => {\n            return (\n                <div className=\"bg-white rounded-md border-l-4 border-\" style={{borderLeftColor: color === 'green' ? '#166534' : '#f97316'}} className=\"bg-white rounded-md border-l-4 px-4 py-4\">\n                    <div className=\"text-gray-500 text-sm\">{title}</div>\n                    <div className=\"text-3xl font-bold text-gray-800 mt-1\">{value}</div>\n                    <div className=\"text-gray-500 text-xs mt-1\">\n                        <span className=\"text-green-600\">▲</span> {change} за смену\n                    </div>\n                </div>\n            );\n        };\n\n        const ZoneRow = ({ zone, percentage, status }) => {\n            const getStatusColor = () => {\n                switch(status.toLowerCase()) {\n                    case 'ok': return 'bg-green-700';\n                    case 'warn': return 'bg-orange-500';\n                    case 'alarm': return 'bg-red-600';\n                    default: return 'bg-green-700';\n                }\n            };\n\n            return (\n                <div className=\"flex items-center justify-between py-2\">\n                    <div className=\"w-16 text-sm font-medium text-gray-700\">{zone}</div>\n                    <div className=\"flex-1 mx-4\">\n                        <div className=\"w-full bg-gray-100 rounded-full h-6\">\n                            <div \n                                className={`h-6 rounded-full ${getStatusColor()}`} \n                                style={{width: `${percentage}%`}}\n                            ></div>\n                        </div>\n                    </div>\n                    <div className=\"w-16 text-right\">\n                        <span className=\"text-sm text-gray-600\">{percentage}%</span>\n                    </div>\n                    <div className=\"w-16\">\n                        <span className={`px-3 py-1 rounded text-xs font-medium text-white ${getStatusColor()}`}>\n                            {status.toUpperCase()}\n                        </span>\n                    </div>\n                </div>\n            );\n        };\n\n        const App = () => {\n            return (\n                <div className=\"min-h-screen bg-gray-50\">\n                    {/* Header */}\n                    <header className=\"bg-slate-900 text-white px-6 py-4\">\n                        <div className=\"flex justify-between items-center\">\n                            <div>\n                                <h1 className=\"text-2xl font-semibold\">Energy Monitoring Dashboard</h1>\n                                <p className=\"text-slate-300 text-sm mt-1\">Energy Center 2 · Day shift · All zones</p>\n                            </div>\n                            <div className=\"bg-slate-800 rounded-md px-4 py-2 text-slate-300 text-sm\">\n                                2026-04-19 14: