  "code": "<html>\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Operator Control Panel</title>\n    <script src=\"https://cdn.jsdelivr.net/npm/react@18.0.0/umd/react.development.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/react-dom@18.0.0/umd/react-dom.development.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/@babel/standalone/babel.js\"></script>\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css\"></link>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap');\n        body {\n            font-family: 'Roboto', sans-serif;\n            background-color: #f1f5f9;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"root\"></div>\n\n    <script type=\"text/babel\">\n        const App = () => {\n            return (\n                <div className=\"min-h-screen flex flex-col\">\n                    <Header />\n                    <main className=\"flex-grow p-6 bg-gray-50\">\n                        <div className=\"grid grid-cols-1 lg:grid-cols-2 gap-6\">\n                            <ControlPanel />\n                            <ReadoutPanel />\n                        </div>\n                    </main>\n                    <Footer />\n                </div>\n            );\n        };\n\n        const Header = () => {\n            return (\n                <header className=\"bg-[#0a3a5d] text-white py-4 px-6\">\n                    <div className=\"container mx-auto flex justify-between items-center\">\n                        <div>\n                            <h1 className=\"text-2xl font-bold\">Operator Control Panel</h1>\n                            <p className=\"text-sm text-gray-300\">Process Loop: Mixer MX-501 · Operator: A. Petrov</p>\n                        </div>\n                        <div className=\"bg-[#1c3b5e] px-4 py-2 rounded text-sm\">\n                            2026-04-19 14:32:07 MSK\n                        </div>\n                    </div>\n                </header>\n            );\n        };\n\n        const ControlPanel = () => {\n            return (\n                <div className=\"bg-white rounded-lg border border-gray-200 p-6 shadow-sm\">\n                    <h2 className=\"text-lg font-semibold text-gray-800 mb-6\">Manual control</h2>\n                    \n                    <div className=\"flex gap-4 mb-6\">\n                        <button className=\"flex-1 bg-[#2b7d35] text-white text-xl font-bold py-4 rounded-md\">\n                            START\n                        </button>\n                        <button className=\"flex-1 bg-[#dc3545] text-white text-xl font-bold py-4 rounded-md\">\n                            STOP\n                        </button>\n                        <button className=\"flex-1 border-2 border-gray-800 text-gray-800 text-xl font-bold py-4 rounded-md\">\n                            RESET\n                        </button>\n                    </div>\n                    \n                    <div className=\"mb-6\">\n                        <h3 className=\"text-gray-800 font-semibold mb-3\">Operating mode</h3>\n                        <div className=\"flex gap-4\">\n                            <button className=\"flex-1 bg-[#0a3a5d] text-white py-3 rounded-md font-medium\">\n                                AUTO\n                            </button>\n                            <button className=\"flex-1 border-2 border-gray-400 text-gray-800 py-3 rounded-md font-medium\">\n                                MANUAL\n                            </button>\n                            <button className=\"flex-1 border-2 border-gray-400 text-gray-800 py-3 rounded-md font-medium\">\n                                SERVICE\n                            </button>\n                        </div>\n                    </div>\n                    \n                    <div>\n                        <h3 className=\"text-gray-800 font-semibold mb-3\">Setpoints</h3>\n                        \n                        <div className=\"space-y-4\">\n                            <div className=\"flex gap-4 items-center\">\n                                <div className=\"flex-grow\">\n                                    <label className=\"block text-xs text-gray-500 mb-1\">Temperature</label>\n                                    <input \n                                        type=\"text\" \n                                        value=\"75.0 °C\" \n                                        className=\"w-full border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-1 focus:ring-green-500\" \n                                    />\n                                </div>\n                                <button className=\"bg-[#2b7d35] text-white font-bold py-2 px-6 rounded-md\">\n                                    SET\n                                </button>\n                            </div>\n                            \n                            <div className=\"flex gap-4 items-center\">\n                                <div className=\"flex-grow\">\n                                    <label className=\"block text-xs text-gray-500 mb-1\">Flow rate</label>\n                                    <input \n                                        type=\"text\" \n                                        value=\"180 L/min\" \n                                        className=\"w-full border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-1 focus:ring-green-500\" \n                                    />\n                                </div>\n                                <button className=\"bg-[#2b7d35] text-white font-bold py-2 px-6 rounded-md\">\n                                    SET\n                                </button>\n                            </div>\n                            \n                            <div className=\"flex gap-4 items-center\">\n                                <div className=\"flex-grow\">\n                                    <label className=\"block text-xs text-gray-500 mb-1\">Mixer RPM</label>\n                                    <input \n                                        type=\"text\" \n                                        value=\"240 rpm\" \n                                        className=\"w-full border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-1 focus:ring-green-500\" \n                                    />\n                                </div>\n                                <button className=\"bg-[#2b7d35] text-white font-bold py-2 px-6 rounded-md\">\n                                    SET\n                                </button>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            );\n        };\n\n        const ReadoutCard = ({ title, value, unit, status }) => {\n            return (\n                <div className=\"border border-gray-200 rounded-lg p-6 bg-white\">\n                    <div className=\"text-sm text-gray-500 mb-3\">{title}</div>\n                    <div className=\"text-5xl font-bold text-gray-800 mb-2\">{value}</div>\n                    <div className=\"text-sm text-gray-500 mb-4\">{unit}</div>\n                    <div className={`text-white text-center py-1 rounded ${status === 'OK' ? 'bg-[#2b7d35]' : 'bg-[#e85212]'}`}>\n                        {status}\n                    </div>\n                </div>\n            );\n        };\n\n        const ReadoutPanel = () => {\n            return (\n                <div className=\"bg-white rounded-lg border border-gray-200 p-6 shadow-sm\">\n                    <h2 className=\"text-lg font-semibold text-gray-800 mb-6\">Live readouts</h2>\n                    \n                    <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n                        <ReadoutCard \n                            title=\"Temperature out\" \n                            value=\"74.6\" \n                            unit=\"°C\" \n                            status=\"OK\" \n                        />\n                        <ReadoutCard \n                            title=\"Flow out\" \n                            value=\"178\" \n                            unit=\"L/min\" \n                            status=\"OK\" \n                        />\n                        <ReadoutCard \n                            title=\"Mixer RPM\" \n                            value=\"238\" \n                            unit=\"rpm\" \n                            status=\"OK\" \n                        />\n                        <ReadoutCard \n                            title=\"Pressure\" \n                            value=\"3.18\" \n                            unit=\"bar\" \n                            status=\"WARN\" \n                        />\n                    </div>\n                </div>\n            );\n        };\n\n        const Footer = () => {\n            return (\n                <footer className=\"bg-gray-100 border-t border-gray-200 py-3 px-6\">\n                    <div className=\"container mx-auto\">\n                        <p className=\"text-xs text-gray-500\">\n                            Connection: OK · Loop status: closed-loop AUTO · Compliance: ANSI/ISA-101.01\n                        </p>\n                    </div>\n                </footer>\n            );\n        };\n\n        ReactDOM.render(<App />, document.getElementById('root'));\n    </script>\n</body>\n</html>",
