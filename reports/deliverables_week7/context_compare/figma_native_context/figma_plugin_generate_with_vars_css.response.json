  "code": "<html>\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Operator Control Panel</title>\n    <script src=\"https://cdn.jsdelivr.net/npm/react@18.0.0/umd/react.development.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/react-dom@18.0.0/umd/react-dom.development.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/@babel/standalone/babel.js\"></script>\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css\"></link>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap');\n        \n        body {\n            font-family: 'Roboto', sans-serif;\n            background-color: #f1f5f9;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"root\"></div>\n\n    <script type=\"text/babel\">\n        function App() {\n            return (\n                <div className=\"min-h-screen flex flex-col\">\n                    <Header />\n                    <main className=\"flex-grow p-6 bg-slate-50\">\n                        <div className=\"flex gap-6 w-full\">\n                            <ControlPanel />\n                            <ReadoutsPanel />\n                        </div>\n                    </main>\n                    <Footer />\n                </div>\n            );\n        }\n\n        function Header() {\n            return (\n                <header className=\"bg-[#1d4067] text-white py-4 px-6\">\n                    <div className=\"flex justify-between items-center\">\n                        <div>\n                            <h1 className=\"text-2xl font-bold\">Operator Control Panel</h1>\n                            <p className=\"text-sm text-slate-300\">Pump Group 3 - Mixer MX-501 - Operator: A. Petrov</p>\n                        </div>\n                        <div className=\"bg-[#1a2d4f] px-4 py-2 rounded text-sm\">\n                            2026-04-19 14:32:07 MSK\n                        </div>\n                    </div>\n                </header>\n            );\n        }\n\n        function ControlPanel() {\n            return (\n                <div className=\"w-1/2 bg-white rounded-lg border border-gray-300 p-6\">\n                    <h2 className=\"text-lg font-semibold text-gray-800 mb-6\">Manual control</h2>\n                    \n                    <div className=\"flex gap-4 mb-6\">\n                        <button className=\"flex-1 bg-[#2e7d32] text-white text-xl font-bold py-8 rounded-md\">\n                            START\n                        </button>\n                        <button className=\"flex-1 bg-[#c62828] text-white text-xl font-bold py-8 rounded-md\">\n                            STOP\n                        </button>\n                        <button className=\"flex-1 border-2 border-gray-800 text-[#2e7d32] text-xl font-bold py-8 rounded-md\">\n                            RESET\n                        </button>\n                    </div>\n                    \n                    <div className=\"mb-6\">\n                        <h3 className=\"text-gray-800 font-semibold mb-3\">Operating mode</h3>\n                        <div className=\"flex gap-4\">\n                            <button className=\"flex-1 bg-[#1a2d4f] text-white font-bold py-3 rounded-md\">\n                                AUTO\n                            </button>\n                            <button className=\"flex-1 border-2 border-gray-400 text-gray-700 font-bold py-3 rounded-md\">\n                                MANUAL\n                            </button>\n                            <button className=\"flex-1 border-2 border-gray-400 text-gray-700 font-bold py-3 rounded-md\">\n                                SERVICE\n                            </button>\n                        </div>\n                    </div>\n                    \n                    <div>\n                        <h3 className=\"text-gray-800 font-semibold mb-3\">Setpoints</h3>\n                        <div className=\"space-y-4\">\n                            <div className=\"flex gap-2\">\n                                <div className=\"w-32 text-xs text-gray-500\">Temperature</div>\n                                <input type=\"text\" value=\"75.0 °C\" className=\"flex-1 border border-gray-300 rounded-md px-3 py-2 text-sm\" />\n                                <button className=\"bg-[#2e7d32] text-white font-bold px-6 py-1 rounded-md\">\n                                    SET\n                                </button>\n                            </div>\n                            \n                            <div className=\"flex gap-2\">\n                                <div className=\"w-32 text-xs text-gray-500\">Flow rate</div>\n                                <input type=\"text\" value=\"180 L/min\" className=\"flex-1 border border-gray-300 rounded-md px-3 py-2 text-sm\" />\n                                <button className=\"bg-[#2e7d32] text-white font-bold px-6 py-1 rounded-md\">\n                                    SET\n                                </button>\n                            </div>\n                            \n                            <div className=\"flex gap-2\">\n                                <div className=\"w-32 text-xs text-gray-500\">Mixer RPM</div>\n                                <input type=\"text\" value=\"240 rpm\" className=\"flex-1 border border-gray-300 rounded-md px-3 py-2 text-sm\" />\n                                <button className=\"bg-[#2e7d32] text-white font-bold px-6 py-1 rounded-md\">\n                                    SET\n                                </button>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            );\n        }\n\n        function ReadoutsPanel() {\n            return (\n                <div className=\"w-1/2 bg-white rounded-lg border border-gray-300 p-6\">\n                    <h2 className=\"text-lg font-semibold text-gray-800 mb-6\">Live readouts</h2>\n                    \n                    <div className=\"grid grid-cols-2 gap-6\">\n                        <ReadoutCard \n                            title=\"Temperature out\" \n                            value=\"74.6\" \n                            unit=\"°C\" \n                            status=\"OK\" \n                            statusColor=\"bg-[#2e7d32]\"\n                        />\n                        \n                        <ReadoutCard \n                            title=\"Flow out\" \n                            value=\"178\" \n                            unit=\"L/min\" \n                            status=\"OK\" \n                            statusColor=\"bg-[#2e7d32]\"\n                        />\n                        \n                        <ReadoutCard \n                            title=\"Mixer RPM\" \n                            value=\"238\" \n                            unit=\"rpm\" \n                            status=\"OK\" \n                            statusColor=\"bg-[#2e7d32]\"\n                        />\n                        \n                        <ReadoutCard \n                            title=\"Pressure\" \n                            value=\"3.18\" \n                            unit=\"bar\" \n                            status=\"WARN\" \n                            statusColor=\"bg-orange-500\"\n                        />\n                    </div>\n                </div>\n            );\n        }\n\n        function ReadoutCard({ title, value, unit, status, statusColor }) {\n            return (\n                <div className=\"border border-gray-300 rounded-lg p-6\">\n                    <div className=\"text-gray-500 text-sm mb-4\">{title}</div>\n                    <div className=\"text-6xl font-bold text-gray-800 mb-2\">{value}</div>\n                    <div className=\"text-gray-500 text-xs mb-4\">{unit}</div>\n                    <div className={`${statusColor} text-white text-center py-1 rounded text-sm font-bold`}>\n                        {status}\n                    </div>\n                </div>\n            );\n        }\n\n        function Footer() {\n            return (\n                <footer className=\"bg-gray-100 text-gray-500 text-xs py-3 px-6 border-t border-gray-200\">\n                    Connection: OK · Loop status: closed-loop AUTO · Compliance: ANSI/ISA-101.01\n                </footer>\n            );\n        }\n\n        ReactDOM.render(<App />, document.getElementById('root'));\n    </script>\n</body>\n</html>",
