                </div>\n                    </div>\n                </header>\n            );\n        };\n\n        const MetricCard = ({ title, value, change, icon, borderColor, iconColor }) => {\n            return (\n                <div className=\"bg-white rounded-md border-t border-r border-b border-gray-200 p-4\">\n                    <div className=\"text-gray-500 text-sm mb-1\">{title}</div>\n                    <div className=\"text-3xl font-bold text-gray-800 mb-2\">{value}</div>\n                    <div className={`text-xs ${iconColor} flex items-center`}>\n                        <span className=\"mr-1\">{icon}</span>\n                        <span>{change}</span>\n                    </div>\n                </div>\n            );\n        };\n\n        const ZoneConsumption = () => {\n            const zones = [\n                { name: 'Zone A', percentage: 62, status: 'OK', color: 'bg-green-700' },\n                { name: 'Zone B', percentage: 48, status: 'OK', color: 'bg-green-700' },\n                { name: 'Zone C', percentage: 81, status: 'WARN', color: 'bg-orange-500' },\n                { name: 'Zone D', percentage: 35, status: 'OK', color: 'bg-green-700' },\n                { name: 'Zone E', percentage: 90, status: 'ALARM', color: 'bg-red-600' },\n                { name: 'Zone F', percentage: 27, status: 'OK', color: 'bg-green-700' },\n            ];\n\n            return (\n                <div className=\"bg-white rounded-md border border-gray-200 p-6\">\n                    <h2 className=\"text-gray-800 font-semibold mb-6\">Power consumption by zone</h2>\n                    <div className=\"space-y-6\">\n                        {zones.map((zone) => (\n                            <ZoneRow key={zone.name} zone={zone} />\n                        ))}\n                    </div>\n                </div>\n            );\n        };\n\n        const ZoneRow = ({ zone }) => {\n            return (\n                <div className=\"flex items-center justify-between\">\n                    <div className=\"w-1/6 text-gray-700 font-medium\">{zone.name}</div>\n                    <div className=\"flex-grow mx-6\">\n                        <div className=\"bg-gray-100 rounded-full h-6 w-full\">\n                            <div \n                                className={`${zone.color} h-6 rounded-full`} \n                                style={{ width: `${zone.percentage}%` }}\n                            ></div>\n                        </div>\n                    </div>\n                    <div className=\"flex items-center space-x-4\">\n                        <div className=\"w-12 text-right text-gray-600 text-sm\">{zone.percentage}%</div>\n                        <div className={`px-4 py-1 rounded-sm text-xs font-medium text-white ${\n                            zone.status === 'OK' ? 'bg-green-700' : \n                            zone.status === 'WARN' ? 'bg-orange-500' : 'bg-red-600'\n                        }`}>\n                            {zone.status.toUpperCase()}\n                        </div>\n                    </div>\n                </div>\n            );\n        };\n\n        const SourceBreakdown = () => {\n            return (\n                <div className=\"bg-white rounded-md border border-gray-200 p-6\">\n                    <h2 className=\"text-gray-800 font-semibold mb-6\">Source breakdown</h2>\n                    <div className=\"flex items-center justify-center\">\n                        <div className=\"relative w-64 h-64\">\n                            {/* Donut chart */}\n                            <div className=\"w-full h-full rounded-full\" style={{ \n                                background: `conic-gradient(\n                                    #2e7d32 0% 57%, \n                                    #1976d2 57% 75%, \n                                    #e65100 75% 100%\n                                )`, \n                                clipPath: 'circle(50%)'\n                            }}></div>\n                            <div className=\"absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 bg-white rounded-full w-40 h-40 flex items-center justify-center\">\n                                <div className=\"text-center\">\n                                    <div className=\"text-4xl font-bold text-gray-800\">100%</div>\n                                    <div className=\"text-gray-500 text-sm mt-1\">today</div>\n                                </div>\n                            </div>\n                            \n                            {/* Legend */}\n                            <div className=\"absolute right-4 top-4 space-y-2\">\n                                <div className=\"flex items-center\">\n                                    <div className=\"w-4 h-4 bg-green-700 mr-2\"></div>\n                                    <span className=\"text-gray-700 text-sm\">Электроэнергия · 57 %</span>\n                                </div>\n                                <div className=\"flex items-center\">\n                                    <div className=\"w-4 h-4 bg-orange-500 mr-2\"></div>\n                                    <span className=\"text-gray-700 text-sm\">Газ · 25 %</span>\n                                </div>\n                                <div className=\"flex items-center\">\n                                    <div className=\"w-4 h-4 bg-blue-500 mr-2\"></div>\n                                    <span className=\"text-gray-700 text-sm\">Утилизация тепла · 18 %</span>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            );\n        };\n\n        const Footer = () => {\n            return (\n                <footer className=\"bg-gray-50 px-6 py-3 border-t border-gray-200\">\n                    <div className=\"text-gray-500 text-sm\">\n                        Connection: OK · Tariff plan: Industrial-2 · Compliance: ANSI/ISA-101.01\n                    </div>\n                </footer>\n            );\n        };\n\n        ReactDOM.render(<App />, document.getElementById('root'));\n    </script>\n</body>\n</html>",
