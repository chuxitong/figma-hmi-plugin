    "current_code": "<html>\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Batch Recipe Management</title>\n    <script src=\"https://cdn.jsdelivr.net/npm/react@18.0.0/umd/react.development.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/react-dom@18.0.0/umd/react-dom.development.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/@babel/standalone/babel.js\"></script>\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css\">\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');\n        \n        body {\n            font-family: 'Inter', sans-serif;\n            background-color: #f1f5f9;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"root\"></div>\n\n    <script type=\"text/babel\">\n        const App = () => {\n            return (\n                <div className=\"min-h-screen flex flex-col\">\n                    <Header />\n                    <main className=\"flex-1 p-6\">\n                        <div className=\"flex gap-6\">\n                            <div className=\"w-2/3 bg-white rounded-lg border border-gray-300 p-6\">\n                                <StepsTable />\n                            </div>\n                            <div className=\"w-1/3 space-y-6\">\n                                <LiveParameters />\n                                <Timeline />\n                            </div>\n                        </div>\n                    </main>\n                    <Footer />\n                </div>\n            );\n        };\n\n        const Header = () => {\n            return (\n                <header className=\"bg-[#13314f] text-white py-4 px-6\">\n                    <div className=\"flex justify-between items-center\">\n                        <div>\n                            <h1 className=\"text-2xl font-bold\">Batch Recipe Management</h1>\n                            <div className=\"text-sm text-gray-300\">\n                                Recipe R-204 · Lot 2026-017 · Batch operator: A. Petrov\n                            </div>\n                        </div>\n                        <div className=\"bg-[#1d4e8c] text-white px-4 py-2 rounded-md text-sm\">\n                            2026-04-19 14:32:07 MSK\n                        </div>\n                    </div>\n                </header>\n            );\n        };\n\n        const StepsTable = () => {\n            const steps = [\n                { id: 1, name: 'Pre-heat', duration: '10 min', status: 'DONE', statusColor: 'bg-[#2e7d32]' },\n                { id: 2, name: 'Fill base', duration: '8 min', status: 'DONE', statusColor: 'bg-[#2e7d32]' },\n                { id: 3, name: 'Mix', duration: '15 min', status: 'ACTIVE', statusColor: 'bg-[#1976d2]' },\n                { id: 4, name: 'Add catalyst', duration: '4 min', status: 'PENDING', statusColor: 'bg-[#4f6b79]' },\n                { id: 5, name: 'Hold', duration: '20 min', status: 'PENDING', statusColor: 'bg-[#4f6b79]' },\n                { id: 6, name: 'Cool down', duration: '12 min', status: 'PENDING', statusColor: 'bg-[#4f6b79]' },\n                { id: 7, name: 'Discharge', duration: '6 min', status: 'PENDING', statusColor: 'bg-[#4f6b79]' }\n            ];\n\n            return (\n                <div>\n                    <h2 className=\"text-lg font-bold mb-4 text-gray-800\">Steps</h2>\n                    <div className=\"overflow-x-auto\">\n                        <table className=\"w-full\">\n                            <thead className=\"bg-gray-100\">\n                                <tr>\n                                    <th className=\"px-4 py-2 text-left text-sm font-medium text-gray-600\">#</th>\n                                    <th className=\"px-4 py-2 text-left text-sm font-medium text-gray-600\">Step</th>\n                                    <th className=\"px-4 py-2 text-left text-sm font-medium text-gray-600\">Duration</th>\n                                    <th className=\"px-4 py-2 text-left text-sm font-medium text-gray-600\">Status</th>\n                                    <th className=\"px-4 py-2 text-left text-sm font-medium text-gray-600\">Action</th>\n                                </tr>\n                            </thead>\n                            <tbody>\n                                {steps.map((step) => (\n                                    <tr key={step.id} className=\"border-b border-gray-200\">\n                                        <td className=\"px-4 py-4 text-sm text-gray-800\">{step.id}</td>\n                                        <td className=\"px-4 py-4 text-sm font-medium text-gray-800\">{step.name}</td>\n                                        <td className=\"px-4 py-4 text-sm text-gray-600\">{step.duration}</td>\n                                        <td className=\"px-4 py-4\">\n                                            <span className={`${step.statusColor} text-white text-xs px-8 py-1 rounded capitalize font-medium`}>\n                                                {step.status}\n                                            </span>\n                                        </td>\n                                        <td className=\"px-4 py-4\">\n                                            <button className=\"border border-gray-400 text-gray-800 px-6 py-1 rounded text-sm font-medium hover:bg-gray-50\">\n                                                View\n                                            </button>\n                                        </td>\n                                    </tr>\n                                ))}\n                            </tbody>\n                        </table>\n                    </div>\n                </div>\n            );\n        };\n\n        const LiveParameters = () => {\n            const parameters = [\n                { label: 'Temperature', value: '65.4', unit: '°C', status: 'OK', statusColor: 'bg-[#2e7d32]' },\n                { label: 'pH', value: '7.1', unit: '', status: 'OK', statusColor: 'bg-[#2e7d32]' },\n                { label: 'RPM', value: '240', unit: '', status: 'OK', statusColor: 'bg-[#2e7d32]' },\n                { label: 'Pressure', value: '1.18', unit: 'bar', status: 'WARN', statusColor: 'bg-[#e65100]' }\n            ];\n\n            return (\n                <div className=\"bg-white rounded-lg border border-gray-300 p-6\">\n                    <h2 className=\"text-lg font-bold mb-4 text-gray-800\">Live parameters</h2>\n                    <div className=\"grid grid-cols-2 gap-4\">\n                        {parameters.map((param, index) => (\n                            <div key={index} className=\"border border-gray-300 rounded-lg p-4\">\n                                <div className=\"text-sm text-gray-500 mb-2\">{param.label}</div>\n                                <div className=\"flex items-end\">\n                                    <span className=\"text-3xl font-medium text-gray-800\">{param.value}</span>\n                                    <span className=\"text-lg text-gray-500 ml-2\">{param.unit}</span>\n                                </div>\n                                <div className=\"mt-2\">\n                                    <span className={`${param.statusColor} text-white text-xs px-8 py-1 rounded capitalize font-medium`}>\n                                        {param.status}\n                                    </span>\n                                </div>\n                            </div>\n                        ))}\n                    </div>\n                </div>\n            );\n        };\n\n        const Timeline = () => {\n            const timelineItems = [\n                { number: 1, time: '10m', isActive: true },\n                { number: 2, time: '8m', isActive: true },\n                { number: 3, time: '15m', isActive: true },\n                { number: 4, time: '4m', isActive: false },\n                { number: 5, time: '20m', isActive: false },\n                { number: 6, time: '12m', isActive: false },\n                { number: 7, time: '6m', isActive: false }\n            ];\n\n            return (\n                <div className=\"bg-white rounded-lg border border-gray-300 p-6\">\n                    <h2 className=\"text-lg font-bold mb-6 text-gray-800\">Timeline</h2>\n                    <div className=\"flex items-center justify-between mb-8\">\n                        {timelineItems.map((item) => (\n                            <div key={item.number} className=\"flex flex-col items-center\">\n                                <div className={`w-8 h-8 rounded-full flex items-center justify-center text-white text-sm font-medium ${\n                                    item.number <= 3 ? 'bg-green-700' : 'bg-gray-500'\n                                }`}>\n                                    {item.number}\n                                </div>\n                                <div className=\"text-xs text-gray-500 mt-2\">{item.time}</div>\n                            </div>\n                        ))}\n                    </div>\n                    <div className=\"flex gap-4\">\n                        <button className=\"flex-1 bg-green-700 text-white py-3 px-4 rounded-md font-bold text-lg hover:bg-green-800\">\n                            RESUME\n                        </button>\n                        <button className=\"flex-1 bg-orange-500 text-white py-3 px-4 rounded-md font-bold text-lg hover:bg-orange-600\">\n                            HOLD\n                        </button>\n                        <button className=\"flex-1 bg-red-600 text-white py-3 px-4 rounded-md font-bold text-lg hover:bg-red-700\">\n                            ABORT\n                        </button>\n                    </div>\n                </div>\n            );\n        };\n\n        const Footer = () => {\n            return (\n                <footer className=\"bg-gray-100 py-4 px-6 border-t border-gray-200\">\n                    <div className=\"text-xs text-gray-500\">\n                        Recipe R-204 · Step 3 of 7 ACTIVE · Compliance: ANSI/ISA-101.01\n                    </div>\n                </footer>\n            );\n        };\n\n        ReactDOM.render(<App />, document.getElementById('root'));\n    </script>\n</body>\n</html>",
