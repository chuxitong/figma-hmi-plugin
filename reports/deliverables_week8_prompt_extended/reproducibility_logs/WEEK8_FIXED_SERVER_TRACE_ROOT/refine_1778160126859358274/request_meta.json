    "current_code": "<html>\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Tank Farm Synoptic</title>\n    <script src=\"https://cdn.jsdelivr.net/npm/react@18.0.0/umd/react.development.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/react-dom@18.0.0/umd/react-dom.development.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/@babel/standalone/babel.js\"></script>\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css\"></link>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap');\n        \n        body {\n            font-family: 'Roboto', sans-serif;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"root\"></div>\n\n    <script type=\"text/babel\">\n        function App() {\n            return (\n                <div className=\"min-h-screen bg-gray-50\">\n                    <Header />\n                    <main className=\"p-6 bg-gray-50\">\n                        <div className=\"bg-white rounded-lg border border-gray-200 p-6 mb-6\">\n                            <h2 className=\"text-lg font-semibold text-gray-800 mb-6\">Levels and connections</h2>\n                            <div className=\"grid grid-cols-5 gap-4\">\n                                <TankIndicator id=\"T-101\" percentage={72} status=\"OK\" color=\"green\" />\n                                <TankIndicator id=\"T-102\" percentage={41} status=\"OK\" color=\"green\" />\n                                <TankIndicator id=\"T-103\" percentage={88} status=\"WARN\" color=\"orange\" />\n                                <TankIndicator id=\"T-104\" percentage={12} status=\"ALARM\" color=\"red\" />\n                                <TankIndicator id=\"T-201\" percentage={64} status=\"OK\" color=\"green\" />\n                                <TankIndicator id=\"T-202\" percentage={95} status=\"ALARM\" color=\"red\" />\n                                <TankIndicator id=\"T-203\" percentage={33} status=\"OK\" color=\"green\" />\n                                <TankIndicator id=\"T-204\" percentage={58} status=\"OK\" color=\"green\" />\n                                <TankIndicator id=\"T-301\" percentage={47} status=\"OK\" color=\"green\" />\n                                <TankIndicator id=\"T-302\" percentage={22} status=\"WARN\" color=\"orange\" />\n                            </div>\n                        </div>\n                        <div className=\"bg-white rounded-lg border border-gray-200 p-6\">\n                            <h3 className=\"text-md font-semibold text-gray-800 mb-4\">Status legend</h3>\n                            <div className=\"flex items-center space-x-6\">\n                                <div className=\"flex items-center\">\n                                    <span className=\"bg-green-600 text-white px-4 py-0.5 text-sm rounded-sm mr-2\">OK</span>\n                                    <span className=\"text-sm text-gray-600\">в норме</span>\n                                </div>\n                                <div className=\"flex items-center\">\n                                    <span className=\"bg-orange-500 text-white px-4 py-0.5 text-sm rounded-sm mr-2\">WARN</span>\n                                    <span className=\"text-sm text-gray-600\">отключение, нужно вмешательство</span>\n                                </div>\n                                <div className=\"flex items-center\">\n                                    <span className=\"bg-red-600 text-white px-4 py-0.5 text-sm rounded-sm mr-2\">ALARM</span>\n                                    <span className=\"text-sm text-gray-600\">критическое отключение, требуется ACK</span>\n                                </div>\n                            </div>\n                            <p className=\"text-xs text-gray-500 mt-4\">\n                                Сообщение закодировано терما независимыми признаками: цвет state-fill, текстовая белёж state-badge, форма state-shape.\n                            </p>\n                        </div>\n                    </main>\n                    <footer className=\"bg-gray-100 py-3 px-6 border-t border-gray-200\">\n                        <div className=\"text-xs text-gray-500\">\n                            Connection: OK - Tanks online: 10/10 - Critical: 2 - Warning: 2\n                        </div>\n                    </footer>\n                </div>\n            );\n        }\n\n        function Header() {\n            return (\n                <header className=\"bg-slate-900 text-white py-3 px-6\">\n                    <div className=\"flex justify-between items-center\">\n                        <div>\n                            <h1 className=\"text-xl font-semibold\">Tank Farm Synoptic</h1>\n                            <p className=\"text-sm text-gray-300\">Facility 2 - Tank yard A - 10 tanks</p>\n                        </div>\n                        <div className=\"bg-slate-800 rounded-md px-4 py-2 text-sm text-gray-300\">\n                            2026-04-19 14:32:07 MSK\n                        </div>\n                    </div>\n                </header>\n            );\n        }\n\n        function TankIndicator({ id, percentage, status, color }) {\n            const getStatusColor = () => {\n                switch(status) {\n                    case 'OK': return 'bg-green-600';\n                    case 'WARN': return 'bg-orange-500';\n                    case 'ALARM': return 'bg-red-600';\n                    default: return 'bg-gray-500';\n                }\n            };\n\n            const getFillColor = () => {\n                switch(color) {\n                    case 'green': return 'bg-green-600';\n                    case 'orange': return 'bg-orange-500';\n                    case 'red': return 'bg-red-600';\n                    default: return 'bg-gray-500';\n                }\n            };\n\n            return (\n                <div className=\"flex flex-col items-center\">\n                    <div className=\"relative w-24 h-48\">\n                        <div className=\"absolute w-full h-full border-2 border-gray-400 rounded-sm bg-gray-100\"></div>\n                        <div \n                            className={`absolute bottom-0 w-full ${getFillColor()}`} \n                            style={{height: `${percentage}%`}}\n                        ></div>\n                        <div className=\"absolute top-1/2 w-16 h-0.5 bg-gray-400\" style={{left: '70%'}}></div>\n                        <div className=\"absolute top-1/2 transform -translate-y-1/2 text-xs text-gray-500\" style={{right: '0', textAlign: 'right'}}>\n                            {percentage}%\n                        </div>\n                    </div>\n                    <div className=\"mt-2 text-sm font-semibold text-gray-800\">{id}</div>\n                    <div className=\"mt-1\">\n                        <span className={`${getStatusColor()} text-white px-4 py-0.5 text-sm rounded-sm`}>\n                            {status}\n                        </span>\n                    </div>\n                </div>\n            );\n        }\n\n        ReactDOM.render(<App />, document.getElementById('root'));\n    </script>\n</body>\n</html>",
