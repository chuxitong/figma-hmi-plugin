                value=\"€ 1 932\" \n                                change=\"+78 за смену\" \n                                color=\"border-green-700\"\n                                textColor=\"text-green-600\"\n                            />\n                            <MetricCard \n                                title=\"Power factor\" \n                                value=\"0.92\" \n                                change=\"+0.01 за смену\" \n                                color=\"border-green-700\"\n                                textColor=\"text-green-600\"\n                            />\n                        </div>\n                        \n                        <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\n                            <ZoneConsumptionCard />\n                            <SourceBreakdownCard />\n                        </div>\n                    </div>\n                    <Footer />\n                </div>\n            );\n        }\n\n        function Header() {\n            return (\n                <header className=\"bg-[#0f3662] text-white py-4 px-6\">\n                    <div className=\"flex justify-between items-center\">\n                        <div>\n                            <h1 className=\"text-2xl font-bold\">Energy Monitoring Dashboard</h1>\n                            <p className=\"text-sm text-gray-300\">Industrial-2 · Day shift · All zones</p>\n                        </div>\n                        <div className=\"bg-gray-800 bg-opacity-30 px-4 py-2 rounded text-sm\">\n                            2026-04-19 14:32:07 MSK\n                        </div>\n                    </div>\n                </header>\n            );\n        }\n\n        function MetricCard({ title, value, change, color, textColor }) {\n            return (\n                <div className={`bg-white rounded p-4 border-l-4 ${color} shadow-sm`}>\n                    <div className=\"text-xs text-gray-500\">{title}</div>\n                    <div className=\"text-4xl font-bold text-gray-800 mt-1\">{value}</div>\n                    <div className=\"text-xs mt-2\">\n                        <span className={`${textColor}`}>▲</span> {change}\n                    </div>\n                </div>\n            );\n        }\n\n        function ZoneConsumptionCard() {\n            const zones = [\n                { name: 'Zone A', percentage: 62, status: 'OK', color: 'bg-green-700' },\n                { name: 'Zone B', percentage: 48, status: 'OK', color: 'bg-green-700' },\n                { name: 'Zone C', percentage: 81, status: 'WARN', color: 'bg-orange-500' },\n                { name: 'Zone D', percentage: 35, status: 'OK', color: 'bg-green-700' },\n                { name: 'Zone E', percentage: 90, status: 'ALARM', color: 'bg-red-600' },\n                { name: 'Zone F', percentage: 27, status: 'OK', color: 'bg-green-700' }\n            ];\n\n            return (\n                <div className=\"bg-white rounded border shadow-sm p-6\">\n                    <h2 className=\"text-gray-800 font-bold mb-6\">Power consumption by zone</h2>\n                    <div className=\"space-y-6\">\n                        {zones.map((zone, index) => (\n                            <div key={index} className=\"flex items-center\">\n                                <div className=\"w-24 text-sm font-medium text-gray-700\">{zone.name}</div>\n                                <div className=\"flex-grow mx-4 bg-gray-100 rounded h-6\">\n                                    <div \n                                        className={`${zone.color} h-6 rounded`}\n                                        style={{ width: `${zone.percentage}%` }}\n                                    ></div>\n                                </div>\n                                <div className=\"w-12 text-right text-sm text-gray-600\">{zone.percentage}%</div>\n                                <div className=\"ml-4\">\n                                    <span className={`px-3 py-1 rounded text-xs font-medium text-white ${\n                                        zone.status === 'OK' ? 'bg-green-700' : \n                                        zone.status === 'WARN' ? 'bg-orange-500' : \n                                        'bg-red-600'\n                                    }`}>\n                                        {zone.status}\n                                    </span>\n                                </div>\n                            </div>\n                        ))}\n                    </div>\n                </div>\n            );\n        }\n\n        function SourceBreakdownCard() {\n            return (\n                <div className=\"bg-white rounded border shadow-sm p-6\">\n                    <h2 className=\"text-gray-800 font-bold mb-6\">Source breakdown</h2>\n                    <div className=\"flex\">\n                        <div className=\"w-1/2\">\n                            <div className=\"relative w-64 h-64 mx-auto\">\n                                <div className=\"absolute inset-0 flex items-center justify-center\">\n                                    <div className=\"text-4xl font-bold text-gray-800\">100%</div>\n                                    <div className=\"text-sm text-gray-500 mt-2\">today</div>\n                                </div>\n                                <div className=\"w-full h-full rounded-full border-[30px]\" style={{\n                                    background: \"conic-gradient(#2e7d32 0% 57%, #ff9800 57% 82%, #1976d2 82% 100%)\"\n                                }}></div>\n                                <div className=\"absolute inset-0 flex items-center justify-center\">\n                                    <div className=\"w-[85%] h-[85%] rounded-full bg-white\"></div>\n                                </div>\n                            </div>\n                        </div>\n                        <div className=\"w-1/2 flex flex-col justify-center space-y-4\">\n                            <div className=\"flex items-center\">\n                                <div className=\"w-4 h-4 bg-green-700 mr-2\"></div>\n                                <span className=\"text-sm text-gray-700\">Электроэнергию · 57 %</span>\n                            </div>\n                            <div className=\"flex items-center\">\n                                <div className=\"w-4 h-4 bg-orange-500 mr-2\"></div>\n                                <span className=\"text-sm text-gray-700\">Газ · 25 %</span>\n                            </div>\n                            <div className=\"flex items-center\">\n                                <div className=\"w-4 h-4 bg-blue-500 mr-2\"></div>\n                                <span className=\"text-sm text-gray-700\">Утилизация тепла · 18 %</span>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            );\n        }\n\n        function Footer() {\n            return (\n                <footer className=\"py-4 px-6 text-xs text-gray-500 border-t\">\n                    Connection: OK · Tariff plan: Industrial-2 · Compliance: ANSI/ISA-101.01\n                </footer>\n            );\n        }\n\n        ReactDOM.render(<App />, document.getElementById('root'));\n    </script>\n</body>\n</html>",
