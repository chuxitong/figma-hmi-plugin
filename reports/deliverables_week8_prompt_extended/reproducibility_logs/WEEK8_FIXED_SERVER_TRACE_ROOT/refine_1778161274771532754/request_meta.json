ame=\"text-sm text-gray-300\">Process Gallery 2 - Tank yard A - 10 tanks</p>\n                                </div>\n                            </div>\n                            <div className=\"bg-slate-800 px-4 py-2 rounded text-sm text-gray-300\">\n                                2026-04-19 14:32:07 MSK\n                            </div>\n                        </div>\n                    </div>\n\n                    {/* Main Content */}\n                    <div className=\"p-6\">\n                        <div className=\"bg-white rounded-lg border border-gray-200 p-6\">\n                            <h2 className=\"text-lg font-semibold text-gray-800 mb-6\">Levels and connections</h2>\n                            \n                            {/* Tank Grid */}\n                            <div className=\"grid grid-cols-5 gap-8 mb-8\">\n                                {tanks.map((tank) => (\n                                    <TankStatus \n                                        key={tank.id}\n                                        tankId={tank.id}\n                                        percentage={tank.percentage}\n                                        status={tank.status}\n                                    />\n                                ))}\n                            </div>\n\n                            {/* Connection Line */}\n                            <div className=\"w-full h-4 bg-gray-400 rounded mb-8\"></div>\n\n                            {/* Status Legend */}\n                            <div className=\"border-t pt-6\">\n                                <h3 className=\"text-md font-semibold text-gray-800 mb-4\">Status legend</h3>\n                                <div className=\"flex items-center space-x-6 mb-4\">\n                                    <div className=\"flex items-center space-x-2\">\n                                        <div className=\"px-4 py-1 bg-green-700 text-white text-xs rounded\">OK</div>\n             