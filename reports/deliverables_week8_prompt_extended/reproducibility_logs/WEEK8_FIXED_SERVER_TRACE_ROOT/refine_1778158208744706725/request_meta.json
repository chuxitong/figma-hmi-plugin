 className=\"px-6 py-1 rounded-full bg-blue-900 text-white text-sm\">Overview</button>\n                                <button className=\"px-6 py-1 rounded-full text-gray-300 hover:bg-blue-800 text-sm\">Alarms</button>\n                                <button className=\"px-6 py-1 rounded-full text-gray-300 hover:bg-blue-800 text-sm\">Tends</button>\n                                <button className=\"px-6 py-1 rounded-full text-gray-300 hover:bg-blue-800 text-sm\">Operator</button>\n                            </nav>\n                            <div className=\"bg-[#1e3a7a] text-gray-300 px-4 py-2 rounded text-sm\">\n                                2026-04-19 14:32:07 MSK\n                            </div>\n                        </div>\n                    </div>\n                </header>\n            );\n        };\n\n        const ProcessFlow = () => {\n            return (\n                <div className=\"bg-white rounded-lg border border-gray-200 p-6\">\n                    <div className=\"mb-4\">\n                        <h2 className=\"text-gray-900 font-semibold text-lg\">Process flow — Line A</h2>\n                        <p className=\"text-gray-500 text-sm mt-1\">Source: ThingsBoard SCADA symbol library — fluid system pack</p>\n                    </div>\n                    \n                    <div className=\"h-64 relative\">\n                        {/* Process Flow Diagram */}\n                        <div className=\"flex items-center justify-between h-full\">\n                            {/* T-101 Tank */}\n                            <div className=\"flex flex-col items-center\">\n                                <div className=\"w-16 h-24 border-2 border-gray-400 rounded-t-lg relative\">\n                                    <div className=\"absolute bottom-0 w-full h-1/3 bg-green-600\"></div>\n                                    <div className=\"absolute top-1/3 w-full h-1/3 bg-gray-300\"></div>\n                                </div>\n                                <span className=\"mt-2 text-xs text-gray-600\">T-101</span>\n                            </div>\n                            \n                            {/* P-101 Pump */}\n                            <div className=\"flex items-center\">\n                                <div className=\"w-12 h-12 border-2 border-gray-400 rounded-full flex items-center justify-center\">\n                                    <div className=\"w-6 h-6 bg-green-600 rounded-full\"></div>\n                                </div>\n                            </div>\n                            \n                            {/* V-201 Valve */}\n                            <div className=\"flex items-center\">\n                                <div className=\"w-8 h-8 border-2 border-gray-400 transform rotate-45 flex items-center justify-center\">\n                                    <div className=\"w-3 h-3 bg-green-600 rounded-full transform -rotate-45\"></div>\n                                </div>\n                            </div>\n                            \n                            {/* P-102 */}\n                            <div className=\"flex items-center\">\n                                <div className=\"w-12 h-12 border-2 border-gray-400 rounded-full flex items-center justify-center\">\n                                    <div className=\"w-6 h-6 bg-orange-500 rounded-full\"></div>\n                                </div>\n                            </div>\n                            \n                            {/* V-202 Valve */}\n                            <div className=\"flex items-center\">\n                                <div className=\"w-8 h-8 border-2 border-gray-400 transform rotate-45 flex items-center justify-center\">\n                                    <div className=\"w-3 h-3 bg-red-600 rounded-full transform -rotate-45\"></div>\n                                </div>\n                            </div>\n                            \n                            {/* Separator */}\n                            <div className=\"relative\">\n                                <div className=\"w-28 h-16 bg-gray-300 rounded-full border-2 border-gray-400\">\n                                    <div className=\"absolute bottom-0 w-full h-1/4 bg-green-600 rounded-b-full\"></div>\n                                </div>\n                                <span className=\"absolute -bottom-6 w-full text-center text-xs text-gray-600\">SEPARATOR S-1</span>\n                            </div>\n                            \n                            {/* T-102 */}\n                            <div className=\"flex flex-col items-center\">\n                                <div className=\"w-16 h-24 border-2 border-gray-400 rounded-t-lg relative\">\n                                    <div className=\"absolute bottom-0 w-full h-1/4 bg-green-600\"></div>\n                                    <div className=\"absolute top-1/4 w-full h-1/2 bg-gray-300\"></div>\n                                </div>\n                                <span className=\"mt-2 text-xs text-gray-600\">T-102</span>\n                            </div>\n                        </div>\n                        \n                        {/* Connecting pipes */}\n                        <div className=\"absolute top-1/2 w-full flex justify-between\">\n                            <div className=\"h-2 w-12 bg-gray-400 rounded-full\"></div>\n                            <div className=\"h-2 w-8 bg-gray-400 rounded-full\"></div>\n                            <div className=\"h-2 w-8 bg-gray-400 rounded-full\"></div>\n                            <div className=\"h-2 w-12 bg-gray-400 rounded-full\"></div>\n                            <div className=\"h-2 w-8 bg-gray-400 rounded-full\"></div>\n                            <div className=\"h-2 w-12 bg-gray-400 rounded-full\"></div>\n                            <div className=\"h-2 w-8 bg-gray-400 rounded-full\"></div>\n                        </div>\n                    </div>\n                    \n                    {/* Temperature Indicators */}\n                    <div className=\"flex justify-around mt-8\">\n                        <div className=\"flex flex-col items-center\">\n                            <div className=\"w-10 h-10 rounded-full border-2 border-gray-400 flex items-center justify-center\">\n                                <span className=\"text-green-600 font-bold\">T</span>\n                            </div>\n                            <span className=\"mt-2 text-xs text-gray-600\">72 °C</span>\n                        </div>\n                        <div className=\"flex flex-col items-center\">\n                            <div className=\"w-10 h-10 rounded-full border-2 border-gray-400 flex items-center justify-center\">\n                                <span className=\"text-green-600 font-bold\">T</span>\n                            </div>\n                            <span className=\"mt-2 text-xs text-gray-600\">3.4 bar</span>\n                        </div>\n                        <div className=\"flex flex-col items-center\">\n                            <div className=\"w-10 h-10 rounded-full border-2 border-gray-400 flex items-center justify-center\">\n                                <span className=\"text-red-600 font-bold\">T</span>\n                            </div>\n                            <span className=\"mt-2 text-xs text-gray-600\">94 °C</span>\n                        </div>\n                    </div>\n                </div>\n            );\n        };\n\n        const KpiCard = ({ title, value, change, changeColor, borderColor }) => {\n            return (\n                <div className={`border-l-4 ${borderColor} bg-white rounded-lg p-4`}>\n                    <div className=\"text-gray-600 text-sm\">{title}</div>\n                    <div className=\"text-3xl font-bold text-gray-900 mt-1\">{value}</div>\n                    <div className={`text-xs mt-2 ${changeColor}`}>\n                        <i className=\"fas fa-caret-up mr-1\"></i>\n                        {change}\n                    </div>\n                </div>\n            );\n        };\n\n        const TrendChart = () => {\n            return (\n                <div className=\"bg-white rounded-lg border border-gray-200 p-4\">\n                    <div className=\"flex justify-between items-center mb-4\">\n                        <h3 className=\"text-gray-900 font-semibold\">Real-time trend — last 60 min</h3>\n                        <div className=\"flex items-center space-x-4 text-xs\">\n                            <div className=\"flex items-center\">\n                                <div className=\"w-3 h-2 bg-green-700 mr-1\"></div>\n                                <span>Temp</span>\n                            </div>\n                            <div className=\"flex items-center\">\n                                <div className=\"w-3 h-2 bg-orange-500 mr-1\"></div>\n                                <span>Pressure</span>\n                            </div>\n                            <div className=\"flex items-center\">\n                                <div className=\"w-3 h-2 bg-red-700 mr-1\"></div>\n                                <span>Flow</span>\n                            </div>\n                        </div>\n                    </div>\n                    <div className=\"h-24 w-full border-b border-l border-gray-200 relative\">\n                        {/* Chart lines would be drawn here with SVG in a real implementation */}\n                        <svg className=\"w-full h-full\" viewBox=\"0 0 400 100\">\n                            <path d=\"M0,70 C50,65 100,60 150,40 C200,30 250,50 300,45 C350,60 400,50\" \n                                  stroke=\"#166534\" fill=\"none\" strokeWidth=\"2\"/>\n                            <path d=\"M0,80 C50,75 100,70 150,65 C200,65 250,64 300,60 C350,55 400,50\" \n                                  stroke=\"#F59E0B\" fill=\"none\" strokeWidth=\"2\"/>\n                            <path d=\"M0,90 C50,88 100,85 150,86 C200,88 250,90 300,85 C350,82 400,75\" \n                                  stroke=\"#DC2626\" fill=\"none\" strokeWidth=\"2\"/>\n                        </svg>\n                    </div>\n                </div>\n            );\n        };\n\n        const AlarmList = () => {\n            const alarms = [\n                {\n                    time: \"14:31\",\n                    id: \"TT-301\",\n                    description: \"Motor temperature high\",\n                    type: \"ALARM\",\n                    color: \"red\"\n                },\n                {\n                    time: \"14:28\",\n                    id: \"PT-102\",\n                    description: \"Discharge pressure\",\n                    type: \"ALARM\",\n                    color: \"red\"\n                },\n                {\n                    time: \"14:22\",\n                    id: \"FT-401\",\n                    description: \"Flow rate deviation\",\n                    type: \"WARN\",\n                    color: \"orange\"\n                },\n                {\n                    time: \"14:15\",\n                    id: \"CT-502\",\n                    description: \"Cooling water temp\",\n                    type: \"WARN\",\n                    color: \"orange\"\n                },\n                {\n                    time: \"14:05\",\n                    id: \"PDT-201\",\n                    description: \"Filter ΔP\",\n                    type: \"INFO\",\n                    color: \"blue\"\n                }\n            ];\n\n            return (\n                <div className=\"bg-white rounded-lg border border-gray-200 p-4\">\n                    <div className=\"flex justify-between items-center mb-4\">\n                        <h3 className=\"text-gray-900 font-semibold\">Active alarms</h3>\n                        <span className=\"text-xs text-gray-500\">3 of 14</span>\n                    </div>\n                    <div className=\"space-y-3\">\n                        {alarms.map((alarm, index) => (\n                            <AlarmItem key={index} alarm={alarm} />\n                        ))}\n                    </div>\n                </div>\n            );\n        };\n\n        const AlarmItem = ({ alarm }) => {\n            return (\n                <div className=\"border border-gray-300 rounded-lg p-3\">\n                    <div className=\"flex justify-between items-center\">\n                        <div className=\"flex items-center space-x-4\">\n                            <span className=\"text-xs text-gray-500\">{alarm.time}</span>\n                            <span className=\"text-xs text-gray-700\">{alarm.id}</span>\n                        </div>\n                    </div>\n                    <div className=\"mt-1\">\n                        <span className=\"text-sm text-gray-700\">{alarm.description}</span>\n                    </div>\n                    <div className=\"flex justify-between items-center mt-2\">\n                        <div className={`text-xs px-2 py-0.5 rounded ${\n                            alarm.type === 'ALARM' ? 'bg-red-600 text-white' : \n                            alarm.type === 'WARN' ? 'bg-orange-500 text-white' : \n                            'bg-blue-600 text-white'\n                        }`}>\n                            {alarm.type}\n                        </div>\n                        <button className=\"px-6 py-1 border border-gray-400 rounded text-sm font-medium hover:bg-gray-50\">\n                            ACK\n                        </button>\n                    </div>\n                </div>\n            );\n        };\n\n        const Footer = () => {\n            return (\n                <footer className=\"p-4 text-xs text-gray-500 border-t\">\n                   