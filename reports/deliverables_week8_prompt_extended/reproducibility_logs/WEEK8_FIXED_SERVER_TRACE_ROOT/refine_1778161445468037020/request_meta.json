iv>\n                    <div className=\"text-xs text-gray-500 mt-2\">\n                        <span className=\"text-green-600\">▲</span> {change}\n                    </div>\n                </div>\n            );\n        };\n\n        const ZoneConsumptionCard = () => {\n            const zones = [\n                { name: 'Zone A', percentage: 62, status: 'OK', color: 'bg-green-700' },\n                { name: 'Zone B', percentage: 48, status: 'OK', color: 'bg-green-700' },\n                { name: 'Zone C', percentage: 81, status: 'WARN', color: 'bg-orange-500' },\n                { name: 'Zone D', percentage: 35, status: 'OK', color: 'bg-green-700' },\n                { name: 'Zone E', percentage: 90, status: 'ALARM', color: 'bg-red-600' },\n                { name: 'Zone F', percentage: 27, status: 'OK', color: 'bg-green-700' },\n            ];\n\n            return (\n                <div className=\"bg-white rounded-md border p-4 shadow-sm\">\n                    <h2 className=\"text-gray-800 font-bold mb-4\">Power consumption by zone</h2>\n                    <div className=\"space-y-6\">\n                        {zones.map((zone, index) => (\n                            <div key={index} className=\"flex items-center\">\n                                <div className=\"w-16 text-sm font-medium text-gray-700\">{zone.name}</div>\n                                <div className=\"flex-grow mx-4 bg-gray-100 rounded-full h-6\">\n                                    <div \n                                        className={`${zone.color} h-6 rounded-full`} \n                                        style={{ width: `${zone.percentage}%` }}\n                                    ></div>\n                                </div>\n                                <div className=\"w-16 text-right text-gray-600\">{zone.percentage}%</div>\n                                <div className=\"ml-4\">\n                                    <span className={`px-4 py-1 rounded text-xs font-semibold ${\n                                        zone.status === 'OK' ? 'bg-green-700 text-white' : \n                                        zone.status === 'WARN' ? 'bg-orange-500 text-white' : \n                                        'bg-red-600 text-white'\n                                    }`}>\n                                        {zone.status}\n                                    </span>\n                                </div>\n                            </div>\n                        ))}\n                    </div>\n                </div>\n            );\n        };\n\n        const SourceBreakdownCard = () => {\n            return (\n                <div className=\"bg-white rounded-md border p-4 shadow-sm\">\n                    <h2 className=\"text-gray-800 font-bold mb-4\">Source breakdown</h2>\n                    <div className=\"flex items-center justify-center\">\n                        <div className=\"relative w-64 h-64\">\n                            {/* This is a simplified donut chart representation */}\n                            <div className=\"absolute inset-0 flex items-center justify-center\">\n                                <div className=\"text-3xl font-bold text-gray-800\">100%</div>\n                                <div className=\"text-sm text-gray-500 mt-2\">today</div>\n                            </div>\n                            <div className=\"w-full h-full rounded-full border-[25px] border-green-700\" style={{\n                                background: `conic-gradient(\n                                    #2e7d32 0% 57%, \n                                    #ff9800 57% 82%, \n                                    #1976d2 82% 100%\n                                )`\n                            }}></div>\n                            <div className=\"absolute inset-0 flex items-center justify-center\">\n                                <div className=\"w-[90%] h-[90%] rounded-full bg-white\"></div>\n                            </div>\n                        </div>\n                        <div className=\"ml-8 space-y-2\">\n                            <div className=\"flex items-center\">\n                                <div className=\"w-4 h-4 bg-green-700 mr-2\"></div>\n                                <span className=\"text-sm text-gray-700\">Электроэнергию · 57 %</span>\n                            </div>\n                            <div className=\"flex items-center\">\n                                <div className=\"w-4 h-4 bg-orange-500 mr-2\"></div>\n                                <span className=\"text-sm text-gray-700\">Газ · 25 %</span>\n                            </div>\n                            <div className=\"flex items-center\">\n                                <div className=\"w-4 h-4 bg-blue-500 mr-2\"></div>\n                                <span className=\"text-sm text-gray-700\">Утилизация тепла · 18 %</span>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            );\n        };\n\n        const Footer = () => {\n            return (\n                <footer className=\"bg-gray-100 py-3 px-6 text-xs text-gray-500 border-t\">\n                    Connection: OK · Tariff plan: Industrial-2 · Compliance: ANSI/ISA-101.01\n                </footer>\n            );\n        };\n\n        ReactDOM.render(<App />, document.getElementById('root'));\n    </script>\n</body>\n</html>",
