    "current_code": "<html>\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Batch Recipe Management</title>\n    <script src=\"https://cdn.jsdelivr.net/npm/react@18.0.0/umd/react.development.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/react-dom@18.0.0/umd/react-dom.development.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/@babel/standalone/babel.js\"></script>\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css\"></link>\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap');\n        \n        body {\n            font-family: 'Roboto', sans-serif;\n            background-color: #f1f5f9;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"root\"></div>\n\n    <script type=\"text/babel\">\n        const App = () => {\n            return (\n                <div className=\"min-h-screen flex flex-col\">\n                    <Header />\n                    <main className=\"flex-grow p-6 bg-[#f3f5f8]\">\n                        <div className=\"flex gap-6\">\n                            <div className=\"w-2/3 bg-white rounded-lg border border-gray-300 p-6\">\n                                <StepsTable />\n                            </div>\n                            <div className=\"w-1/3\">\n                                <LiveParameters />\n                            </div>\n                        </div>\n                    </main>\n                    <Footer />\n                </div>\n            );\n        };\n\n        const Header = () => {\n            return (\n                <header className=\"bg-[#13314f] text-white py-4 px-6\">\n                    <div className=\"flex justify-between items-center\">\n                        <div className=\"flex items-center space-x-2\">\n                            <div className=\"bg-[#45a29e] rounded-full p-2\">\n                                <i className=\"fas fa-cog text-white\"></i>\n                            </div>\n                            <div>\n                                <h1 className=\"text-2xl font-semibold\">Batch Recipe Management</h1>\n                                <p className=\"text-sm text-gray-300\">Recipe: R-204 · Lot 2026-017 · Batch operator: A. Petrov</p>\n                            </div>\n                        </div>\n                        <div className=\"bg-[#1c4587] px-4 py-2 rounded-md text-sm\">\n                            2026-04-19 14:32:07 MSK\n                        </div>\n                    </div>\n                </header>\n            );\n        };\n\n        const StepsTable = () => {\n            const steps = [\n                { id: 1, step: 'Pre-heat', duration: '10 min', status: 'DONE' },\n                { id: 2, step: 'Fill base', duration: '8 min', status: 'DONE' },\n                { id: 3, step: 'Mix', duration: '15 min', status: 'ACTIVE' },\n                { id: 4, step: 'Add catalyst', duration: '4 min', status: 'PENDING' },\n                { id: 5, step: 'Hold', duration: '20 min', status: 'PENDING' },\n                { id: 6, step: 'Cool down', duration: '12 min', status: 'PENDING' },\n                { id: 7, step: 'Discharge', duration: '6 min', status: 'PENDING' }\n            ];\n\n            return (\n                <div>\n                    <h2 className=\"text-lg font-semibold text-gray-800 mb-4\">Steps</h2>\n                    <div className=\"overflow-x-auto\">\n                        <table className=\"w-full border-collapse\">\n                            <thead>\n                                <tr className=\"bg-gray-100\">\n                                    <th className=\"text-left py-2 px-4 text-sm text-gray-600 border-b\">#</th>\n                                    <th className=\"text-left py-2 px-4 text-sm text-gray-600 border-b\">Step</th>\n                                    <th className=\"text-left py-2 px-4 text-sm text-gray-600 border-b\">Duration</th>\n                                    <th className=\"text-left py-2 px-4 text-sm text-gray-600 border-b\">Status</th>\n                                    <th className=\"text-left py-2 px-4 text-sm text-gray-600 border-b\">Action</th>\n                                </tr>\n                            </thead>\n                            <tbody>\n                                {steps.map((step) => (\n                                    <StepRow key={step.id} step={step} />\n                                ))}\n                            </tbody>\n                        </table>\n                    </div>\n                </div>\n            );\n        };\n\n        const StepRow = ({ step }) => {\n            const getStatusClass = () => {\n                switch (step.status) {\n                    case 'DONE':\n                        return 'bg-[#2e7d32] text-white';\n                    case 'ACTIVE':\n                        return 'bg-[#1976d2] text-white';\n                    case 'PENDING':\n                        return 'bg-[#4e5b70] text-white';\n                    default:\n                        return 'bg-gray-500 text-white';\n                }\n            };\n\n            return (\n                <tr className=\"border-b hover:bg-gray-50\">\n                    <td className=\"py-3 px-4 text-gray-800\">{step.id}</td>\n                    <td className=\"py-3 px-4 text-gray-800 font-medium\">{step.step}</td>\n                    <td className=\"py-3 px-4 text-gray-800\">{step.duration}</td>\n                    <td className=\"py-3 px-4\">\n                        <span className={`px-6 py-1 rounded text-xs font-medium ${getStatusClass()}`}>\n                            {step.status}\n                        </span>\n                    </td>\n                    <td className=\"py-3 px-4\">\n                        <button className=\"border border-gray-400 rounded px-4 py-1 text-gray-800 hover:bg-gray-100 text-sm font-medium\">\n                            View\n                        </button>\n                    </td>\n                </tr>\n            );\n        };\n\n        const LiveParameters = () => {\n            return (\n                <div className=\"space-y-6\">\n                    <div className=\"bg-white rounded-lg border border-gray-300 p-6\">\n                        <h2 className=\"text-lg font-semibold text-gray-800 mb-4\">Live parameters</h2>\n                        <div className=\"grid grid-cols-2 gap-4\">\n                            <div className=\"bg-white rounded-lg border border-gray-300 p-4\">\n                                <div className=\"text-sm text-gray-500 mb-1\">Temperature</div>\n                                <div className=\"flex items-end\">\n                                    <span className=\"text-4xl font-medium text-gray-800\">65.4</span>\n                                    <span className=\"text-2xl text-gray-600 ml-2\">°C</span>\n                                </div>\n                                <div className=\"mt-2\">\n                                    <span className=\"bg-[#2e7d32] text-white text-xs px-4 py-0.5 rounded\">OK</span>\n                                </div>\n                            </div>\n                            \n                            <div className=\"bg-white rounded-lg border border-gray-300 p-4\">\n                                <div className=\"text-sm text-gray-500 mb-1\">pH</div>\n                                <div className=\"text-4xl font-medium text-gray-800\">7.1</div>\n                                <div className=\"mt-2\">\n                                    <span className=\"bg-[#2e7d32] text-white text-xs px-4 py-0.5 rounded\">OK</span>\n                                </div>\n                            </div>\n                            \n                            <div className=\"bg-white rounded-lg border border-gray-300 p-4\">\n                                <div className=\"text-sm text-gray-500 mb-1\">RPM</div>\n                                <div className=\"text-4xl font-medium text-gray-800\">240</div>\n                                <div className=\"mt-2\">\n                                    <span className=\"bg-[#2e7d32] text-white text-xs px-4 py-0.5 rounded\">OK</span>\n                                </div>\n                            </div>\n                            \n                            <div className=\"bg-white rounded-lg border border-gray-300 p-4\">\n                                <div className=\"text-sm text-gray-500 mb-1\">Pressure</div>\n                                <div className=\"flex items-end\">\n                                    <span className=\"text-4xl font-medium text-gray-800\">1.18</span>\n                                    <span className=\"text-2xl text-gray-600 ml-2\">bar</span>\n                                </div>\n                                <div className=\"mt-2\">\n                                    <span className=\"bg-[#e65100] text-white text-xs px-4 py-0.5 rounded\">WARN</span>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                    \n                    <div className=\"bg-white rounded-lg border border-gray-300 p-6\">\n                        <h2 className=\"text-lg font-semibold text-gray-800 mb-4\">Timeline</h2>\n                        <div className=\"flex justify-between items-center mb-8\">\n                            <div className=\"flex items-center\">\n                                <div className=\"bg-green-700 text-white rounded-full w-8 h-8 flex items-center justify-center text-sm\">\n                                    1\n                                </div>\n                                <span className=\"ml-2 text-xs text-gray-500\">10m</span>\n                            </div>\n                            <div className=\"flex items-center\">\n                                <div className=\"bg-green-700 text-white rounded-full w-8 h-8 flex items-center justify-center text-sm\">\n                                    2\n                                </div>\n                                <span className=\"ml-2 text-xs text-gray-500\">8m</span>\n                            </div>\n                            <div className=\"flex items-center\">\n                                <div className=\"bg-blue-600 text-white rounded-full w-8 h-8 flex items-center justify-center text-sm\">\n                                    3\n                                </div>\n                                <span className=\"ml-2 text-xs text-gray-500\">15m</span>\n                            </div>\n                            <div className=\"flex items-center\">\n                                <div className=\"bg-gray-500 text-white rounded-full w-8 h-8 flex items-center justify-center text-sm\">\n                                    4\n                                </div>\n                                <span className=\"ml-2 text-xs text-gray-500\">4m</span>\n                            </div>\n                            <div className=\"flex items-center\">\n                                <div className=\"bg-gray-500 text-white rounded-full w-8 h-8 flex items-center justify-center text-sm\">\n                                    5\n                                </div>\n                                <span className=\"ml-2 text-xs text-gray-500\">20m</span>\n                            </div>\n                            <div className=\"flex items-center\">\n                                <div className=\"bg-gray-500 text-white rounded-full w-8 h-8 flex items-center justify-center text-sm\">\n                                    6\n                                </div>\n                                <span className=\"ml-2 text-xs text-gray-500\">12m</span>\n                            </div>\n                            <div className=\"flex items-center\">\n                                <div className=\"bg-gray-500 text-white rounded-full w-8 h-8 flex items-center justify-center text-sm\">\n                                    7\n                                </div>\n                                <span className=\"ml-2 text-xs text-gray-500\">6m</span>\n                            </div>\n                        </div>\n                        \n                        <div className=\"flex space-x-2 mt-12\">\n                            <button className=\"bg-[#2e7d32] text-white px-8 py-3 rounded-md text-lg font-bold hover:bg-[#1b5e20]\">\n                                RESUME\n                            </button>\n                            <button className=\"bg-[#e65100] text-white px-8 py-3 rounded-md text-lg font-bold hover:bg-[#c62828]\">\n                                HOLD\n                            </button>\n                            <button className=\"bg-[#dc3545] text-white px-8 py-3 rounded-md text-lg font-bold hover:bg-[#cc2929]\">\n                                ABORT\n                            </button>\n                        </div>\n                    </div>\n                </div>\n            );\n        };\n\n        const Footer = () => {\n            return (\n                <footer className=\"bg-gray-100 py-3 px-6 border-t\">\n                    <div className=\"text-xs text-gray-500\">\n                        Recipe R-204 · Step 3 of 7 ACTIVE · Compliance: ANSI/ISA-101.01\n                    </div>\n                </footer>\n            );\n        };\n\n        ReactDOM.render(<App />, document.getElementById('root'));\n    </script>\n</body>\n</html>",
