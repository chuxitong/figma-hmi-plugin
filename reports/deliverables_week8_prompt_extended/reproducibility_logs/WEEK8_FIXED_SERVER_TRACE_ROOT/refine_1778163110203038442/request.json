    "current_code": "<html>\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Energy Monitoring Dashboard</title>\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/react@18.0.0/umd/react.development.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/react-dom@18.0.0/umd/react-dom.development.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/@babel/standalone/babel.js\"></script>\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css\">\n    <style>\n        body {\n            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"root\"></div>\n\n    <script type=\"text/babel\">\n        const MetricCard = ({ title, value, change, color = \"green\", icon = \"triangle-up\" }) => {\n            return (\n                <div className=\"bg-white rounded-lg border-l-4 border-\" style={{borderLeftColor: color === \"green\" ? \"#2e7d32\" : \"#f57c00\"}}>\n                    <div className=\"p-4\">\n                        <div className=\"text-xs text-gray-500 mb-1\">{title}</div>\n                        <div className=\"text-3xl font-bold text-gray-800 mb-2\">{value}</div>\n                        <div className=\"text-xs text-gray-500\">\n                            <span className=\"text-green-600\">▲ {change}</span>\n                        </div>\n                    </div>\n                </div>\n            );\n        };\n\n        const ZoneRow = ({ zone, percentage, status }) => {\n            const getStatusColor = () => {\n                switch (status.toLowerCase()) {\n                    case 'ok': return 'bg-green-600';\n                    case 'warn': return 'bg-orange-500';\n                    case 'alarm': return 'bg-red-600';\n                    default: return 'bg-green-600';\n                }\n            };\n\n            return (\n                <div className=\"flex items-center justify-between py-2\">\n                    <div className=\"w-16 text-sm font-medium text-gray-700\">{zone}</div>\n                    <div className=\"flex-1 mx-4\">\n                        <div className=\"w-full bg-gray-100 rounded-full h-6\">\n                            <div \n                                className=\"h-6 rounded-full bg-green-600\" \n                                style={{width: `${percentage}%`}}\n                            ></div>\n                        </div>\n                    </div>\n                    <div className=\"w-12 text-right\">\n                        <span className=\"text-sm text-gray-600\">{percentage}%</span>\n                    </div>\n                    <div className=\"ml-4 w-16\">\n                        <span className={`px-3 py-1 rounded text-xs text-white ${getStatusColor()}`}>\n                            {status.toUpperCase()}\n                        </span>\n                    </div>\n                </div>\n            );\n        };\n\n        const App = () => {\n            const zoneData = [\n                { zone: 'Zone A', percentage: 62, status: 'ok' },\n                { zone: 'Zone B', percentage: 48, status: 'ok' },\n                { zone: 'Zone C', percentage: 81, status: 'warn' },\n                { zone: 'Zone D', percentage: 35, status: 'ok' },\n                { zone: 'Zone E', percentage: 90, status: 'alarm' },\n                { zone: 'Zone F', percentage: 27, status: 'ok' }\n            ];\n\n            return (\n                <div className=\"min-h-screen bg-gray-50\">\n                    {/* Header */}\n                    <div className=\"bg-slate-800 text-white px-6 py-4\">\n                        <div className=\"flex justify-between items-center\">\n                            <div>\n                                <h1 className=\"text-2xl font-bold\">Energy Monitoring Dashboard</h1>\n                                <p className=\"text-sm text-slate-300 mt-1\">Industrial-2 - Day shift - All zones</p>\n                            </div>\n                            <div className=\"bg-slate-700 rounded-md px-4 py-2 text-sm text-slate-300\">\n                                2026-04-19 14:32:07 MSK\n                            </div>\n                        </div>\n                    </div>\n\n                    {/* Metrics Cards */}\n                    <div className=\"p-6 bg-gray-50\">\n                        <div className=\"grid grid-cols-4 gap-6 mb-6\">\n                            <div>\n                                <div className=\"bg-white rounded-lg border-l-4 border-green-600 p-4\">\n                                    <div className=\"text-xs text-gray-500 mb-1\">Total kWh</div>\n                                    <div className=\"text-3xl font-bold text-gray-800 mb-2\">12 845</div>\n                                    <div className=\"text-xs text-gray-500\">\n                                        <span className=\"text-green-600\">▲ +340 за смену</span>\n                                    </div>\n                                </div>\n                            </div>\n                            \n                            <div>\n                                <div className=\"bg-white rounded-lg border-l-4 border-orange-500 p-4\">\n                                    <div className=\"text-xs text-gray-500 mb-1\">Peak load</div>\n                                    <div className=\"text-3xl font-bold text-gray-800 mb-2\">742</div>\n                                    <div className=\"text-xs text-gray-500\">\n                                        <span className=\"text-orange-600\">▲ +18 за смену</span>\n                                    </div>\n                                </div>\n                            </div>\n                            \n                            <div>\n                                <div className=\"bg-white rounded-lg border-l-4 border-orange-500 p-4\">\n                                    <div className=\"text-xs text-gray-500 mb-1\">Cost (today)</div>\n                                    <div className=\"text-3xl font-bold text-gray-800 mb-2\">€ 1 932</div>\n                                    <div className=\"text-xs text-gray-500\">\n                                        <span className=\"text-orange-600\">▲ +78 за смену</span>\n                                    </div>\n                                </div>\n                            </div>\n                            \n                            <div>\n                                <div className=\"bg-white rounded-lg border-l-4 border-green-600 p-4\">\n                                    <div className=\"text-xs text-gray-500 mb-1\">Power factor</div>\n                                    <div className=\"text-3xl font-bold text-gray-800 mb-2\">0.92</div>\n                                    <div className=\"text-xs text-gray-500\">\n                                        <span className=\"text-green-600\">▲ +0.01 за смену</span>\n                                    </div>\n                                </div>\n                            </div>\n                        </div>\n\n                        {/* Main Content Grid */}\n                        <div className=\"grid grid-cols-2 gap-6\">\n                            {/* Power Consumption by Zone */}\n                            <div className=\"bg-white rounded-lg border border-gray-200 p-6\">\n                                <h2 className=\"text-lg font-semibold text-gray-800 mb-6\">Power consumption by zone</h2>\n                                \n                                {zoneData.map((item, index) => (\n                                    <ZoneRow \n                                        key={index}\n                                        zone={item.zone}\n                                        percentage={item.percentage}\n                                        status={item.status}\n                                    />\n                                ))}\n                            </div>\n\n                            {/* Source Breakdown */}\n                            <div className=\"bg-white rounded-lg border border-gray-200 p-6\">\n                                <h2 className=\"text-lg font-semibold text-gray-800 mb-6\">Source breakdown</h2>\n                                \n                                <div className=\"flex items-center justify-center\">\n                                    <div className=\"relative w-64 h-64\">\n                                        {/* Donut chart would go here - using border-radius to create pie segments */}\n                                        <div className=\"absolute inset-0 rounded-full overflow-hidden\">\n                                            <div style={{\n                                                position: 'absolute',\n                                                width: '100%',\n                                                height: '100%',\n                                                background: 'conic-gradient(#2e7d32 0% 57%, #1976d2 57% 82%, #ff9800 82% 100%)',\n                                                clipPath: 'circle(50% at center)'\n                                            }}></div>\n                                            <div style={{\n                                                position: 'absolute',\n                                                width: '80%',\n                                                height: '80%',\n                                                left: '10%',\n                                                top: '10%',\n                                                background: 'white',\n                                                borderRadius: '50%'\n                                            }}></div>\n                                        </div>\n                                        \n                                        <div className=\"absolute inset-0 flex items-center justify-center flex-col\">\n                                            <div className=\"text-4xl font-bold text-gray-800\">100%</div>\n                                            <div className=\"text-sm text-gray-500 mt-1\">today</div>\n                                        </div>\n                                    </div>\n                                </div>\n                                \n                                <div className=\"mt-8 grid grid-cols-1 gap-2\">\n                                    <div className=\"flex items-center\">\n                                        <div className=\"w-4 h-4 bg-green-700 mr-2\"></div>\n                                        <span className=\"text-sm text-gray-700\">Электроэнергия · 57 %</span>\n                                    </div>\n                                    <div className=\"flex items-center\">\n                                        <div className=\"w-4 h-4 bg-orange-500 mr-2\"></div>\n                                        <span className=\"text-sm text-gray-700\">Газ · 25 %</span>\n                                    </div>\n                                    <div className=\"flex items-center\">\n                                        <div className=\"w-4 h-4 bg-blue-500 mr-2\"></div>\n                                        <span className=\"text-sm text-gray-700\">Утилизация тепла · 18 %</span>\n                                    </div>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n\n                    {/* Footer */}\n                    <div className=\"bg-gray-100 border-t border-gray-200 py-4 px-6\">\n                        <div className=\"text-xs text-gray-500\">\n                            Connection: OK · Tariff plan: Industrial-2 · Compliance: ANSI/ISA-101.01\n                        </div>\n                    </div>\n                </div>\n            );\n        };\n\n        ReactDOM.render(<App />, document.getElementById('root'));\n    </script>\n</body>\n</html>",
