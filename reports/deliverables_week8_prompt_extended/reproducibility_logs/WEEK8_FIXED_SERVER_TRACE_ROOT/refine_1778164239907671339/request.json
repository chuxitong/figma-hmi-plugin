    "current_code": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Batch Recipe Management</title>\n    <script src=\"https://cdn.jsdelivr.net/npm/react@18.0.0/umd/react.development.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/react-dom@18.0.0/umd/react-dom.development.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/@babel/standalone/babel.js\"></script>\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css\">\n    <style>\n        body {\n            background-color: #f3f5f8;\n            font-family: Arial, sans-serif;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"root\"></div>\n\n    <script type=\"text/babel\">\n        const App = () => {\n            return (\n                <div className=\"min-h-screen flex flex-col\">\n                    <Header />\n                    <div className=\"flex-grow p-6 flex gap-6\">\n                        <StepsPanel />\n                        <div className=\"w-1/3 space-y-6\">\n                            <LiveParameters />\n                            <Timeline />\n                        </div>\n                    </div>\n                    <Footer />\n                </div>\n            );\n        };\n\n        const Header = () => {\n            return (\n                <header className=\"bg-[#13314f] text-white px-6 py-4\">\n                    <div className=\"flex justify-between items-center\">\n                        <div className=\"flex items-center space-x-4\">\n                            <div className=\"bg-green-700 p-2 rounded-md\">\n                                <i className=\"fas fa-clock text-white\"></i>\n                            </div>\n                            <div>\n                                <h1 className=\"text-xl font-bold\">Batch Recipe Management</h1>\n                                <p className=\"text-sm text-gray-300\">Recipe: R-204 · Lot 2026-017 · Batch operator: A. Petrov</p>\n                            </div>\n                        </div>\n                        <div className=\"bg-blue-800 px-4 py-2 rounded-md text-sm\">\n                            2026-04-19 14:32:07 MSK\n                        </div>\n                    </div>\n                </header>\n            );\n        };\n\n        const StepsPanel = () => {\n            const steps = [\n                { id: 1, name: \"Pre-heat\", duration: \"10 min\", status: \"DONE\" },\n                { id: 2, name: \"Fill base\", duration: \"8 min\", status: \"DONE\" },\n                { id: 3, name: \"Mix\", duration: \"15 min\", status: \"ACTIVE\" },\n                { id: 4, name: \"Add catalyst\", duration: \"4 min\", status: \"PENDING\" },\n                { id: 5, name: \"Hold\", duration: \"20 min\", status: \"PENDING\" },\n                { id: 6, name: \"Cool down\", duration: \"12 min\", status: \"PENDING\" },\n                { id: 7, name: \"Discharge\", duration: \"6 min\", status: \"PENDING\" }\n            ];\n\n            return (\n                <div className=\"w-2/3 bg-white rounded-lg border border-gray-200 p-6\">\n                    <h2 className=\"text-lg font-bold text-gray-800 mb-4\">Steps</h2>\n                    <div className=\"overflow-x-auto\">\n                        <table className=\"w-full border-collapse\">\n                            <thead>\n                                <tr className=\"bg-gray-100\">\n                                    <th className=\"text-left py-2 px-4 border-b\">#</th>\n                                    <th className=\"text-left py-2 px-4 border-b\">Step</th>\n                                    <th className=\"text-left py-2 px-4 border-b\">Duration</th>\n                                    <th className=\"text-left py-2 px-4 border-b\">Status</th>\n                                    <th className=\"text-left py-2 px-4 border-b\">Action</th>\n                                </tr>\n                            </thead>\n                            <tbody>\n                                {steps.map(step => (\n                                    <tr key={step.id} className=\"border-b hover:bg-gray-50\">\n                                        <td className=\"py-3 px-4\">{step.id}</td>\n                                        <td className=\"py-3 px-4 font-medium\">{step.name}</td>\n                                        <td className=\"py-3 px-4\">{step.duration}</td>\n                                        <td className=\"py-3 px-4\">\n                                            <span className={`inline-block px-6 py-1 text-white text-xs font-medium rounded ${\n                                                step.status === \"DONE\" ? \"bg-green-700\" :\n                                                step.status === \"ACTIVE\" ? \"bg-blue-600\" : \"bg-gray-600\"\n                                            }`}>\n                                                {step.status}\n                                            </span>\n                                        </td>\n                                        <td className=\"py-3 px-4\">\n                                            <button className=\"border border-gray-400 text-gray-800 px-6 py-1 rounded hover:bg-gray-50 text-sm font-medium\">\n                                                View\n                                            </button>\n                                        </td>\n                                    </tr>\n                                ))}\n                            </tbody>\n                        </table>\n                    </div>\n                </div>\n            );\n        };\n\n        const LiveParameters = () => {\n            return (\n                <div className=\"bg-white rounded-lg border border-gray-200 p-6\">\n                    <h2 className=\"text-lg font-bold text-gray-800 mb-4\">Live parameters</h2>\n                    <div className=\"grid grid-cols-2 gap-4\">\n                        <div className=\"border rounded-lg p-4\">\n                            <div className=\"text-sm text-gray-500 mb-1\">Temperature</div>\n                            <div className=\"flex items-baseline\">\n                                <span className=\"text-4xl font-medium text-gray-800\">65.4</span>\n                                <span className=\"text-2xl text-gray-600 ml-2\">°C</span>\n                            </div>\n                            <div className=\"mt-2\">\n                                <span className=\"bg-green-700 text-white text-xs px-4 py-0.5 rounded\">OK</span>\n                            </div>\n                        </div>\n                        \n                        <div className=\"border rounded-lg p-4\">\n                            <div className=\"text-sm text-gray-500 mb-1\">pH</div>\n                            <div className=\"text-4xl font-medium text-gray-800\">7.1</div>\n                            <div className=\"mt-2\">\n                                <span className=\"bg-green-700 text-white text-xs px-4 py-0.5 rounded\">OK</span>\n                            </div>\n                        </div>\n                        \n                        <div className=\"border rounded-lg p-4\">\n                            <div className=\"text-sm text-gray-500 mb-1\">RPM</div>\n                            <div className=\"text-4xl font-medium text-gray-800\">240</div>\n                            <div className=\"mt-2\">\n                                <span className=\"bg-green-700 text-white text-xs px-4 py-0.5 rounded\">OK</span>\n                            </div>\n                        </div>\n                        \n                        <div className=\"border rounded-lg p-4\">\n                            <div className=\"text-sm text-gray-500 mb-1\">Pressure</div>\n                            <div className=\"flex items-baseline\">\n                                <span className=\"text-4xl font-medium text-gray-800\">1.18</span>\n                                <span className=\"text-2xl text-gray-600 ml-2\">bar</span>\n                            </div>\n                            <div className=\"mt-2\">\n                                <span className=\"bg-orange-600 text-white text-xs px-4 py-0.5 rounded\">WARN</span>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            );\n        };\n\n        const Timeline = () => {\n            return (\n                <div className=\"bg-white rounded-lg border border-gray-200 p-6\">\n                    <h2 className=\"text-lg font-bold text-gray-800 mb-6\">Timeline</h2>\n                    \n                    <div className=\"flex justify-between items-center mb-8\">\n                        <div className=\"flex items-center\">\n                            <div className=\"w-8 h-8 rounded-full bg-green-700 text-white flex items-center justify-center text-sm font-medium\">\n                                1\n                            </div>\n                            <span className=\"ml-2 text-xs text-gray-500\">10m</span>\n                        </div>\n                        \n                        <div className=\"flex items-center\">\n                            <div className=\"w-8 h-8 rounded-full bg-green-700 text-white flex items-center justify-center text-sm font-medium\">\n                                2\n                            </div>\n                            <span className=\"ml-2 text-xs text-gray-500\">8m</span>\n                        </div>\n                        \n                        <div className=\"flex items-center\">\n                            <div className=\"w-8 h-8 rounded-full bg-blue-600 text-white flex items-center justify-center text-sm font-medium\">\n                                3\n                            </div>\n                            <span className=\"ml-2 text-xs text-gray-500\">15m</span>\n                        </div>\n                        \n                        <div className=\"flex items-center\">\n                            <div className=\"w-8 h-8 rounded-full bg-gray-500 text-white flex items-center justify-center text-sm font-medium\">\n                                4\n                            </div>\n                            <span className=\"ml-2 text-xs text-gray-500\">4m</span>\n                        </div>\n                        \n                        <div className=\"flex items-center\">\n                            <div className=\"w-8 h-8 rounded-full bg-gray-500 text-white flex items-center justify-center text-sm font-medium\">\n                                5\n                            </div>\n                            <span className=\"ml-2 text-xs text-gray-500\">20m</span>\n                        </div>\n                        \n                        <div className=\"flex items-center\">\n                            <div className=\"w-8 h-8 rounded-full bg-gray-500 text-white flex items-center justify-center text-sm font-medium\">\n                                6\n                            </div>\n                            <span className=\"ml-2 text-xs text-gray-500\">12m</span>\n                        </div>\n                        \n                        <div className=\"flex items-center\">\n                            <div className=\"w-8 h-8 rounded-full bg-gray-500 text-white flex items-center justify-center text-sm font-medium\">\n                                7\n                            </div>\n                            <span className=\"ml-2 text-xs text-gray-500\">6m</span>\n                        </div>\n                    </div>\n                    \n                    <div className=\"flex space-x-4 mt-16\">\n                        <button className=\"flex-1 bg-green-700 hover:bg-green-800 text-white font-bold py-3 px-4 rounded\">\n                            RESUME\n                        </button>\n                        <button className=\"flex-1 bg-orange-600 hover:bg-orange-700 text-white font-bold py-3 px-4 rounded\">\n                            HOLD\n                        </button>\n                        <button className=\"flex-1 bg-red-600 hover:bg-red-700 text-white font-bold py-3 px-4 rounded\">\n                            ABORT\n                        </button>\n                    </div>\n                </div>\n            );\n        };\n\n        const Footer = () => {\n            return (\n                <footer className=\"bg-gray-100 py-3 px-6 border-t\">\n                    <div className=\"text-xs text-gray-500\">\n                        Recipe R-204 · Step 3 of 7 ACTIVE · Compliance: ANSI/ISA-101.01\n                    </div>\n                </footer>\n            );\n        };\n\n        ReactDOM.render(<App />, document.getElementById('root'));\n    </script>\n</body>\n</html>",
