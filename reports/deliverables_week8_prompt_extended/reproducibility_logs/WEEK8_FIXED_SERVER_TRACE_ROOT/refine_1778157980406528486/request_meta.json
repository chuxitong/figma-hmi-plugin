    "current_code": "<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Production Line A — Overview</title>\n    <script src=\"https://cdn.jsdelivr.net/npm/react@18.0.0/umd/react.development.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/react-dom@18.0.0/umd/react-dom.development.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/@babel/standalone/babel.js\"></script>\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css\">\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            background-color: #f0f2f5;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"root\"></div>\n\n    <script type=\"text/babel\">\n        const App = () => {\n            return (\n                <div className=\"min-h-screen bg-gray-50\">\n                    <Header />\n                    <div className=\"container mx-auto p-4 flex gap-4\">\n                        <div className=\"w-3/4\">\n                            <ProcessFlow />\n                            <div className=\"mt-4 grid grid-cols-4 gap-2\">\n                                <MetricCard title=\"OEE\" value=\"82.5\" change=\"+1.2 за месяц\" borderColor=\"border-l-4 border-green-800\" />\n                                <MetricCard title=\"Units / h\" value=\"12480\" change=\"+340 за месяц\" borderColor=\"border-l-4 border-green-800\" />\n                                <MetricCard title=\"Reject\" value=\"0.6\" change=\"-0.1 за месяц\" borderColor=\"border-l-4 border-orange-500\" />\n                                <MetricCard title=\"Energy\" value=\"742\" change=\"+18 за месяц\" borderColor=\"border-l-4 border-orange-500\" />\n                            </div>\n                            <TrendChart />\n                        </div>\n                        <div className=\"w-1/4\">\n                            <AlarmsPanel />\n                        </div>\n                    </div>\n                    <Footer />\n                </div>\n            );\n        };\n\n        const Header = () => {\n            return (\n                <div className=\"bg-blue-900 text-white py-3 px-6\">\n                    <div className=\"flex justify-between items-center\">\n                        <div>\n                            <h1 className=\"text-xl font-semibold\">Production Line A — Overview</h1>\n                            <p className=\"text-xs mt-1\">Shift: Assembly 2 - Shift B - Operator: A. Petrov</p>\n                        </div>\n                        <div className=\"flex items-center space-x-1\">\n                            <button className=\"px-6 py-1 rounded-full bg-blue-800 text-white text-sm\">Overview</button>\n                            <button className=\"px-6 py-1 rounded-full text-gray-300 hover:bg-blue-800 text-sm\">Alarms</button>\n                            <button className=\"px-6 py-1 rounded-full text-gray-300 hover:bg-blue-800 text-sm\">Tends</button>\n                            <button className=\"px-6 py-1 rounded-full text-gray-300 hover:bg-blue-800 text-sm\">Operator</button>\n                        </div>\n                        <div className=\"bg-blue-800 px-4 py-2 rounded-md text-sm\">\n                            2026-04-19 14:32:07 MSK\n                        </div>\n                    </div>\n                </div>\n            );\n        };\n\n        const ProcessFlow = () => {\n            return (\n                <div className=\"bg-white rounded-lg border border-gray-200 p-6\">\n                    <div className=\"mb-4\">\n                        <h2 className=\"text-md font-semibold text-gray-900\">Process flow — Line A</h2>\n                        <p className=\"text-xs text-gray-500 mt-1\">Source: ThingsBoard SCADA symbol library — fluid system pack</p>\n                    </div>\n                    \n                    <div className=\"relative py-8\">\n                        {/* Percentage indicators */}\n                        <span className=\"absolute left-16 top-8 text-xs text-gray-600\">72%</span>\n                        <span className=\"absolute right-16 top-8 text-xs text-gray-600\">41%</span>\n                        \n                        {/* Process Flow Diagram */}\n                        <div className=\"flex items-center justify-between\">\n                            {/* T-101 Tank */}\n                            <div className=\"flex flex-col items-center\">\n                                <div className=\"w-20 h-32 relative\">\n                                    <div className=\"absolute bottom-0 w-12 h-24 bg-gray-300 rounded-l-md left-1/2 transform -translate-x-1/2\"></div>\n                                    <div className=\"absolute bottom-0 w-12 h-20 bg-green-700 left-1/2 transform -translate-x-1/2\"></div>\n                                    <div className=\"absolute bottom-0 w-full h-2 bg-gray-400\"></div>\n                                </div>\n                                <span className=\"mt-2 text-xs text-gray-600\">T-101</span>\n                            </div>\n                            \n                            {/* P-101 Pump */}\n                            <div className=\"flex items-center\">\n                                <div className=\"w-12 h-12 rounded-full border-2 border-gray-400 flex items-center justify-center\">\n                                    <div className=\"w-8 h-8 rounded-full bg-green-600\"></div>\n                                </div>\n                                <span className=\"ml-2 text-xs text-gray-600\">P-101</span>\n                            </div>\n                            \n                            {/* V-201 Valve */}\n                            <div className=\"flex items-center\">\n                                <div className=\"w-10 h-10 border-2 border-gray-400 flex items-center justify-center\">\n                                    <div className=\"w-6 h-6 bg-green-600 relative\">\n                                        <div className=\"absolute -top-1 left-1/2 transform -translate-x-1/2 w-1 h--3 bg-green-800\"></div>\n                                        <div className=\"absolute -right-1 top-1/2 transform -translate-y-1/2 w-3 h-1 bg-green-800\"></div>\n                                    </div>\n                                </div>\n                                <span className=\"ml-2 text-xs text-gray-600\">V-201</span>\n                            </div>\n                            \n                            {/* P-102 Pipe */}\n                            <div className=\"flex items-center\">\n                                <div className=\"w-12 h-6 border-t-2 border-l-2 border-r-2 border-gray-400\"></div>\n                                <span className=\"ml-2 text-xs text-gray-600\">P-102</span>\n                            </div>\n                            \n                            {/* V-202 Valve */}\n                            <div className=\"flex items-center\">\n                                <div className=\"w-10 h-10 border-2 border-gray-400 flex items-center justify-center\">\n                                    <div className=\"w-6 h-6 rounded-full bg-orange-500 relative\">\n                                        <div className=\"absolute -top-1 left-1/2 transform -translate-x-1/2 w-1 h--3 bg-orange-700\"></div>\n                                        <div className=\"absolute -right-1 top-1/2 transform -translate-y-1/2 w-3 h-1 bg-orange-700\"></div>\n                                    </div>\n                                </div>\n                                <span className=\"ml-2 text-xs text-gray-600\">V-202</span>\n                            </div>\n                            \n                            {/* Separator S-1 */}\n                            <div className=\"flex flex-col items-center\">\n                                <div className=\"w-32 h-20 relative\">\n                                    <div className=\"absolute inset-0 rounded-full bg-gray-400\"></div>\n                                    <div className=\"absolute inset-0 rounded-full bg-green-600 opacity-70\"></div>\n                                    <div className=\"absolute bottom-0 w-full h-4 bg-gray-400 rounded-b-full\"></div>\n                                    <span className=\"absolute text-xs text-gray-700 w-full text-center mt-6\">SEPARATOR S-1</span>\n                                </div>\n                            </div>\n                            \n                            {/* T-102 Tank */}\n                            <div className=\"flex flex-col items-center\">\n                                <div className=\"w-20 h-32 relative\">\n                                    <div className=\"absolute bottom-0 w-12 h-24 bg-gray-300 rounded-l-md left-1/2 transform -translate-x-1/2\"></div>\n                                    <div className=\"absolute bottom-0 w-12 h-12 bg-green-700 left-1/2 transform -translate-x-1/2\"></div>\n                                </div>\n                                <span className=\"mt-2 text-xs text-gray-600\">T-102</span>\n                            </div>\n                        </div>\n                        \n                        {/* Temperature Indicators */}\n                        <div className=\"flex justify-around mt-8\">\n                            <div className=\"flex flex-col items-center\">\n                                <div className=\"w-10 h-10 rounded-full border-2 border-gray-400 flex items-center justify-center\">\n                                    <div className=\"w-7 h-7 rounded-full bg-green-600 flex items-center justify-center text-white text-xs font-bold\">T</div>\n                                </div>\n                                <span className=\"mt-2 text-xs text-gray-600\">72 °C</span>\n                            </div>\n                            <div className=\"flex flex-col items-center\">\n                                <div className=\"w-10 h-10 rounded-full border-2 border-gray-400 flex items-center justify-center\">\n                                    <div className=\"w-7 h-7 rounded-full bg-green-600 flex items-center justify-center text-white text-xs font-bold\">T</div>\n                                </div>\n                                <span className=\"mt-2 text-xs text-gray-600\">3.4 bar</span>\n                            </div>\n                            <div className=\"flex flex-col items-center\">\n                                <div className=\"w-10 h-10 rounded-full border-2 border-gray-400 flex items-center justify-center\">\n                                    <div className=\"w-7 h-7 rounded-full bg-red-600 flex items-center justify-center text-white text-xs font-bold\">T</div>\n                                </div>\n                                <span className=\"mt-2 text-xs text-gray-600\">94 °C</span>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            );\n        };\n\n        const MetricCard = ({ title, value, change, borderColor }) => {\n            return (\n                <div className={`bg-white rounded border border-gray-200 p-4 ${borderColor}`}>\n                    <div className=\"text-xs text-gray-600\">{title}</div>\n                    <div className=\"text-3xl font-bold text-gray-900\">{value}</div>\n                    <div className=\"text-xs text-gray-600 mt-1\">\n                        <span className=\"text-green-600\">▲</span> {change}\n                    </div>\n                </div>\n            );\n        };\n\n        const TrendChart = () => {\n            return (\n                <div className=\"bg-white rounded-lg border border-gray-200 p-4 mt-4\">\n                    <div className=\"flex justify-between items-center mb-4\">\n                        <h2 className=\"text-md font-semibold text-gray-900\">Real-time trend — last 60 min</h2>\n                        <div className=\"flex items-center space-x-4 text-xs\">\n                            <div className=\"flex items-center\">\n                                <div className=\"w-4 h-2 bg-green-700 mr-1\"></div>\n                                <span>Temp</span>\n                            </div>\n                            <div className=\"flex items-center\">\n                                <div className=\"w-4 h-2 bg-orange-500 mr-1\"></div>\n                                <span>Pressure</span>\n                            </div>\n                            <div className=\"flex items-center\">\n                                <div className=\"w-4 h-2 bg-red-700 mr-1\"></div>\n                                <span>Flow</span>\n                            </div>\n                        </div>\n                    </div>\n                    <div className=\"h-24 w-full relative border-b border-l border-gray-200\">\n                        {/* Simple chart representation */}\n                        <div className=\"w-full h-full relative\">\n                            <svg className=\"w-full h-full\" viewBox=\"0 0 1000 100\" preserveAspectRatio=\"none\">\n                                <path d=\"M0,70 C100,65 200,60 300,65 C400,70 500,45 600,30 C700,50 800,40 900,35 L1000,40\" \n                                      stroke=\"#2e7d32\" strokeWidth=\"2\" fill=\"none\" />\n                                <path d=\"M0,80 C100,78 200,75 300,70 C400,65 500,60 600,58 C700,55 800,50 900,45 L1000,40\" \n                                      stroke=\"#f9a825\" strokeWidth=\"2\" fill=\"none\" />\n                                <path d=\"M0,90 C100,88 200,85 300,87 C400,90 500,92 600,88 C700,84 800,82 900,78 L1000,75\" \n                                      stroke=\"#d32f2f\" strokeWidth=\"2\" fill=\"none\" />\n                            </svg>\n                        </div>\n                    </div>\n                </div>\n            );\n        };\n\n        const AlarmsPanel = () => {\n            const alarms = [\n                { time: \"14:31\", id: \"TT-301\", description: \"Motor temperature high\", type: \"ALARM\" },\n                { time: \"14:28\", id: \"PT-102\", description: \"Discharge pressure\", type: \"ALARM\" },\n                { time: \"14:22\", id: \"FT-401\", description: \"Flow rate deviation\", type: \"WARN\" },\n                { time: \"14:15\", id: \"CT-502\", description: \"Cooling water temp\", type: \"WARN\" },\n                { time: \"14:05\", id: \"PDT-201\", description: \"Filter ΔP\", type: \"INFO\" }\n            ];\n\n            return (\n                <div className=\"bg-white rounded-lg border border-gray-200 p-4\">\n                    <div className=\"flex justify-between items-center mb-4\">\n                        <h2 className=\"text-md font-semibold text-gray-900\">Active alarms</h2>\n                        <span className=\"text-xs text-gray-500\">3 of 14</span>\n                    </div>\n                    <div className=\"space-y-3\">\n                        {alarms.map((alarm, index) => (\n                            <AlarmItem key={index} alarm={alarm} />\n                        ))}\n                    </div>\n                </div>\n            );\n        };\n\n        const AlarmItem = ({ alarm }) => {\n            return (\n                <div className=\"border border-gray-200 rounded-md p-3\">\n                    <div className=\"flex justify-between items-center\">\n                        <div className=\"flex items-center space-x-4\">\n                            <span className=\"text-xs text-gray-500\">{alarm.time}</span>\n                            <span className=\"text-xs text-gray-700\">{alarm.id}</span>\n                        </div>\n                        <button className=\"px-6 py-1 rounded-md text-sm font-medium border border-gray-300 hover:bg-gray-50 text-gray-900\">\n                            ACK\n                        </button>\n                    </div>\n                    <div className=\"mt-2\">\n                        <span className=\"text-sm text-gray-700\">{alarm.description}</span>\n                        <div className=\"mt-1\">\n                            <span className={`text-xs px-2 py-0.5 rounded-sm ${\n                                alarm.type === 'ALARM' ? 'bg-red-600 text-white' : \n                                alarm.type === 'WARN' ? 'bg-orange-500 text-white' : \n                                'bg-blue-600 text-white'\n                            }`}>\n                                {alarm.type}\n                            </span>\n                        </div>\n                    </div>\n                </div>\n            );\n        };\n\n        const Footer = () => {\n            return (\n                <footer className=\"bg-gray-100 py-3 px-6 border-t border-gray-200 mt-6\">\n                    <div className=\"text-xs text-gray-500\">\n                        Connection: OK · Latency: 18 ms · Logged in as A. Petrov · ThingsBoard SCADA glyphs imported via 00_raw_svg\n                    </div>\n                </footer>\n            );\n        };\n\n        ReactDOM.render(<App />, document.getElementById('root'));\n    </script>\n</body>\n</html>",
