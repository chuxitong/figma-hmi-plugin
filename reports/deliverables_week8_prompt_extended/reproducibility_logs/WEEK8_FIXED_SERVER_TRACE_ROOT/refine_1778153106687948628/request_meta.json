nery2/U9/F-902\"\n                                    />\n                                    <AlarmRow \n                                        severity=\"INFO\"\n                                        time=\"13:54:22\"\n                                        tag=\"CT-101\"\n                                        description=\"Communication restored\"\n                                        value=\"—\"\n                                        unit=\"\"\n                                        source=\"Bus/CT-101\"\n                                    />\n                                </tbody>\n                            </table>\n                        </div>\n                    </div>\n\n                    {/* Footer */}\n                    <div className=\"bg-gray-100 border-t border-gray-200 py-4 px-6 mt-8\">\n                        <div className=\"text-xs text-gray-500\">\n                            Connection: OK · Latency: 22 ms · Compliance: ANSI/ISA-101.01-2015 — colour + text + shape encoding for every state\n                        </div>\n                    </div>\n                </div>\n            );\n        };\n\n        ReactDOM.render(<App />, document.getElementById('root'));\n    </script>\n</body>\n</html>",
