ce-x-2\">\n                                <i className=\"fas fa-flask text-xl\"></i>\n                                <h1 className=\"text-2xl font-semibold\">Batch Recipe Management</h1>\n                            </div>\n                            <p className=\"text-sm text-gray-300 mt-1\">\n                                Recipe: R-204 · Lot 2026-017 · Batch operator: A. Petrov\n                            </p>\n                        </div>\n                        <div className=\"bg-[#1c3b73] px-4 py-2 rounded-md text-sm text-gray-300\">\n                            2026-04-19 14:32:07 MSK\n                        </div>\n                    </div>\n                </header>\n            );\n        };\n\n        const StepsSection = () => {\n            const steps = [\n                { id: 1, step: \"Pre-heat\", duration: \"10 min\", status: \"DONE\", statusColor: \"bg-green-700\" },\n                { id: 2, step: \"Fill base\", duration: \"8 min\", status: \"DONE\", statusColor: \"bg-green-700\" },\n                { id: 3, step: \"Mix\", duration: \"15 min\", status: \"ACTIVE\", statusColor: \"bg-blue-600\" },\n                { id: 4, step: \"Add catalyst\", duration: \"4 min\", status: \"PENDING\", statusColor: \"bg-gray-600\" },\n                { id: 5, step: \"Hold\", duration: \"20 min\", status: \"PENDING\", statusColor: \"bg-gray-600\" },\n                { id: 6, step: \"Cool down\", duration: \"12 min\", status: \"PENDING\", statusColor: \"bg-gray-600\" },\n                { id: 7, step: \"Discharge\", duration: \"6 min\", status: \"PENDING\", statusColor: \"bg-gray-600\" }\n            ];\n\n            return (\n                <div>\n                    <h2 className=\"text-lg font-semibold text-gray-800 mb-4\">Steps</h2>\n                    <div className=\"overflow-x-auto\">\n                        <table className=\"w-full border-collapse\">\n                            <thead>\n                                <tr className=\"bg-gray-100\">\n                                    <th className=\"text-left py-2 px-4 text-sm font-medium text-gray-600 border-b\">#</th>\n                                    <th className=\"text-left py-2 px-4 text-sm font-medium text-gray-600 border-b\">Step</th>\n                                    <th className=\"text-left py-2 px-4 text-sm font-medium text-gray-600 border-b\">Duration</th>\n                                    <th className=\"text-left py-2 px-4 text-sm font-medium text-gray-600 border-b\">Status</th>\n                                    <th className=\"text-left py-2 px-4 text-sm font-medium text-gray-600 border-b\">Action</th>\n                                </tr>\n                            </thead>\n                            <tbody>\n                                {steps.map((step) => (\n                                    <tr key={step.id} className=\"border-b hover:bg-gray-50\">\n                                        <td className=\"py-3 px-4 text-gray-800\">{step.id}</td>\n                                        <td className=\"py-3 px-4 font-medium text-gray-800\">{step.step}</td>\n                                        <td className=\"py-3 px-4 text-gray-600\">{step.duration}</td>\n                                        <td className=\"py-3 px-4\">\n                                            <span className={`${step.statusColor} text-white text-xs px-8 py-1 rounded capitalize`}>\n                                                {step.status}\n                                            </span>\n                                        </td>\n                                        <td className=\"py-3 px-4\">\n                                            <button className=\"border border-gray-400 text-gray-800 px-6 py-1 rounded hover:bg-gray-50 font-medium\">\n                                                View\n                                            </button>\n                                        </td>\n                                    </tr>\n                                ))}\n                            </tbody>\n                        </table>\n                    </div>\n                </div>\n            );\n        };\n\n        const LiveParameters = () => {\n            const parameters = [\n                { label: \"Temperature\", value: \"65.4\", unit: \"°C\", status: \"OK\", statusColor: \"bg-green-700\" },\n                { label: \"pH\", value: \"7.1\", unit: \"\", status: \"OK\", statusColor: \"bg-green-700\" },\n                { label: \"RPM\", value: \"240\", unit: \"\", status: \"OK\", statusColor: \"bg-green-700\" },\n                { label: \"Pressure\", value: \"1.18\", unit: \"bar\", status: \"WARN\", statusColor: \"bg-orange-500\" }\n            ];\n\n            return (\n                <div className=\"bg-white rounded-lg border border-gray-300 p-6\">\n                    <h2 className=\"text-lg font-semibold text-gray-800 mb-4\">Live parameters</h2>\n                    <div className=\"grid grid-cols-2 gap-4\">\n                        {parameters.map((param, index) => (\n                            <div key={index} className=\"border border-gray-300 rounded-lg p-4\">\n                                <div className=\"text-sm text-gray-500 mb-2\">{param.label}</div>\n                                <div className=\"flex items-center space-x-2\">\n                                    <span className=\"text-3xl font-bold text-gray-800\">{param.value}</span>\n                                    {param.unit && <span className=\"text-xl text-gray-600\">{param.unit}</span>}\n                                </div>\n                                <div className=\"mt-2\">\n                                    <span className={`${param.statusColor} text-white text-xs px-8 py-1 rounded capitalize`}>\n                                        {param.status}\n                                    </span>\n                                </div>\n                            </div>\n                        ))}\n                    </div>\n                </div>\n            );\n        };\n\n        const TimelineSection = () => {\n            const timelineItems = [\n                { id: 1, active: false, color: \"bg-gray-500\" }, \n                { id: 2, active: false, color: \"bg-gray-500\" }, \n                { id: 3, active: true, color: \"bg-green-600\" }, \n                { id: 4, active: false, color: \"bg-gray-500\" }, \n                { id: 5, active: false, color: \"bg-gray-500\" }, \n                { id: 6, active: false, color: \"bg-gray-500\" }, \n                { id: 7, active: false, color: \"bg-gray-500\" }\n\n            ];\n\n            return (\n                <div className=\"bg-white rounded-lg border border-gray-300 p-6\">\n                    <h2 className=\"text-lg font-semibold text-gray-800 mb-4\">Timeline</h2>\n                    <div className=\"flex justify-between items-center space-x-4 mb-8\">\n                        {timelineItems.map((item) => (\n                            <div key={item.id} className=\"flex flex-col items-center\">\n                                <div className={`w-8 h-8 rounded-full ${item.color} text-white flex items-center justify-center font-medium text-sm`}>\n                                    {item.id}\n                                </div>\n                                <div className=\"text-xs text-gray-500 mt-2\">\n                                    {item.id === 3 ? '15m' : \n                                     item.id === 1 ? '10m' : \n                                     item.id === 2 ? '8m' : \n                                     item.id === 4 ? '4m' : \n                                     item.id === 5 ? '20m' : \n                                     item.id === 6 ? '12m' : '6m'}\n                                </div>\n                            </div>\n                        ))}\n                    </div>\n                    <div className=\"flex space-x-4 pt-4\">\n                        <button className=\"flex-1 bg-green-700 text-white py-3 px-4 rounded font-bold hover:bg-green-800\">\n                            RESUME\n                        </button>\n                        <button className=\"flex-1 bg-orange-500 text-white py-3 px-4 rounded font-bold hover:bg-orange-600\">\n                            HOLD\n                        </button>\n                        <button className=\"flex-1 bg-red-600 text-white py-3 px-4 rounded font-bold hover:bg-red-700\">\n                            ABORT\n                        </button>\n                    </div>\n                </div>\n            );\n        };\n\n        const Footer = () => {\n            return (\n                <footer className=\"bg-gray-100 border-t border-gray-300 py-4 px-6\">\n                    <div className=\"text-sm text-gray-500\">\n                        Recipe R-204 · Step 3 of 7 ACTIVE · Compliance: ANSI/ISA-101.01\n                    </div>\n                </footer>\n            );\n        };\n\n        ReactDOM.render(<App />, document.getElementById('root'));\n    </script>\n</body>\n</html>",
