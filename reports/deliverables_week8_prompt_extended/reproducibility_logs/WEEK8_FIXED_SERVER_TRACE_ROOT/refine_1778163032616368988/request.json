enter justify-between py-3 border-b border-gray-100 last:border-b-0\">\n                    <div className=\"w-16 text-sm font-medium text-gray-800\">{zone}</div>\n                    <div className=\"flex-1 mx-6\">\n                        <div className=\"w-full bg-gray-100 rounded-full h-6\">\n                            <div \n                                className=\"h-6 rounded-full bg-green-600\" \n                                style={{width: `${percentage}%`}}\n                            ></div>\n                        </div>\n                    </div>\n                    <div className=\"w-16 text-right\">\n                        <span className=\"text-sm text-gray-600\">{percentage}%</span>\n                    </div>\n                    <div className=\"w-20 ml-4\">\n                        <span className={`px-4 py-1 rounded text-xs text-white ${getStatusColor()}`}>\n                            {status}\n                        </span>\n                    </div>\n                </div>\n            );\n        };\n\n        const DonutChart = () => {\n            return (\n                <div className=\"relative w-64 h-64 mx-auto\">\n                    <svg className=\"w-64 h-64 transform -rotate-90\" viewBox=\"0 0 160 160\">\n                        <circle\n                            cx=\"80\"\n                            cy=\"80\"\n                            r=\"60\"\n                            fill=\"none\"\n                            stroke=\"#2e7d32\"\n                            strokeWidth=\"16\"\n                            strokeDasharray=\"269.28 0\"\n                            strokeDashoffset=\"0\"\n                        />\n                        <circle\n                            cx=\"80\"\n                            cy=\"80\"\n                            r=\"60\"\n                            fill=\"none\"\n                            stroke=\"#1976d2\"\n                            strokeWidth=\"16\"\n             