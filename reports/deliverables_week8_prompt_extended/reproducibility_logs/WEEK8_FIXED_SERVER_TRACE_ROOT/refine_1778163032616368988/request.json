te-300 mt-1\">Industrial-2 - Day shift - All zones</p>\n                            </div>\n                            <div className=\"bg-slate-700 rounded-md px-4 py-2 text-sm text-slate-300\">\n                                2026-04-19 14:32:07 MSK\n                            </div>\n                        </div>\n                    </div>\n\n                    {/* Metrics Cards */}\n                    <div className=\"p-6 bg-gray-50\">\n                        <div className=\"grid grid-cols-4 gap-6 mb-6\">\n                            <MetricCard title=\"Total kWh\" value=\"12 845\" change=\"+340 за смену\" color=\"green\" />\n                            <MetricCard title=\"Peak load\" value=\"742\" change=\"+18 за смену\" color=\"orange\" />\n                            <MetricCard title=\"Cost (today)\" value=\"€ 1 932\" change=\"+78 за смену\" color=\"orange\" />\n                            <MetricCard title=\"Power factor\" value=\"0.92\" change=\"+0.01 за смену\" color=\"green\" />\n                        </div>\n\n                        {/* Main Content Grid */}\n                        <div className=\"grid grid-cols-2 gap-6\">\n                            {/* Power Consumption by Zone */}\n                            <div className=\"bg-white rounded-lg border border-gray-200 p-6\">\n                                <h2 className=\"text-lg font-semibold text-gray-800 mb-4\">Power consumption by zone</h2>\n                                <div>\n                                    {zoneData.map((item, index) => (\n                                        <ZoneRow \n                                            key={index}\n                                            zone={item.zone}\n                                            percentage={item.percentage}\n                                            status={item.status}\n                                        />\n                                    ))}\n                                </div>\n     