-4 py-3 text-sm font-medium text-gray-700\">Tag</th>\n                                        <th className=\"text-left px-4 py-3 text-sm font-medium text-gray-700\">Description</th>\n                                        <th className=\"text-left px-4 py-3 text-sm font-medium text-gray-700\">Value</th>\n                                        <th className=\"text-left px-4 py-3 text-sm font-medium text-gray-700\">Source</th>\n                                        <th className=\"text-left px-4 py-3 text-sm font-medium text-gray-700\">Action</th>\n                                    </tr>\n                                </thead>\n                                <tbody>\n                                    {alarms.map((alarm, index) => (\n                                        <AlarmRow key={index} {...alarm} />\n                                    ))}\n                                </tbody>\n                            </table>\n                            \n                            <div className=\"p-4 border-t bg-gray-50\">\n                                <div className=\"text-xs text-gray-500\">\n                                    Connection: OK · Latency: 22 ms · Compliance: ANSI/ISA-101.01-2015 — colour + text + shape encoding for every state\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            );\n        };\n\n        ReactDOM.render(<App />, document.getElementById('root'));\n    </script>\n</body>\n</html>",
