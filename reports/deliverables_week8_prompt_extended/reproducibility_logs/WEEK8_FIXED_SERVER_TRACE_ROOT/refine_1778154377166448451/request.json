e=\"border-b hover:bg-gray-50\">\n                    <td className=\"px-4 py-3\">\n                        <span className={`px-3 py-1 rounded text-xs font-medium ${getSeverityStyle(severity)}`}>\n                            {severity.toUpperCase()}\n                        </span>\n                    </td>\n                    <td className=\"px-4 py-3 text-sm text-gray-700\">{time}</td>\n                    <td className=\"px-4 py-3 text-sm font-medium text-gray-900\">{tag}</td>\n                    <td className=\"px-4 py-3 text-sm text-gray-700\">{description}</td>\n                    <td className=\"px-4 py-3 text-sm text-gray-700\">\n                        <span className=\"font-medium\">{value}</span> {unit}\n                    </td>\n                    <td className=\"px-4 py-3 text-sm text-gray-500\">{source}</td>\n                    <td className=\"px-4 py-3\">\n                        <div className=\"flex space-x-2\">\n                            <button className=\"px-4 py-1 border border-gray-300 rounded text-sm font-medium text-gray-700 hover:bg-gray-50\">\n                                ACK\n                            </button>\n                            <button className=\"px-4 py-1 border border-gray-300 rounded text-sm font-medium text-gray-700 hover:bg-gray-50\">\n                                View\n                            </button>\n                        </div>\n                    </td>\n                </tr>\n            );\n        };\n\n        const App = () => {\n            const alarms = [\n                {\n                    severity: 'CRITICAL',\n                    time: '14:31:42',\n                    tag: 'TT-301',\n                    description: 'Motor temperature exceeds high-high limit',\n                    value: '94.2',\n                    unit: '°C',\n                    source: 'Refinery2/U2/M-301'\n                },\n                {\n                    severity: 'CRITICAL',\n                   