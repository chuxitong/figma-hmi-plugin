              <StatusCard \n                name=\"Pump P-101\"\n                value=\"1480\"\n                trend=\"+12\"\n                status=\"OK\"\n                borderColor=\"border-green-600\"\n              />\n              \n              <StatusCard \n                name=\"Pump P-102\"\n                value=\"1492\"\n                trend=\"+8\"\n                status=\"OK\"\n                borderColor=\"border-green-600\"\n              />\n              \n              <StatusCard \n                name=\"Compressor C-201\"\n                value=\"3.21\"\n                trend=\"+0.04\"\n                status=\"OK\"\n                borderColor=\"border-green-600\"\n              />\n              \n              <StatusCard \n                name=\"Motor M-301\"\n                value=\"94.2\"\n                trend=\"+5.1\"\n                status=\"ALARM\"\n                borderColor=\"border-red-600\"\n              />\n              \n              <StatusCard \n                name=\"Valve V-102\"\n                value=\"CLOSED\"\n                trend=\"—\"\n                status=\"ALARM\"\n                borderColor=\"border-red-600\"\n              />\n              \n              <StatusCard \n                name=\"Conveyor CV-401\"\n                value=\"0.00\"\n                trend=\"—\"\n                status=\"MAINT\"\n                borderColor=\"border-orange-500\"\n              />\n              \n              <StatusCard \n                name=\"Mixer MX-501\"\n                value=\"240\"\n                trend=\"—\"\n                status=\"IDLE\"\n                borderColor=\"border-gray-500\"\n              />\n              \n              <StatusCard \n                name=\"Heater H-201\"\n                value=\"62.0\"\n                trend=\"-1.2\"\n                status=\"WARN\"\n                borderColor=\"border-orange-500\"\n              />\n              \n              <StatusCard \n   