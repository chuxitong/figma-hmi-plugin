  "code": "<html>\n<head>\n    <script src=\"https://cdn.jsdelivr.net/npm/react@18.0.0/umd/react.development.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/react-dom@18.0.0/umd/react-dom.development.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/@babel/standalone/babel.js\"></script>\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css\">\n    <style>\n        body {\n            font-family: Arial, Sans-serif;\n        }\n    </style>\n</head>\n<body>\n    <div id=\"root\"></div>\n\n    <script type=\"text/babel\">\n        const StatusCard = ({ title, value, unit, trend, status, hasRedBorder }) => {\n            const getStatusBadge = () => {\n                const baseClasses = \"px-3 py-1 text-xs font-semibold rounded\";\n                switch(status) {\n                    case 'OK':\n                        return `${baseClasses} bg-green-700 text-white`;\n                    case 'ALARM':\n                        return `${baseClasses} bg-red-700 text-white`;\n                    case 'MAINT':\n                        return `${baseClasses} bg-orange-500 text-white`;\n                    case 'IDLE':\n                        return `${baseClasses} bg-gray-500 text-white`;\n                    case 'WARN':\n                        return `${baseClasses} bg-orange-600 text-white`;\n                    default:\n                        return `${baseClasses} bg-gray-500 text-white`;\n                }\n            };\n\n            return (\n                <div className={`bg-white rounded-lg border ${hasRedBorder ? 'border-l-4 border-red-600' : 'border-l-4 border-green-700'} p-4 shadow-sm`}>\n                    <div className=\"text-gray-600 text-sm mb-2\">{title}</div>\n                    <div className=\"text-4xl font-bold text-gray-900 mb-2\">\n                        {value}\n                        {unit && <span className=\"text-lg text-gray-600 ml-1\">{unit}</span>}\n                    </div>\n                    <div className=\"text-gray-600 text-xs mb-2\">trend: {trend}</div>\n                    <div>\n                        <span className={getStatusBadge()}>\n                            {status}\n                        </span>\n                    </div>\n                </div>\n            );\n        };\n\n        const App = () => {\n            const statusData = [\n                {\n                    title: \"Pump P-101\",\n                    value: \"1480\",\n                    unit: \"\",\n                    trend: \"+12\",\n                    status: \"OK\",\n                    hasRedBorder: false\n                },\n                {\n                    title: \"Pump P-102\",\n                    value: \"1492\",\n                    unit: \"\",\n                    trend: \"+8\",\n                    status: \"OK\",\n                    hasRedBorder: false\n                },\n                {\n                    title: \"Compressor C-201\",\n                    value: \"3.21\",\n                    unit: \"bar\",\n                    trend: \"+0.04\",\n                    status: \"OK\",\n                    hasRedBorder: false\n                },\n                {\n                    title: \"Motor M-301\",\n                    value: \"94.2\",\n                    unit: \"\",\n                    trend: \"+5.1\",\n                    status: \"ALARM\",\n                    hasRedBorder: true\n                },\n                {\n                    title: \"Valve V-102\",\n                    value: \"CLOSED\",\n                    unit: \"\",\n                    trend: \"—\",\n                    status: \"ALARM\",\n                    hasRedBorder: true\n                },\n                {\n                    title: \"Conveyor CV-401\",\n                    value: \"0.00\",\n                    unit: \"/s\",\n                    trend: \"—\",\n                    status: \"MAINT\",\n                    hasRedBorder: false\n                },\n                {\n                    title: \"Mixer MX-501\",\n                    value: \"240\",\n                    unit: \"\",\n                    trend: \"—\",\n                    status: \"IDLE\",\n                    hasRedBorder: false\n                },\n                {\n                    title: \"Heater H-201\",\n                    value: \"62.0\",\n                    unit: \"\",\n                    trend: \"-1.2\",\n                    status: \"WARN\",\n                    hasRedBorder: false\n                },\n                {\n                    title: \"Tank T-101\",\n                    value: \"72\",\n                    unit: \"\",\n                    trend: \"+2\",\n                    status: \"OK\",\n                    hasRedBorder: false\n                },\n                {\n                    title: \"Tank T-102\",\n                    value: \"41\",\n                    unit: \"\",\n                    trend: \"-1\",\n                    status: \"OK\",\n                    hasRedBorder: false\n                },\n                {\n                    title: \"Sensor T-405\",\n                    value: \"38.5\",\n                    unit: \"\",\n                    trend: \"+0.4\",\n                    status: \"OK\",\n                    hasRedBorder: false\n                },\n                {\n                    title: \"Sensor F-902\",\n                    value: \"180\",\n                    unit: \"/h\",\n                    trend: \"+3\",\n                    status: \"OK\",\n                    hasRedBorder: false\n                }\n            ];\n\n            return (\n                <div className=\"min-h-screen bg-gray-50\">\n                    {/* Header */}\n                    <div className=\"bg-[#0a2e56] text-white px-6 py-4\">\n                        <div className=\"flex justify-between items-center\">\n                            <div>\n                                <h1 className=\"text-2xl font-bold\">Equipment Status Dashboard</h1>\n                                <div className=\"text-gray-300 text-sm mt-1\">Shift: Assembly 2 - Line A - Shift B</div>\n                            </div>\n                            <div className=\"bg-gray-700 bg-opacity-50 px-4 py-2 rounded text-sm\">\n                                2026-04-19 14:32:07 MSK\n                            </div>\n                        </div>\n                    </div>\n\n                    {/* Main Content */}\n                    <div className=\"p-8\">\n                        <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6\">\n                            {statusData.map((item, index) => (\n                                <StatusCard \n                                    key={index}\n                                    title={item.title}\n                                    value={item.value}\n                                    unit={item.unit}\n                                    trend={item.trend}\n                                    status={item.status}\n                                    hasRedBorder={item.hasRedBorder}\n                                />\n                            ))}\n                        </div>\n                    </div>\n\n                    {/* Footer */}\n                    <div className=\"border-t bg-gray-50 px-6 py-3\">\n                        <div className=\"text-gray-600 text-sm\">\n                            Connection: OK - Items: 12 - Critical: 2 - Warnings: 2\n                        </div>\n                    </div>\n                </div>\n            );\n        };\n\n        ReactDOM.render(<App />, document.getElementById('root'));\n    </script>\n</body>\n</html>",
